---
interface CtaItem {
  label: string;
  href: string;
  style: "primary" | "secondary" | "ghost";
}

interface Props {
  title: string;
  description: string;
  backgroundImage: string;
  ctas: CtaItem[];
}

const {
  title = "Supporting You Through Every Step of Your Journey",
  description = "We provide free of charge palliative care and support for families across Leicestershire, Nottinghamshire & Lincolnshire.",
  backgroundImage = "/images/hero-supporting-journey.png",
  ctas = [
    { label: "I am a Patient", href: "#", style: "secondary" },
    { label: "I am a Carer", href: "#", style: "ghost" },
    { label: "I am a Healthcare Professional", href: "#", style: "primary" }
  ]
} = Astro.props as Props;
---

<section class="hero-section" style={`background-image: url('${backgroundImage}')`}>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1>{title}</h1>
    <p>{description}</p>

    <div class="hero-cta-row">
      {
        ctas.map((cta) => (
          <a href={cta.href} class={`btn btn-${cta.style} hero-pill`}>
            {cta.label}
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(16, 34, 58, 0.56) 0%,
      rgba(16, 34, 58, 0.42) 38%,
      rgba(16, 34, 58, 0.58) 100%
    );
  }

  .hero-content {
    position: relative;
    width: min(980px, 92%);
    text-align: center;
    color: var(--color-white);
    padding: 56px 0;
  }

  .hero-content h1 {
    margin: 0;
    font-size: var(--type-hero-title);
    line-height: 1.2;
    letter-spacing: -0.03em;
    font-weight: 700;
    max-width: 760px;
    margin-inline: auto;
  }

  .hero-content p {
    margin: 14px auto 28px;
    max-width: 700px;
    font-size: var(--type-body-large);
    line-height: 1.6;
    font-weight: 500;
  }

  .hero-cta-row {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero-pill {
    height: 44px;
    min-height: 44px;
    padding: 0 18px;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
    border-radius: 999px;
    border-width: 1px;
    border-style: solid;
  }

  .hero-pill::after {
    content: "▾";
    margin-left: 8px;
    font-size: 10px;
  }

  .hero-pill.btn-secondary {
    color: var(--color-teal);
    border-color: rgba(13, 27, 62, 0.55);
    background: rgba(255, 255, 255, 0.94);
  }

  .hero-pill.btn-secondary:hover,
  .hero-pill.btn-secondary:focus-visible {
    background: rgba(255, 255, 255, 0.94);
    color: var(--color-teal);
    border-color: rgba(13, 27, 62, 0.55);
  }

  .hero-pill.btn-primary {
    color: #273146;
    background: var(--color-golden-yellow);
    border-color: #e6cb1f;
  }

  .hero-pill.btn-primary:hover,
  .hero-pill.btn-primary:focus-visible {
    background: #f1d106;
    color: #273146;
    border-color: #e6cb1f;
  }

  .hero-pill.btn-ghost {
    color: #f3f7ff;
    border-color: rgba(255, 255, 255, 0.4);
    background: var(--color-steel-blue-1);
  }

  .hero-pill.btn-ghost:hover,
  .hero-pill.btn-ghost:focus-visible {
    background: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  @media (max-width: 700px) {
    .hero-section {
      min-height: 460px;
    }

    .hero-content {
      padding: 44px 0;
      text-align: left;
    }

    .hero-content h1,
    .hero-content p {
      margin-left: 0;
      margin-right: 0;
    }

    .hero-cta-row {
      justify-content: flex-start;
    }

    .hero-pill {
      width: 100%;
    }
  }
</style>

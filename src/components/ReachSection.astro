---
interface Props {
  backgroundImage: string;
}

const {
  backgroundImage = "/images/reach-section-bg.png"
} = Astro.props as Props;
---

<section class="reach-section" style={`background-image: url('${backgroundImage}')`}>
  <div class="overlay"></div>
</section>

<style>
  .reach-section {
    position: relative;
    min-height: 400px;
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(18, 31, 47, 0.22);
  }

  @media (max-width: 980px) {
    .reach-section {
      min-height: 280px;
    }
  }

  @media (max-width: 640px) {
    .reach-section {
      min-height: 220px;
    }
  }
</style>

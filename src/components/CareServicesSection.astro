---
interface Card {
  tag: string;
  title: string;
  description: string;
  image: string;
  imagePosition: string;
  href: string;
}

interface Props {
  title: string;
  intro: string;
  cards: Card[];
}

const defaultCards: Card[] = [
  {
    tag: "Tue-Thu | 10am-3pm",
    title: "Hospice Services",
    description: "Free day hospice on Tue–Thu, 10am–3pm, plus nursing, therapies, and support tailored to you.",
    image: "/images/hero-supporting-journey.png",
    imagePosition: "center 42%",
    href: "/hospice-services/"
  },
  {
    tag: "Mondays | 10am-1pm",
    title: "Carer & Patient Wellbeing",
    description:
      "Relaxed Monday mornings for patients and carers together — activities, nursing advice, and lunch.",
    image: "/images/hero-family-alt.png",
    imagePosition: "center 48%",
    href: "/what-we-offer/carer-patient-wellbeing/"
  },
  {
    tag: "Dementia Support",
    title: "Dementia Home-Sitting",
    description: "Friendly home visits from trained volunteers so unpaid carers can take a proper break.",
    image: "/images/hero-family-alt.png",
    imagePosition: "center 48%",
    href: "/what-we-offer/dementia-home-sitting/"
  },
  {
    tag: "Counselling & Support",
    title: "Counselling & Support",
    description: "Confidential listening and counselling for patients, families, and carers at every stage.",
    image: "/images/care-counselling.png",
    imagePosition: "center 40%",
    href: "/hospice-services/counselling-support/"
  }
];

const {
  title = "Care and Comfort Where You Need It Most",
  intro = "From specialist nursing to emotional support, we provide free, compassionate care for individuals and families within our local community.",
  cards = defaultCards
} = Astro.props as Props;
---

<section class="care-services">
  <div class="container care-wrap">
    <h2>{title}</h2>
    <p class="intro">{intro}</p>

    <div class="cards-grid">
      {
        cards.map((card) => (
          <article class="service-card">
            <div class="card-image" style={`background-image:url('${card.image}');background-position:${card.imagePosition};`}>
            </div>
            <span class="tag">{card.tag}</span>
            <div class="card-content">
              <h3>{card.title}</h3>
              <p>{card.description}</p>
              <a href={card.href} class="card-link">
                <span class="card-link-text">Find Out More</span>
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .care-services {
    background: var(--color-lavender);
    padding: 58px 0 70px;
  }

  .care-wrap h2 {
    margin: 0;
    text-align: center;
    color: var(--color-steel-blue);
    font-size: var(--type-section-title);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .intro {
    margin: 16px auto 30px;
    max-width: 760px;
    text-align: center;
    color: #2f4260;
    font-size: var(--type-body-large);
    line-height: 1.65;
    font-weight: 400;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .service-card {
    background: var(--color-white);
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    border: 1px solid #dce5f2;
    box-shadow: 0 6px 16px rgba(19, 47, 82, 0.08);
    min-height: 100%;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .service-card:hover,
  .service-card:focus-within {
    transform: translateY(-4px);
    border-color: #bfd0e7;
    box-shadow: 0 14px 26px rgba(18, 44, 83, 0.14);
  }

  .card-image {
    height: 138px;
    position: relative;
    overflow: hidden;
    border-radius: 16px 16px 0 0;
    background-size: cover;
    background-repeat: no-repeat;
    transition: transform 0.35s ease;
  }

  .service-card:hover .card-image,
  .service-card:focus-within .card-image {
    transform: scale(1.05);
  }

  .tag {
    position: relative;
    z-index: 3;
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    justify-content: center;
    margin: -12px 0 0 12px;
    min-height: 26px;
    border-radius: 999px;
    padding: 5px 14px;
    font-size: var(--type-micro);
    line-height: 1;
    font-weight: 700;
    color: var(--color-white);
    background: var(--color-steel-blue-1, #1d508d);
  }

  .card-content {
    padding: 8px 16px 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-content h3 {
    margin: 6px 0 10px;
    font-size: clamp(1.1rem, 1.4vw, 1.4rem);
    line-height: 1.28;
    letter-spacing: -0.01em;
    color: #152a47;
    font-weight: 700;
  }

  .card-content p {
    margin: 0;
    min-height: 3.25rem;
    color: #495d78;
    font-size: var(--type-body);
    line-height: 1.6;
    flex: 1;
  }

  .card-link {
    margin-top: auto;
    padding-top: 16px;
    color: var(--color-steel-blue);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    font-size: var(--type-button);
    font-weight: 700;
  }

  .card-link:hover,
  .card-link:focus-visible {
    color: #153f73;
  }

  .card-link-text {
    position: relative;
  }

  .card-link-text::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 3px;
    background: var(--color-golden-yellow);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s ease;
  }

  .card-link:hover .card-link-text::after,
  .card-link:focus-visible .card-link-text::after {
    transform: scaleX(1);
  }

  @media (max-width: 980px) {
    .cards-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .care-services {
      padding: 44px 0 54px;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .card-content p {
      min-height: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card {
      transition: none;
    }

    .service-card:hover,
    .service-card:focus-within {
      transform: none;
    }

    .service-card:hover .card-image,
    .service-card:focus-within .card-image {
      transform: none;
    }
  }
</style>

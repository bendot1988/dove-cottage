---
const links = [
  { label: "Donate", href: "/donate/" },
  { label: "Shop overview", href: "/shops/" },
  { label: "Contact", href: "/contact/" }
];
---

<div class="quick-fab" data-quick-fab>
  <button
    class="quick-fab__toggle"
    type="button"
    aria-expanded="false"
    aria-controls="quick-fab-menu"
    aria-label="Open quick links"
    data-quick-fab-toggle
  >
    <span aria-hidden="true" class="quick-fab__heart">♥</span>
  </button>

  <nav id="quick-fab-menu" class="quick-fab__menu" aria-label="Quick links" data-quick-fab-menu>
    <ul>
      {
        links.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-quick-fab]");
    if (!root) return;

    const button = root.querySelector("[data-quick-fab-toggle]");
    const menu = root.querySelector("[data-quick-fab-menu]");
    if (!(button instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

    const setOpen = (isOpen) => {
      root.classList.toggle("is-open", isOpen);
      button.setAttribute("aria-expanded", String(isOpen));
      button.setAttribute("aria-label", isOpen ? "Close quick links" : "Open quick links");
    };

    button.addEventListener("click", () => {
      setOpen(!root.classList.contains("is-open"));
    });

    document.addEventListener("click", (event) => {
      if (!root.classList.contains("is-open")) return;
      const target = event.target;
      if (target instanceof Node && !root.contains(target)) {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });
  })();
</script>

<style>
  .quick-fab {
    position: fixed;
    right: clamp(0.9rem, 2.4vw, 1.5rem);
    bottom: clamp(0.9rem, 2.8vw, 1.5rem);
    z-index: 90;
  }

  .quick-fab__toggle {
    width: 52px;
    height: 52px;
    border: 1px solid rgba(16, 35, 60, 0.25);
    border-radius: 999px;
    background: var(--color-golden-yellow);
    color: #10233c;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(16, 35, 60, 0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.24s var(--motion-ease-out),
      box-shadow 0.24s var(--motion-ease-out),
      background 0.24s var(--motion-ease-out),
      border-color 0.24s var(--motion-ease-out);
  }

  .quick-fab__toggle:hover,
  .quick-fab__toggle:focus-visible {
    transform: translateY(-4px) scale(1.04);
    box-shadow: 0 16px 28px rgba(16, 35, 60, 0.28);
    background: #ffd400;
    border-color: rgba(16, 35, 60, 0.35);
  }

  .quick-fab__toggle:active {
    transform: translateY(-2px) scale(1.01);
    box-shadow: 0 10px 20px rgba(16, 35, 60, 0.24);
  }

  .quick-fab__toggle:focus-visible {
    outline: 2px solid #10233c;
    outline-offset: 2px;
  }

  .quick-fab__heart {
    font-size: 1.3rem;
    line-height: 1;
    transform: translateY(-1px);
    transition: transform 0.22s var(--motion-ease-out);
  }

  .quick-fab__toggle:hover .quick-fab__heart,
  .quick-fab__toggle:focus-visible .quick-fab__heart {
    transform: translateY(-1px) scale(1.14);
    color: #0b2443;
  }

  .quick-fab__toggle:hover .quick-fab__heart {
    animation: quick-fab-heart-pulse 0.55s var(--motion-ease-out) both;
  }

  .quick-fab__menu {
    position: absolute;
    right: 0;
    bottom: calc(100% + 10px);
    pointer-events: none;
  }

  .quick-fab__menu ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 8px;
  }

  .quick-fab__menu li {
    opacity: 0;
    transform: translateY(10px) scale(0.98);
    transition:
      opacity 0.22s var(--motion-ease-out),
      transform 0.22s var(--motion-ease-out);
  }

  .quick-fab__menu a {
    display: inline-block;
    min-width: 148px;
    text-align: center;
    padding: 10px 14px;
    border-radius: 999px;
    text-decoration: none;
    font-size: var(--type-body-small);
    font-weight: 700;
    color: #153a66;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid #d9e4f4;
    box-shadow: 0 8px 20px rgba(16, 35, 60, 0.16);
    transition:
      transform 0.2s var(--motion-ease-out),
      box-shadow 0.2s var(--motion-ease-out),
      background 0.2s var(--motion-ease-out),
      color 0.2s var(--motion-ease-out),
      border-color 0.2s var(--motion-ease-out);
  }

  .quick-fab__menu a:hover,
  .quick-fab__menu a:focus-visible {
    background: #fff9cc;
    color: #0f2e54;
    border-color: #e0c84c;
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 14px 26px rgba(16, 35, 60, 0.23);
  }

  .quick-fab__menu a:active {
    transform: translateY(-1px) scale(1.01);
  }

  .quick-fab__menu a:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
  }

  .quick-fab.is-open .quick-fab__menu {
    pointer-events: auto;
  }

  .quick-fab.is-open .quick-fab__menu li {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .quick-fab.is-open .quick-fab__menu li:nth-child(1) {
    transition-delay: 0.03s;
  }

  .quick-fab.is-open .quick-fab__menu li:nth-child(2) {
    transition-delay: 0.07s;
  }

  .quick-fab.is-open .quick-fab__menu li:nth-child(3) {
    transition-delay: 0.11s;
  }

  @media (prefers-reduced-motion: reduce) {
    .quick-fab__toggle,
    .quick-fab__menu li,
    .quick-fab__heart,
    .quick-fab__menu a {
      transition: none;
    }
  }

  @keyframes quick-fab-heart-pulse {
    0% {
      transform: translateY(-1px) scale(1);
    }
    55% {
      transform: translateY(-1px) scale(1.2);
    }
    100% {
      transform: translateY(-1px) scale(1.14);
    }
  }
  @media (max-width: 640px) {
    .quick-fab__toggle {
      width: 48px;
      height: 48px;
    }

    .quick-fab__menu a {
      min-width: 136px;
    }
  }
</style>

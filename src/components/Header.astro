---
import contact from "../data/contact.json";
import archive from "../data/site-archive.json";
import { toTitleCase } from "../lib/titleCase";

const path = Astro.url.pathname;
const isHome = path === "/" || path === "";
const isDonatePage = path === "/donate" || path.startsWith("/donate/");
const isNewsEventsSection =
  path === "/news" ||
  path.startsWith("/news/") ||
  path.startsWith("/events/") ||
  path === "/newsletter" ||
  path.startsWith("/newsletter/");
const utilTelHref = `tel:${contact.trustPhone}`;
const donateLabel = toTitleCase(contact.trustDonateLabel);

const filterLabelById = new Map(archive.filters.map((f) => [f.id, f.label]));
const parseFilterKeys = (raw: string) =>
  raw
    .split(/[,]+/)
    .map((key) => key.trim())
    .filter(Boolean);

const baseSearchEntries = [
  { title: "Home", href: "/", section: "Main" },
  { title: "Explore Our Work", href: "/explore/", section: "Main" },
  { title: "Hospice Services overview", href: "/hospice-services/", section: "Hospice Services" },
  { title: "Counselling & Support overview", href: "/hospice-services/counselling-support/", section: "Counselling & Support" },
  { title: "Donate", href: "/donate/", section: "Support Us" },
  { title: "Contact Us", href: "/contact/", section: "Main" },
  { title: "News & Events", href: "/news/", section: "News" },
  { title: "Newsletter archive", href: "/newsletter/", section: "News" },
  { title: "Our Shops", href: "/shops/", section: "Support Us" }
];

const archiveSearchEntries = archive.items
  .filter((item) => item.href && item.href !== "#" && item.href.trim().length)
  .map((item) => {
    const firstKey = parseFilterKeys(item.filterKeys)[0];
    const section = firstKey ? filterLabelById.get(firstKey) ?? "Services" : "Services";
    return {
      title: item.title,
      href: item.href,
      section,
      excerpt: item.excerpt
    };
  });

const searchIndex = [...baseSearchEntries, ...archiveSearchEntries].filter(
  (entry, idx, all) => all.findIndex((x) => x.href === entry.href) === idx
);

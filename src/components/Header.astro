---
import contact from "../data/contact.json";
import { toTitleCase } from "../lib/titleCase";

const path = Astro.url.pathname;
const isHome = path === "/" || path === "";
const utilTelHref = `tel:${contact.trustPhone}`;
const donateLabel = toTitleCase(contact.trustDonateLabel);
const utilCharity = toTitleCase(contact.trustCharityLine);
---

<div class="header-wrap">
  <div class="header-top-stack">
    <div class="header-util" role="region" aria-label="Charity and phone">
      <div class="container header-util-inner">
        <span class="header-util-charity">{utilCharity}</span>
        <a href={utilTelHref} class="header-util-phone" aria-label="Call Dove Cottage">
          <span class="header-util-phone-icon" aria-hidden="true">☎</span>
          {contact.trustPhoneDisplay}
        </a>
      </div>
    </div>
    <header class="site-header">
    <div class="top-row">
    <div class="container top-content">
      <a href="/" class="brand" aria-label="Dove Cottage website home">
        <img src="/images/dove-logo-white.svg" alt="Dove Cottage Day Hospice" class="brand-logo" />
      </a>

      <div class="actions">
        <a href={contact.trustDonateUrl} class="btn btn-primary btn-shine donate-btn">{donateLabel}</a>
      </div>

      <button
        class="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open mobile menu"
      >
        <span class="menu-toggle-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span>Menu</span>
      </button>
    </div>
  </div>
  </header>
  </div>

  <nav class="nav-row" aria-label="Main navigation">
    <div class="container">
      <ul class="nav-content">
        <li class="nav-item">
          <a
            class:list={["nav-link", { active: isHome }]}
            href="/"
            aria-current={isHome ? "page" : undefined}
          >
            Home
          </a>
        </li>

        <li class="nav-item has-dropdown">
          <a class="nav-link with-arrow" href="#">
            <span>About Us</span>
            <span class="dropdown-icon" aria-hidden="true">
              <svg viewBox="0 0 12 12" focusable="false">
                <path d="M2.1 4.35L6 8.1l3.9-3.75" />
              </svg>
            </span>
          </a>
          <div class="dropdown-panel mega-menu about-mega">
            <div class="mega-grid">
              <section class="mega-column">
                <h3 class="mega-title">What We Offer</h3>
                <a href="#" class="mega-link">Carer &amp; patient wellbeing sessions</a>
                <a href="#" class="mega-link">Dementia home-sitting</a>
              </section>

              <section class="mega-column">
                <h3 class="mega-title">Hospice Services</h3>
                <a href="#" class="mega-link">Counselling</a>
                <a href="#" class="mega-link">Nursing care &amp; medical advice</a>
                <a href="#" class="mega-link">Wellbeing activities</a>
                <a href="#" class="mega-link">Complementary therapies</a>
                <a href="#" class="mega-link">Therapy Bathing</a>
                <a href="#" class="mega-link">Spiritual &amp; Chaplaincy support</a>
                <a href="#" class="mega-link">Transport</a>
              </section>

              <section class="mega-column">
                <h3 class="mega-title">Counselling &amp; Support</h3>
                <a href="#" class="mega-link">Counselling</a>
                <a href="#" class="mega-link">Support groups</a>
                <h3 class="mega-title secondary-title">About Dove Cottage</h3>
                <a href="#" class="mega-link">Our Team</a>
                <a href="#" class="mega-link">Our Facilities</a>
              </section>
            </div>
          </div>
        </li>

        <li class="nav-item has-dropdown">
          <a class="nav-link with-arrow" href="#">
            <span>Support Us</span>
            <span class="dropdown-icon" aria-hidden="true">
              <svg viewBox="0 0 12 12" focusable="false">
                <path d="M2.1 4.35L6 8.1l3.9-3.75" />
              </svg>
            </span>
          </a>
          <div class="dropdown-panel mega-menu support-mega">
            <div class="mega-grid support-grid">
              <section class="mega-column">
                <h3 class="mega-title">Support Us</h3>
                <a href="#" class="mega-link">Make a donation</a>
                <a href="#" class="mega-link">Volunteer your time</a>
                <a href="#" class="mega-link">Leave a gift in your will</a>
                <a href="#" class="mega-link">Fundraise for us</a>
                <a href="/shops/" class="mega-link">Visit our shops</a>
                <a href="#" class="mega-link">Corporate partnerships</a>
              </section>
            </div>
          </div>
        </li>

        <li class="nav-item">
          <a
            class:list={["nav-link", { active: path.startsWith("/news") }]}
            href="/news/"
            aria-current={path.startsWith("/news") ? "page" : undefined}
          >
            News &amp; Events
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#">Hire our facilities</a>
        </li>
        <li class="nav-item">
          <a
            class:list={["nav-link", { active: path === "/contact" || path.startsWith("/contact/") }]}
            href="/contact/"
            aria-current={path === "/contact" || path.startsWith("/contact/") ? "page" : undefined}
          >
            Contact Us
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <div class="mobile-nav" id="mobile-menu" aria-hidden="true">
    <button class="mobile-nav-backdrop" type="button" data-close-mobile-menu aria-label="Close menu"></button>
    <aside class="mobile-nav-panel" role="dialog" aria-modal="true" aria-label="Mobile menu">
      <div class="mobile-nav-head">
        <strong>Menu</strong>
        <button type="button" class="mobile-close" data-close-mobile-menu aria-label="Close mobile menu">✕</button>
      </div>

      <nav class="mobile-links" aria-label="Mobile navigation">
        <a
          href="/"
          class:list={["mobile-link", { active: isHome }]}
          aria-current={isHome ? "page" : undefined}
        >
          Home
        </a>

        <details class="mobile-group">
          <summary>About Us</summary>
          <div class="mobile-group-content">
            <a href="#" class="mobile-link">What We Offer</a>
            <a href="#" class="mobile-link">Carer &amp; patient wellbeing sessions</a>
            <a href="#" class="mobile-link">Dementia home-sitting</a>
            <a href="#" class="mobile-link">Counselling</a>
            <a href="#" class="mobile-link">Support groups</a>
            <a href="#" class="mobile-link">Our Team</a>
            <a href="#" class="mobile-link">Our Facilities</a>
          </div>
        </details>

        <details class="mobile-group">
          <summary>Support Us</summary>
          <div class="mobile-group-content">
            <a href="#" class="mobile-link">Make a donation</a>
            <a href="#" class="mobile-link">Volunteer your time</a>
            <a href="#" class="mobile-link">Leave a gift in your will</a>
            <a href="#" class="mobile-link">Fundraise for us</a>
            <a href="/shops/" class="mobile-link">Visit our shops</a>
            <a href="#" class="mobile-link">Corporate partnerships</a>
          </div>
        </details>

        <a
          href="/news/"
          class:list={["mobile-link", { active: path.startsWith("/news") }]}
          aria-current={path.startsWith("/news") ? "page" : undefined}
        >
          News &amp; Events
        </a>
        <a href="#" class="mobile-link">Hire our facilities</a>
        <a
          href="/contact/"
          class:list={["mobile-link", { active: path === "/contact" || path.startsWith("/contact/") }]}
          aria-current={path === "/contact" || path.startsWith("/contact/") ? "page" : undefined}
        >
          Contact Us
        </a>
      </nav>

      <div class="mobile-cta">
        <a href="tel:01949860303" class="mobile-phone">☎ 01949 860303</a>
        <a href={contact.trustDonateUrl} class="btn btn-primary btn-shine mobile-donate">{donateLabel}</a>
        <a href="#" class="btn btn-secondary mobile-secondary-cta">Volunteer</a>
      </div>
    </aside>
  </div>
</div>

<script is:inline>
  (() => {
    const headerWrap = document.querySelector(".header-wrap");
    const header = document.querySelector(".site-header");
    const headerTopStack = document.querySelector(".header-top-stack");
    if (!headerWrap || !header) return;

    const toggle = header.querySelector(".menu-toggle");
    const menu = headerWrap.querySelector(".mobile-nav");
    const closeButtons = headerWrap.querySelectorAll("[data-close-mobile-menu]");

    if (!toggle || !menu) return;

    const setMenuOpen = (open) => {
      headerWrap.classList.toggle("mobile-menu-open", open);
      menu.setAttribute("aria-hidden", open ? "false" : "true");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      document.body.classList.toggle("mobile-menu-open", open);
    };

    toggle.addEventListener("click", () => {
      const isOpen = headerWrap.classList.contains("mobile-menu-open");
      setMenuOpen(!isOpen);
    });

    closeButtons.forEach((btn) => btn.addEventListener("click", () => setMenuOpen(false)));

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setMenuOpen(false);
      }
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 1100) {
        setMenuOpen(false);
      }
    });

    const navRow = headerWrap.querySelector(".nav-row");
    if (navRow) {
      const isDesktop = () => window.innerWidth > 1100;

      const syncStuck = () => {
        if (!isDesktop() || !headerTopStack) {
          navRow.classList.remove("is-stuck");
          return;
        }
        const bottom = headerTopStack.getBoundingClientRect().bottom;
        navRow.classList.toggle("is-stuck", bottom < 0.5);
      };

      const onScrollOrResize = () => {
        requestAnimationFrame(syncStuck);
      };

      window.addEventListener("scroll", onScrollOrResize, { passive: true });
      window.addEventListener("resize", onScrollOrResize, { passive: true });
      window.addEventListener(
        "pageshow",
        (e) => {
          if (e.persisted) {
            onScrollOrResize();
          }
        }
      );
      if (document.fonts?.ready) {
        void document.fonts.ready.then(() => onScrollOrResize());
      } else {
        onScrollOrResize();
      }
    }
  })();
</script>

<style>
  :global(body.mobile-menu-open) {
    overflow: hidden;
  }

  .site-header {
    font-family: "Montserrat", "Segoe UI", Arial, sans-serif;
  }

  .header-top-stack {
    position: relative;
    z-index: 2;
  }

  .header-util {
    background: #f7f9fd;
    border-bottom: 1px solid #dde6f2;
  }

  .header-util-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px 20px;
    min-height: 40px;
    font-size: var(--type-micro, 0.8rem);
    font-weight: 600;
    color: #1e3a5f;
  }

  .header-util-charity {
    letter-spacing: 0.02em;
  }

  .header-util-phone {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
  }

  .header-util-phone:hover,
  .header-util-phone:focus-visible {
    color: #0b2448;
    text-decoration: underline;
  }

  .header-util-phone-icon {
    opacity: 0.9;
  }

  .container {
    width: min(1200px, 95%);
    margin: 0 auto;
  }

  .top-row {
    background: var(--color-teal);
    padding: 9px 0;
    position: relative;
    z-index: 1;
    box-shadow: 0 2px 10px rgba(10, 35, 74, 0.12);
  }

  .top-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand {
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    min-width: 120px;
  }

  .brand-logo {
    width: clamp(72px, 9vw, 108px);
    height: auto;
    display: block;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #fff;
    font-weight: 700;
  }

  .phone-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
  }

  .phone-label {
    font-size: var(--type-micro);
    line-height: 1;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: none;
    opacity: 0.95;
  }

  .phone-link {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--type-card-title);
    line-height: 1;
    letter-spacing: -0.01em;
    font-weight: 700;
    text-shadow: 0 1px 2px rgba(8, 26, 48, 0.35);
  }

  .phone-link:hover,
  .phone-link:focus-visible {
    opacity: 0.9;
  }

  .phone-icon {
    font-size: var(--type-subtitle);
    line-height: 1;
    opacity: 0.95;
  }

  .donate-btn {
    border-radius: 999px;
    height: 42px;
    padding: 0 20px;
  }

  .menu-toggle {
    display: none;
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(22, 69, 122, 0.5);
    color: #fff;
    border-radius: 10px;
    min-height: 40px;
    padding: 8px 12px;
    font: inherit;
    font-size: var(--type-body-small);
    font-weight: 700;
    gap: 10px;
    align-items: center;
  }

  .menu-toggle-icon {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
  }

  .menu-toggle-icon span {
    width: 16px;
    height: 2px;
    border-radius: 999px;
    background: #fff;
  }

  .nav-row {
    background: var(--color-steel-blue-1);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    position: relative;
  }

  @media (min-width: 1101px) {
    /* In-flow + sticky: avoids JS "top" sync which could read 0px before layout and cover the header. */
    .nav-row {
      position: -webkit-sticky;
      position: sticky;
      top: 0;
      z-index: 200;
      box-shadow: 0 2px 10px rgba(10, 35, 74, 0.1);
    }

    .nav-row::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
      height: 2px;
      background: var(--color-golden-yellow);
      box-shadow: 0 1px 2px rgba(10, 35, 74, 0.18);
      opacity: 0;
      transition: opacity 0.22s ease;
      pointer-events: none;
      z-index: 5;
    }

    .nav-row.is-stuck::before {
      opacity: 1;
    }

    .nav-row.is-stuck {
      box-shadow: 0 4px 16px rgba(10, 35, 74, 0.14);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    @media (min-width: 1101px) {
      .nav-row::before {
        transition: none;
      }
    }
  }

  .nav-content {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
    min-height: 52px;
    gap: 8px 22px;
  }

  .nav-item {
    position: relative;
    list-style: none;
    /* Extends hover area so cursor can move into dropdown without closing. */
    padding-bottom: 6px;
    margin-bottom: -6px;
  }

  .site-header ul,
  .site-header li {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    color: #fff;
    text-decoration: none;
    font-size: var(--type-nav);
    font-weight: 600;
    display: inline-block;
    padding: 14px 0 12px;
    white-space: nowrap;
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 3px;
    background: var(--color-golden-yellow);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    opacity: 0.92;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .with-arrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  @media (min-width: 1101px) {
    .nav-content {
      justify-content: stretch;
      flex-wrap: nowrap;
      gap: 0;
      width: 100%;
    }

    .nav-item {
      flex: 1 1 0;
      min-width: 0;
      display: flex;
      justify-content: center;
    }

    .nav-item .nav-link {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      min-width: 0;
      box-sizing: border-box;
    }
  }

  .dropdown-icon {
    width: 10px;
    height: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transform: translateY(0);
    transition: transform 0.2s ease;
    color: #fff;
    opacity: 0.9;
  }

  .dropdown-icon svg {
    width: 100%;
    height: 100%;
  }

  .dropdown-icon path {
    fill: none;
    stroke: #fff;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .has-dropdown:hover .dropdown-icon,
  .has-dropdown:focus-within .dropdown-icon {
    transform: rotate(180deg);
  }

  .dropdown-panel {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    transform: none;
    margin-top: 0;
    background: #ffffff;
    color: #12243f;
    border: 1px solid #d9e4f2;
    border-radius: 12px;
    box-shadow: 0 18px 38px rgba(7, 29, 64, 0.16);
    z-index: 20;
    padding: 10px;
  }

  .has-dropdown:hover .dropdown-panel,
  .has-dropdown:focus-within .dropdown-panel {
    display: block;
  }

  .mega-menu {
    width: min(940px, calc(100vw - 24px));
    padding: 22px;
  }

  .mega-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .support-grid {
    grid-template-columns: minmax(260px, 1fr);
  }

  .mega-column {
    padding: 4px;
  }

  .mega-title {
    margin: 0 0 8px;
    font-size: var(--type-body-small);
    font-weight: 700;
    color: #163766;
    letter-spacing: -0.01em;
  }

  .secondary-title {
    margin-top: 14px;
  }

  .mega-link {
    display: block;
    font-size: var(--type-body-small);
    font-weight: 500;
    line-height: 1.5;
    color: #12243f;
    text-decoration: none;
    padding: 9px 10px;
    margin-bottom: 2px;
    border-radius: 8px;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .mega-link:hover,
  .mega-link:focus-visible {
    background: var(--color-alice-blue);
    color: #0f2f61;
    outline: none;
  }

  .about-mega {
    min-width: 760px;
    max-width: calc(100vw - 24px);
  }

  .support-mega {
    min-width: 340px;
    width: min(420px, 90vw);
  }

  .mobile-nav {
    display: none;
  }

  @media (max-width: 1100px) {
    .actions {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
    }

    .nav-content {
      display: none;
    }

    .mobile-nav {
      position: fixed;
      inset: 0;
      z-index: 90;
      pointer-events: none;
    }

    .mobile-nav-backdrop {
      position: absolute;
      inset: 0;
      border: 0;
      background: rgba(8, 22, 40, 0.55);
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    .mobile-nav-panel {
      position: absolute;
      top: 0;
      right: 0;
      width: min(420px, 88vw);
      height: 100%;
      background: #fff;
      box-shadow: -10px 0 28px rgba(6, 23, 43, 0.28);
      transform: translateX(100%);
      transition: transform 0.24s ease;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    .header-wrap.mobile-menu-open .mobile-nav {
      display: block;
      pointer-events: auto;
    }

    .header-wrap.mobile-menu-open .mobile-nav-backdrop {
      opacity: 1;
    }

    .header-wrap.mobile-menu-open .mobile-nav-panel {
      transform: translateX(0);
    }

    .mobile-nav-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--color-steel-blue-1);
      color: #fff;
      padding: 14px 16px;
      font-size: var(--type-body);
    }

    .mobile-close {
      border: 0;
      background: transparent;
      color: #fff;
      font-size: 1.3rem;
      line-height: 1;
      cursor: pointer;
    }

    .mobile-links {
      padding: 10px 0;
      border-bottom: 1px solid #e2eaf5;
    }

    .mobile-link,
    .mobile-group > summary {
      display: block;
      padding: 12px 16px;
      text-decoration: none;
      color: #12335f;
      font-size: var(--type-body);
      font-weight: 600;
      border-bottom: 1px solid #edf2f9;
    }

    .mobile-link.active {
      color: var(--color-steel-blue);
      border-left: 3px solid var(--color-golden-yellow);
      padding-left: 13px;
    }

    .mobile-group > summary {
      cursor: pointer;
      list-style: none;
      position: relative;
      padding-right: 36px;
    }

    .mobile-group > summary::-webkit-details-marker {
      display: none;
    }

    .mobile-group > summary::after {
      content: "▾";
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: #325b91;
      font-size: 0.8rem;
      transition: transform 0.2s ease;
    }

    .mobile-group[open] > summary::after {
      transform: translateY(-50%) rotate(180deg);
    }

    .mobile-group-content .mobile-link {
      padding-left: 28px;
      font-weight: 500;
      font-size: var(--type-body-small);
      color: #2e4c72;
    }

    .mobile-cta {
      padding: 14px 16px 20px;
      display: grid;
      gap: 10px;
    }

    .mobile-phone {
      text-decoration: none;
      color: var(--color-steel-blue);
      font-size: var(--type-subtitle);
      font-weight: 700;
      padding: 6px 0 2px;
    }

    .mobile-donate,
    .mobile-secondary-cta {
      border-radius: 999px;
      width: 100%;
    }

    .mobile-donate {
      color: #233a5a;
    }

    .mobile-secondary-cta {
      color: #204a81;
      border-color: #204a81;
    }
  }

  @media (max-width: 700px) {
    .mobile-nav-panel {
      width: 100%;
      max-width: 100%;
    }

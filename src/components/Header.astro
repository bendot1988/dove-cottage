<script is:inline>
  (() => {
    const headerWrap = document.querySelector(".header-wrap");
    const header = document.querySelector(".site-header");
    const headerTopStack = document.querySelector(".header-top-stack");
    if (!headerWrap || !header) return;

    const toggle = header.querySelector(".menu-toggle");
    const menu = headerWrap.querySelector(".mobile-nav");
    const closeButtons = headerWrap.querySelectorAll("[data-close-mobile-menu]");
    const searchButton = headerWrap.querySelector("[data-open-search]");
    const searchLayer = headerWrap.querySelector("[data-site-search]");
    const searchInput = headerWrap.querySelector("[data-search-input]");
    const searchHint = headerWrap.querySelector("[data-search-hint]");
    const searchResults = headerWrap.querySelector("[data-search-results]");
    const searchCloseButtons = headerWrap.querySelectorAll("[data-close-search]");
    const rawSearchData = searchLayer?.getAttribute("data-search-index") || "[]";
    let searchIndex = [];

    try {
      searchIndex = JSON.parse(rawSearchData);
    } catch {
      try {
        const decoder = document.createElement("textarea");
        decoder.innerHTML = rawSearchData;
        searchIndex = JSON.parse(decoder.value);
      } catch {
        searchIndex = [];
      }
    }

    const setMenuOpen = (open) => {
      if (!toggle || !menu) return;
      headerWrap.classList.toggle("mobile-menu-open", open);
      menu.setAttribute("aria-hidden", open ? "false" : "true");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      document.body.classList.toggle("mobile-menu-open", open);
    };

    const renderSearchResults = (items) => {
      if (!searchResults) return;
      const esc = (value) =>
        String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      if (!items.length) {
        searchResults.innerHTML = "";
        return;
      }
      searchResults.innerHTML = items
        .slice(0, 8)
        .map(
          (item) => `
            <li>
              <a class="site-search-result" href="${esc(item.href)}">
                <span class="site-search-result__main">
                  <span class="site-search-result__title">${esc(item.title)}</span>
                  ${item.excerpt ? `<span class="site-search-result__excerpt">${esc(item.excerpt)}</span>` : ""}
                </span>
                <span class="site-search-result__trail">
                  <span class="site-search-result__meta">${esc(item.section)}</span>
                  <span class="site-search-result__arrow" aria-hidden="true">→</span>
                </span>
              </a>
            </li>
          `
        )
        .join("");
    };

    const runSearch = (query) => {
      const term = query.trim().toLowerCase();
      if (!searchHint) return;
      if (term.length < 2) {
        searchHint.textContent = "Type at least 2 letters to search.";
        renderSearchResults([]);
        return;
      }

      const results = searchIndex
        .map((entry) => {
          const title = String(entry.title || "").toLowerCase();
          const section = String(entry.section || "").toLowerCase();
          const excerpt = String(entry.excerpt || "").toLowerCase();
          const starts = title.startsWith(term) ? 2 : 0;
          const inTitle = title.includes(term) ? 1 : 0;
          const inOther = section.includes(term) || excerpt.includes(term) ? 0.5 : 0;
          return { ...entry, score: starts + inTitle + inOther };
        })
        .filter((entry) => entry.score > 0)
        .sort((a, b) => b.score - a.score || a.title.localeCompare(b.title));

      searchHint.textContent = results.length
        ? `${results.length} result${results.length === 1 ? "" : "s"}`
        : "Type at least 2 letters to search.";
      renderSearchResults(results);
    };

    const setSearchOpen = (open) => {
      if (!searchLayer || !searchButton) return;
      searchLayer.setAttribute("aria-hidden", open ? "false" : "true");
      searchButton.setAttribute("aria-expanded", open ? "true" : "false");
      headerWrap.classList.toggle("site-search-open", open);
      document.body.classList.toggle("site-search-open", open);

      if (open) {
        if (searchInput) {
          searchInput.value = "";
          window.requestAnimationFrame(() => searchInput.focus());
        }
        if (searchHint) searchHint.textContent = "Type at least 2 letters to search.";
        renderSearchResults([]);
      }
    };

    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        const isOpen = headerWrap.classList.contains("mobile-menu-open");
        setMenuOpen(!isOpen);
      });

      closeButtons.forEach((btn) => btn.addEventListener("click", () => setMenuOpen(false)));
    }

    if (searchButton && searchLayer) {
      searchButton.addEventListener("click", () => {
        setMenuOpen(false);
        setSearchOpen(true);
      });
      searchCloseButtons.forEach((btn) => btn.addEventListener("click", () => setSearchOpen(false)));

      searchLayer.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest(".site-search-result")) {
          setSearchOpen(false);
        }
      });
    }

    if (searchInput) {
      searchInput.addEventListener("input", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        runSearch(target.value);
      });
    }

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setMenuOpen(false);
        setSearchOpen(false);
      }

      if (event.key !== "/") return;
      const target = event.target;
      if (
        target instanceof HTMLInputElement ||
        target instanceof HTMLTextAreaElement ||
        (target instanceof HTMLElement && target.isContentEditable)
      ) {
        return;
      }
      event.preventDefault();
      setMenuOpen(false);
      setSearchOpen(true);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 980) {
        setMenuOpen(false);
      }
    });

    const navRow = headerWrap.querySelector(".nav-row");
    if (navRow) {
      const syncStuck = () => {
        if (!headerTopStack) {
          navRow.classList.remove("is-stuck");
          return;
        }
        const bottom = headerTopStack.getBoundingClientRect().bottom;
        navRow.classList.toggle("is-stuck", bottom < 0.5);
      };

      const onScrollOrResize = () => {
        requestAnimationFrame(syncStuck);
      };

      window.addEventListener("scroll", onScrollOrResize, { passive: true });
      window.addEventListener("resize", onScrollOrResize, { passive: true });
      window.addEventListener(
        "pageshow",
        (e) => {
          if (e.persisted) {
            onScrollOrResize();
          }
        }
      );
      if (document.fonts?.ready) {
        void document.fonts.ready.then(() => onScrollOrResize());
      } else {
        onScrollOrResize();
      }
    }
  })();
</script>

<style>
  :global(body.mobile-menu-open) {
    overflow: hidden;
  }

  :global(body.site-search-open) {
    overflow: hidden;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .site-header {
    font-family: "Montserrat", "Segoe UI", Arial, sans-serif;
  }

  .header-top-stack {
    position: relative;
    z-index: 2;
  }

  .brand-cluster {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    min-width: 0;
  }

  .mobile-donate-strip {
    display: none;
  }

  .top-row {
    background: var(--color-teal);
    padding: 9px 0;
    position: relative;
    z-index: 1;
    box-shadow: 0 2px 10px rgba(10, 35, 74, 0.12);
  }

  .top-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .header-right {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: 10px 12px;
  }

  .brand {
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    min-width: 120px;
  }

  .brand-logo {
    width: clamp(72px, 9vw, 108px);
    height: auto;
    display: block;
  }

  .actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px 14px;
    color: #fff;
    font-weight: 700;
  }

  .header-phone {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
    font-size: var(--type-body);
    line-height: 1;
    text-shadow: 0 1px 2px rgba(8, 26, 48, 0.35);
  }

  .header-phone:hover,
  .header-phone:focus-visible {
    text-decoration: underline;
    color: #fff;
  }

  .header-phone-icon {
    font-size: var(--type-subtitle);
    line-height: 1;
    opacity: 0.95;
  }

  .phone-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
  }

  .phone-label {
    font-size: var(--type-micro);
    line-height: 1;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: none;

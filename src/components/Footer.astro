---
import contact from "../data/contact.json";

const footerMapHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(contact.mapSearchQuery)}`;
const charityCommissionHref =
  contact.charityCommissionUrl ??
  "https://register-of-charities.charitycommission.gov.uk/en/charity-search/-/charity-details/1057941/charity-overview";

const mailingListFormUrl =
  "https://dovecottagedayhospice.beaconforms.com/form/3501530c";
---

<footer class="site-footer">
  <section class="footer-cta">
    <div class="container footer-cta-inner">
      <p>Every donation helps us provide palliative care and support to local families.</p>
      <div class="cta-actions">
        <a href="/donate/" class="btn btn-secondary cta-button">Donate Now</a>
        <a href="tel:01949860303" class="cta-phone">01949 860303</a>
      </div>
    </div>
  </section>

  <section class="footer-main">
    <img
      src="/images/sunflower-brand-small.png"
      alt=""
      class="footer-sunflower"
      aria-hidden="true"
      loading="lazy"
    />

    <div class="container footer-grid">
      <div class="footer-col footer-col--links">
        <h3>What We Offer</h3>
        <a href="/hospice-services/">Hospice Services</a>
        <a href="/what-we-offer/carer-patient-wellbeing/">Carer &amp; Patient Wellbeing</a>
        <a href="/what-we-offer/dementia-home-sitting/">Dementia Home-Sitting</a>
        <a href="/hospice-services/counselling-support/">Counselling &amp; Support</a>
      </div>

      <div class="footer-col footer-col--links">
        <h3>Support Us</h3>
        <a href="/support-us/">See All Ways to Support Us</a>
        <a href="/donate/">Make a Donation</a>
        <a href="/support-us/volunteer-your-time/">Volunteer Your Time</a>
        <a href="/support-us/leave-a-gift-in-your-will/">Leave a Gift in Your Will</a>
        <a href="/support-us/fundraise-for-us/">Fundraise for Us</a>
        <a href="/shops/">Visit Our Shops</a>
        <a href="/support-us/corporate-partnerships/">Become a Corporate Partner</a>
        <a href="/support-us/our-corporate-partners/">Our Corporate Partners</a>
      </div>

      <div class="footer-col footer-col--links">
        <h3>Resources</h3>
        <a href="/explore/">About Us</a>
        <a href="/contact/">Contact Us</a>
        <a href="/make-a-referral/">Make a Referral</a>
        <a href="/hospice-services/resource-hub/">Resource Hub</a>
        <a href="/hospice-services/vacancies/">Vacancies</a>
        <a href="/news/">News &amp; Events</a>
        <a href="/news/?feed=event">Forthcoming Events</a>
        <a href="/newsletter/">Newsletter Archive</a>
        <a href="/hire-our-facilities/">Hire Our Facilities</a>
        <a href="/raising-a-complaint/">Raising a Complaint</a>
        <a href="/cookie-policy/">Cookie Policy</a>
        <a href="/privacy/">Privacy Policy</a>
        <a href="/terms-and-conditions/">Terms &amp; Conditions</a>
        <a href="/sitemap/">Site Map</a>
      </div>

      <div class="mailing-list-card">
        <h3>Join our mailing list</h3>
        <p>Hear about events, news, and hospice life. Signing up takes a minute on our secure form.</p>
        <a
          href={mailingListFormUrl}
          class="btn btn-primary btn-shine mailing-list-cta"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Join our mailing list — opens signup form in a new tab"
        >
          Sign Up
          <svg class="mailing-list-cta-external" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M14 3h7v7M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
            />
          </svg>
        </a>
      </div>
    </div>

    <div class="container footer-contact" role="region" aria-label="Contact Dove Cottage">
      <ul class="footer-contact-list">
        <li class="footer-contact-item-wrap">
          <a href="tel:01949860303" class="footer-contact-item">
            <span class="footer-contact-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </span>
            <span class="footer-contact-body">
              <span class="footer-contact-label">Call us</span>
              <span class="footer-contact-value">01949 860303</span>
            </span>
          </a>
        </li>
        <li class="footer-contact-item-wrap footer-contact-item-wrap--email">
          <a href="mailto:admin@dovecottage.org" class="footer-contact-item footer-contact-item--email">
            <span class="footer-contact-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            </span>
            <span class="footer-contact-body">
              <span class="footer-contact-label">Email us</span>
              <span class="footer-contact-value">admin@dovecottage.org</span>
            </span>
          </a>
        </li>
        <li class="footer-contact-item-wrap">
          <a
            href={footerMapHref}
            class="footer-contact-item"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit us — open address in Google Maps"
          >
            <span class="footer-contact-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <span class="footer-contact-body">
              <span class="footer-contact-label">Visit us</span>
              <span class="footer-contact-value"
                >Canal Lane, Stathern, <wbr />Melton Mowbray, LE14 4EX</span
              >
            </span>
          </a>
        </li>
      </ul>
    </div>

    <div class="container footer-bottom">
      <a href="/" class="footer-brand" aria-label="Dove Cottage website home">
        <img
          src="/images/dove-logo-white.svg"
          alt="Dove Cottage Day Hospice"
          class="footer-brand-logo"
          width="108"
          loading="lazy"
        />
      </a>
      <div class="socials" aria-label="Social media">
        <a
          href="https://www.facebook.com/DoveCottageDayHospice/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Dove Cottage on Facebook"
        >
          <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/dove_cottage_hospice/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Dove Cottage on Instagram"
        >
          <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.youtube.com/@DoveCottageHospice"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Dove Cottage on YouTube"
        >
          <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
            ></path>
          </svg>
        </a>
      </div>
      <p>Dove Cottage Day Hospice</p>
      <small>
        © 2026 Registered Charity No.
        <a href={charityCommissionHref} target="_blank" rel="noopener noreferrer">1057941</a>
      </small>
      <p class="footer-site-meta">
        <a href="/sitemap/">Page Sitemap</a>
        <span class="footer-site-meta-sep" aria-hidden="true">/</span>
        <a href="/sitemap.xml">Sitemap XML</a>
        <br />
        <a class="footer-siteby-link" href="https://dotwall.co.uk" target="_blank" rel="noopener noreferrer">
          dotwall
        </a>
      </p>
    </div>
  </section>
</footer>

<style>
  .site-footer {
    margin-top: 0;
  }

  .footer-cta {
    background: var(--color-golden-yellow);
    padding: 22px 0;
  }

  .footer-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .footer-cta p {
    margin: 0;
    color: #204579;
    font-size: var(--type-body-large);
    line-height: 1.35;
    font-weight: 700;
    max-width: 560px;
  }

  .cta-actions {
    display: inline-flex;
    align-items: center;
    gap: 18px;
  }

  .cta-button {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 999px;
    height: 40px;
    padding: 0 20px;
    border-color: #2c5ea6;
    color: #2c5ea6;
    background: rgba(255, 255, 255, 0.95);
  }

  .cta-phone {
    color: #2a4f86;
    text-decoration: none;
    font-size: var(--type-body);
    font-weight: 700;
  }

  .footer-main {
    position: relative;
    background: #2b58a3;
    color: rgba(255, 255, 255, 0.92);
    overflow: hidden;
    padding: 44px 0 28px;
  }

  .footer-sunflower {
    position: absolute;
    right: -80px;
    bottom: -110px;
    width: clamp(220px, 24vw, 360px);
    opacity: 0.16;
    pointer-events: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr minmax(230px, 260px);
    gap: 24px;
    align-items: start;
  }

  .footer-col h3,
  .mailing-list-card h3 {
    margin: 0 0 10px;
    font-size: var(--type-micro);
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-golden-yellow);
  }

  .footer-col--links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  /* Animated white underline (grows from centre on hover / focus) */
  .footer-site-meta a,
  .footer-bottom small a {
    position: relative;
    display: inline-block;
    width: fit-content;
    max-width: 100%;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    padding-bottom: 3px;
    transition: color 0.2s ease;
  }

  .footer-col--links a {
    position: relative;
    display: block;
    width: fit-content;
    max-width: 100%;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    padding-bottom: 3px;
    transition: color 0.2s ease;
    font-size: var(--type-body-small);
    line-height: 1.45;
    margin-bottom: 6px;
  }

  .footer-col--links a:last-child {
    margin-bottom: 0;
  }

  .footer-col--links a::after,
  .footer-site-meta a::after,
  .footer-bottom small a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 1px;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .footer-col--links a:hover,
  .footer-col--links a:focus-visible,
  .footer-site-meta a:hover,
  .footer-site-meta a:focus-visible,
  .footer-bottom small a:hover,
  .footer-bottom small a:focus-visible {
    color: #fff;
  }

  .footer-col--links a:hover::after,
  .footer-col--links a:focus-visible::after,
  .footer-site-meta a:hover::after,
  .footer-site-meta a:focus-visible::after,
  .footer-bottom small a:hover::after,
  .footer-bottom small a:focus-visible::after {
    transform: scaleX(1);
  }

  .footer-col--links a:focus-visible,
  .footer-site-meta a:focus-visible,
  .footer-bottom small a:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .mailing-list-card {
    background: linear-gradient(
      160deg,
      rgba(255, 255, 255, 0.16) 0%,
      rgba(255, 255, 255, 0.07) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 14px;
    padding: 16px;
    box-shadow: 0 10px 28px rgba(8, 24, 58, 0.22);
  }

  .mailing-list-card p {
    margin: 0 0 14px;
    font-size: var(--type-body-small);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.94);
    max-width: 36ch;
  }

  .mailing-list-card .mailing-list-cta {
    width: 100%;
    box-sizing: border-box;
    min-height: 46px;
    height: auto;
    padding: 11px 18px;
    border-radius: 999px;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: none;
    border: 1px solid rgba(255, 255, 255, 0.35);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.14);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }

  .mailing-list-card .mailing-list-cta:hover,
  .mailing-list-card .mailing-list-cta:focus-visible {
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.2);
  }

  .mailing-list-cta:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 3px;
  }

  .mailing-list-cta-external {
    width: 1.1em;
    height: 1.1em;
    flex-shrink: 0;
    opacity: 0.92;
    margin-inline-start: 0.15em;
    translate: 0 1px;
  }

  .footer-contact {
    margin-top: 30px;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .footer-contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 20px 36px;
  }

  .footer-contact-item-wrap {
    flex: 1 1 200px;
    max-width: 340px;
    min-width: min(100%, 220px);
  }

  .footer-contact-item-wrap--email {
    flex: 1.15 1 260px;
    max-width: 400px;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.92);
    margin: 0;
    line-height: 1.4;
  }

  a.footer-contact-item:hover,
  a.footer-contact-item:focus-visible {
    color: #fff;
  }

  a.footer-contact-item:hover .footer-contact-icon,
  a.footer-contact-item:focus-visible .footer-contact-icon {
    background: rgba(255, 255, 255, 0.18);
    color: #fff4a8;
    box-shadow: 0 0 0 1px rgba(254, 220, 6, 0.45);
  }

  a.footer-contact-item:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 4px;
    border-radius: 12px;
  }

  .footer-contact-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.15);
    color: var(--color-golden-yellow);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    transition:
      background 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .footer-contact-icon svg {
    width: 22px;
    height: 22px;
  }

  .footer-contact-item--email .footer-contact-icon {
    width: 50px;
    height: 50px;
    border-radius: 14px;
  }

  .footer-contact-item--email .footer-contact-icon svg {
    width: 24px;
    height: 24px;
  }

  .footer-contact-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .footer-contact-label {
    font-size: var(--type-micro);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-golden-yellow);
    opacity: 0.95;
  }

  .footer-contact-value {
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    word-break: break-word;
  }

  a.footer-contact-item--email .footer-contact-value {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .socials {
    display: flex;
    gap: 8px;
  }

  .footer-bottom .socials {
    justify-content: center;
    gap: 14px;
    margin: 0 auto 18px;
  }

  .socials a {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #fff;
    background: rgba(34, 64, 114, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.18);
    font-size: var(--type-micro);
    font-weight: 700;
  }

  .footer-bottom .socials a {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    border-width: 2px;
    transition:
      transform 0.32s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.28s ease,
      box-shadow 0.32s ease,
      border-color 0.28s ease;
  }

  .footer-bottom .socials a:hover,
  .footer-bottom .socials a:focus-visible {
    transform: translateY(-4px) scale(1.07);
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(254, 220, 6, 0.75);
    box-shadow:
      0 10px 24px rgba(0, 0, 0, 0.22),
      0 0 0 1px rgba(254, 220, 6, 0.4),
      0 0 28px rgba(254, 220, 6, 0.18);
  }

  .footer-bottom .socials a:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 3px;
  }

  .footer-bottom .social-icon {
    width: 22px;
    height: 22px;
    display: block;
    flex-shrink: 0;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .footer-bottom .socials a:hover .social-icon,
  .footer-bottom .socials a:focus-visible .social-icon {
    transform: scale(1.12);
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-bottom .socials a,
    .footer-bottom .social-icon {
      transition: none;
    }

    .footer-bottom .socials a:hover,
    .footer-bottom .socials a:focus-visible {
      transform: none;
      box-shadow: none;
    }

    .footer-bottom .socials a:hover .social-icon,
    .footer-bottom .socials a:focus-visible .social-icon {
      transform: none;
    }

    .footer-col--links a::after,
    .footer-site-meta a::after,
    .footer-bottom small a::after {
      transition: none;
    }
  }

  .footer-bottom {
    margin-top: 26px;
    padding-top: 18px;

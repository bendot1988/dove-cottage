---
interface ShopItem {
  slug: string;
  /** Short label for the blue banner (e.g. BOTTESFORD) */
  label: string;
  image: string;
}

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  vintedUrl: string;
  ebayUrl: string;
  sunflowerImage?: string;
  shops: ShopItem[];
}

const {
  eyebrow,
  title,
  intro,
  vintedUrl,
  ebayUrl,
  sunflowerImage = "/images/sunflower-brand.png",
  shops
} = Astro.props as Props;
---

{
  shops.length > 0 && (
    <section class="home-shops">
      <img
        src={sunflowerImage}
        alt=""
        class="home-shops-flower"
        width="440"
        height="440"
        loading="lazy"
        aria-hidden="true"
      />

      <div class="container home-shops-inner">
        <div class="home-shops-grid-wrap">
          <div class="home-shops-grid cards-grid">
            {shops.map((shop) => (
              <a
                href={`/shops/${shop.slug}/`}
                class="home-shop-card"
                aria-label={`${shop.label} — view shop details`}
              >
                <div class="home-shop-image" style={`background-image: url('${shop.image}')`} aria-hidden="true" />
                <span class="home-shop-label">{shop.label}</span>
              </a>
            ))}
          </div>
        </div>

        <div class="home-shops-copy">
          <p class="home-shops-eyebrow">{eyebrow}</p>
          <h2 class="home-shops-title">{title}</h2>
          <p class="home-shops-intro">{intro}</p>
          <div class="home-shops-actions">
            <a href={vintedUrl} class="home-shops-btn" target="_blank" rel="noreferrer">
              Vinted Store
            </a>
            <a href={ebayUrl} class="home-shops-btn" target="_blank" rel="noreferrer">
              Ebay Store
            </a>
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .home-shops {
    position: relative;
    background: #fff;
    padding: clamp(3.75rem, 9vw, 6rem) 0 clamp(4rem, 9.5vw, 6.25rem);
    overflow: hidden;
    isolation: isolate;
  }

  .container {
    width: min(1200px, 95%);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .home-shops-flower {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    width: clamp(200px, 32vw, 400px);
    height: auto;
    right: -10%;
    bottom: -20%;
    opacity: 0.88;
    object-fit: contain;
  }

  .home-shops-inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: clamp(24px, 4vw, 48px);
    position: relative;
    z-index: 2;
  }

  .home-shops-grid-wrap {
    flex: 1;
    min-width: 0;
    max-width: min(100%, 520px);
  }

  .home-shops-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .home-shop-card {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: block;
    text-decoration: none;
    box-shadow: 0 8px 22px rgba(18, 44, 83, 0.12);
    border: 1px solid rgba(15, 40, 80, 0.08);
    transition:
      transform 0.25s var(--motion-ease-out, ease),
      box-shadow 0.25s ease;
  }

  .home-shop-card:hover,
  .home-shop-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 14px 28px rgba(18, 44, 83, 0.16);
  }

  .home-shop-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s var(--motion-ease-out, ease);
  }

  .home-shop-card:hover .home-shop-image,
  .home-shop-card:focus-visible .home-shop-image {
    transform: scale(1.05);
  }

  .home-shop-label {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 11px 10px;
    background: var(--color-steel-blue-1);
    color: #fff;
    font-weight: 800;
    font-size: clamp(0.65rem, 1.5vw, 0.75rem);
    letter-spacing: 0.1em;
    text-align: center;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .home-shops-copy {
    flex: 1;
    min-width: min(100%, 380px);
    position: relative;
    z-index: 2;
    padding: clamp(0.75rem, 2vw, 1.25rem) clamp(1rem, 3.5vw, 2.75rem) clamp(0.75rem, 2vw, 1.25rem)
      clamp(0.25rem, 1vw, 0.75rem);
  }

  /* Solid white plate behind copy so the sunflower never competes with text */
  .home-shops-copy::before {
    content: "";
    position: absolute;
    top: -0.5rem;
    bottom: -0.5rem;
    left: clamp(-1.25rem, -3vw, -0.5rem);
    right: clamp(-2rem, -5vw, -1rem);
    background: #fff;
    border-radius: 0 16px 16px 0;
    z-index: -1;
    pointer-events: none;
    box-shadow: -12px 0 28px rgba(255, 255, 255, 0.9);
  }

  .home-shops-eyebrow {
    margin: 0 0 10px;
    font-size: var(--type-micro);
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-steel-blue);
  }

  .home-shops-title {
    margin: 0 0 14px;
    font-size: var(--type-section-title);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: #0f2240;
  }

  .home-shops-intro {
    margin: 0 0 22px;
    color: #3f5370;
    font-size: var(--type-body-large);
    line-height: 1.55;
  }

  .home-shops-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .home-shops-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 22px;
    border-radius: 999px;
    background: var(--color-steel-blue-1);
    color: #fff;
    font-size: var(--type-button);
    font-weight: 700;
    text-decoration: none;
    border: 1px solid rgba(15, 40, 80, 0.15);
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .home-shops-btn:hover,
  .home-shops-btn:focus-visible {
    background: var(--color-steel-blue);
    color: #fff;
  }

  .home-shops-btn:active {
    transform: scale(0.98);
  }

  @media (max-width: 960px) {
    .home-shops-inner {
      flex-direction: column;
      align-items: stretch;
    }

    .home-shops-grid-wrap {
      max-width: 480px;
      margin-inline: auto;
      order: 2;
    }

    .home-shops-copy {
      order: 1;
      text-align: center;
      padding-left: clamp(0.75rem, 3vw, 1.5rem);
      padding-right: clamp(0.75rem, 3vw, 1.5rem);
    }

    .home-shops-copy::before {
      left: 0;
      right: 0;
      top: -0.25rem;
      bottom: -0.25rem;
      border-radius: 14px;
      background: #fff;
      box-shadow: 0 8px 32px rgba(18, 44, 83, 0.06);
    }

    .home-shops-actions {
      justify-content: center;
    }

    .home-shops-flower {
      right: -14%;
      bottom: -24%;
      opacity: 0.75;
    }
  }

  @media (max-width: 520px) {
    .home-shops-actions {
      flex-direction: column;
    }

    .home-shops-btn {
      width: 100%;
    }
  }
</style>

---
import reviewData from "../data/subpage-reviews.json";

type ReviewRow = { text: string } | string;

interface Props {
  reviews?: ReviewRow[];
  intervalMs?: number;
  supportCtaLabel?: string;
  supportCtaHref?: string;
}

const props = Astro.props as Props;
const input = props.reviews ?? reviewData.reviews;
const reviews = input
  .map((row) => (typeof row === "string" ? row : row.text))
  .map((text) => text.trim())
  .filter(Boolean);
const intervalMs = Math.max(1800, Number(props.intervalMs ?? reviewData.intervalMs ?? 3200));
const supportCtaLabel = (props.supportCtaLabel ?? reviewData.supportCtaLabel ?? "How you can support us").trim();
const supportCtaHref = (props.supportCtaHref ?? reviewData.supportCtaHref ?? "#").trim() || "#";
---

{
  reviews.length > 0 && (
    <div class="subpage-review-strip" aria-label="Supporter reviews">
      <div class="container">
        <div class="subpage-review-row">
          <div
            class="subpage-review-rotator"
            data-subpage-review-rotator
            data-interval-ms={intervalMs}
            aria-live="polite"
          >
            {reviews.map((text, idx) => (
              <p class:list={["subpage-review-item", { "is-active": idx === 0 }]}>
                <span class="subpage-review-quote" aria-hidden="true">“</span>
                <span class="subpage-review-text">{text}</span>
                <span class="subpage-review-quote" aria-hidden="true">”</span>
              </p>
            ))}
          </div>
          <a class="btn btn-ghost subpage-review-cta" href={supportCtaHref}>
            <span>{supportCtaLabel}</span>
          </a>
        </div>
      </div>
    </div>
  )
}

<script is:inline>
  (() => {
    const rotators = document.querySelectorAll("[data-subpage-review-rotator]");
    rotators.forEach((rotator) => {
      const items = Array.from(rotator.querySelectorAll(".subpage-review-item"));
      if (items.length < 2) return;

      const intervalMs = Number(rotator.getAttribute("data-interval-ms")) || 3200;
      let active = 0;

      window.setInterval(() => {
        items[active]?.classList.remove("is-active");
        active = (active + 1) % items.length;
        items[active]?.classList.add("is-active");
      }, intervalMs);
    });
  })();
</script>

<style>
  .subpage-review-strip {
    background: #fff;
    border-bottom: 1px solid #d9e3f0;
  }

  .subpage-review-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 14px 24px;
    padding: 10px 0;
  }

  .subpage-review-cta {
    min-height: 38px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid #c6d5eb;
    background: #f8fbff;
    color: #224979;
    font-size: var(--type-button-small);
    font-weight: 700;
    line-height: 1.1;
    transition:
      background 0.18s var(--motion-ease-out),
      border-color 0.18s var(--motion-ease-out),
      color 0.18s var(--motion-ease-out),
      box-shadow 0.18s var(--motion-ease-out);
    text-decoration: none !important;
    white-space: nowrap;
    justify-self: end;
  }

  .subpage-review-cta:hover,
  .subpage-review-cta:focus-visible {
    background: #edf4ff;
    border-color: #aac2e2;
    color: #1d467c;
    text-decoration: none !important;
    box-shadow: 0 4px 12px rgba(23, 55, 94, 0.12);
  }

  .subpage-review-cta:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
  }

  .subpage-review-rotator {
    min-height: 52px;
    width: 100%;
    justify-self: start;
    display: grid;
    align-items: center;
    padding: 8px 0;
  }

  .subpage-review-item {
    grid-area: 1 / 1;
    margin: 0;
    width: 100%;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 0.45s var(--motion-ease-out),
      transform 0.45s var(--motion-ease-out);
    text-align: left;
    pointer-events: none;
    visibility: hidden;
  }

  .subpage-review-item.is-active {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }

  .subpage-review-quote {
    color: var(--color-golden-yellow);
    font-size: 1.6rem;
    line-height: 1;
    vertical-align: middle;
    font-weight: 700;
  }

  .subpage-review-text {
    margin: 0 6px;
    color: #0f2240;
    font-size: var(--type-body);
    font-style: italic;
    line-height: 1.45;
    vertical-align: middle;
    text-align: left;
  }

  @media (max-width: 640px) {
    .subpage-review-row {
      grid-template-columns: 1fr;
      align-items: stretch;
      gap: 8px;
    }

    .subpage-review-cta {
      display: none;
    }

    .subpage-review-rotator {
      min-height: 74px;
      max-width: none;
      width: 100%;
      justify-self: stretch;
      padding: 6px 0;
      justify-items: center;
    }

    .subpage-review-item,
    .subpage-review-text {
      text-align: center;
    }

    .subpage-review-text {
      font-size: var(--type-body-small);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .subpage-review-item {
      transition: none;
    }
  }
</style>

---
interface SupportCard {
  icon: string;
  title: string;
  description: string;
  buttonLabel: string;
  buttonLink: string;
  buttonVariant: "primary" | "secondary" | "ghost";
  featured?: boolean;
}

interface Props {
  title: string;
  intro: string;
  backgroundFlowerLeft: string;
  backgroundFlowerRight: string;
  cards: SupportCard[];
}

const {
  title = "Help us Keep Our Doors Open",
  intro = "It costs over £705,000 each year to provide our specialist care free of charge to local families. We rely on the kindness of our local community to ensure no family faces life-limiting conditions alone.",
  backgroundFlowerLeft = "/images/sunflower-brand-small.png",
  backgroundFlowerRight = "/images/sunflower-brand.png",
  cards = [
    {
      icon: "/images/icon-pound.svg",
      title: "Make a Donation",
      description:
        "Whether it is a one-off gift or a monthly contribution, your support directly funds our nursing care and family support.",
      buttonLabel: "Donate Now",
      buttonLink: "/donate/",
      buttonVariant: "primary",
      featured: true
    },
    {
      icon: "/images/icon-heart.svg",
      title: "Volunteer",
      description:
        "Join the Dove family! We are always looking for friendly faces to help support our work.",
      buttonLabel: "Learn More",
      buttonLink: "#",
      buttonVariant: "secondary"
    },
    {
      icon: "/images/icon-medal.svg",
      title: "Fundraise For Us",
      description:
        "From coffee mornings to marathons, turn your passion into support for local families.",
      buttonLabel: "Get Involved",
      buttonLink: "#",
      buttonVariant: "primary"
    },
    {
      icon: "/images/icon-tree.svg",
      title: "Leave a Legacy",
      description:
        "A gift in your Will is a wonderful way to ensure that future generations receive the care they deserve.",
      buttonLabel: "Find Out More",
      buttonLink: "#",
      buttonVariant: "secondary"
    }
  ]
} = Astro.props as Props;
---

<section class="support-cards">
  <img src={backgroundFlowerLeft} alt="" class="flower flower-left" loading="lazy" aria-hidden="true" />
  <img src={backgroundFlowerRight} alt="" class="flower flower-right" loading="lazy" aria-hidden="true" />

  <div class="container">
    <h2>{title}</h2>
    <p>{intro}</p>

    <div class="cards-grid">
      {
        cards.map((card) => (
          <article class="support-card">
            <div class="card-top">
              <span class="icon-wrap">
                <img src={card.icon} alt="" aria-hidden="true" />
              </span>
              {card.featured && <span class="badge">★ MOST NEEDED</span>}
            </div>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <a href={card.buttonLink} class={`btn btn-${card.buttonVariant} support-btn ${card.featured ? "btn-shine" : ""}`}>
              {card.buttonLabel}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .support-cards {
    position: relative;
    background: var(--color-lavender);
    padding: 58px 0 70px;
    overflow: hidden;
    isolation: isolate;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  .flower {
    position: absolute;
    pointer-events: none;
    opacity: 0.2;
    z-index: 0;
  }

  .flower-left {
    width: clamp(160px, 20vw, 270px);
    left: -48px;
    top: 84px;
  }

  .flower-right {
    width: clamp(220px, 30vw, 440px);
    right: -100px;
    bottom: -110px;
  }

  h2 {
    margin: 0;
    text-align: center;
    color: #0f2240;
    font-size: var(--type-section-title);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .container > p {
    margin: 12px auto 30px;
    max-width: 840px; /* was 790px — a touch wider to reduce orphaned last lines */
    text-align: center;
    text-wrap: pretty;
    color: #364861;
    font-size: var(--type-body-large);
    line-height: 1.5;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .support-card {
    background: #fff;
    border: 1px solid #dbe4f2;
    border-radius: 16px;
    box-shadow: 0 8px 20px rgba(20, 41, 74, 0.08);
    padding: 20px 18px 18px;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.24s ease,
      box-shadow 0.24s ease,
      border-color 0.24s ease;
  }

  .support-card:focus-within {
    outline: 2px solid rgba(44, 94, 166, 0.45);
    outline-offset: 3px;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 14px;
    min-height: 52px;
  }

  .icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .icon-wrap img {
    width: 52px;
    height: 52px;
    object-fit: contain;
    transition: transform 0.24s ease;
  }

  .badge {
    background: var(--color-golden-yellow);
    color: #2b2b2b;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: var(--type-micro);
    line-height: 1;
    font-weight: 700;
    white-space: nowrap;
    margin-top: 2px;
  }

  h3 {
    margin: 0 0 8px;
    font-size: var(--type-card-title);
    line-height: 1.25;
    font-weight: 600;
    color: #111f35;
  }

  .support-card p {
    margin: 0 0 18px;
    color: #425671;
    font-size: var(--type-body);
    line-height: 1.5;
    flex-grow: 1;
  }

  .support-btn {
    border-radius: 999px;
    width: 100%;
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .support-card:hover,
    .support-card:focus-within {
      transform: translateY(-4px);
      border-color: #c7d7ec;
      box-shadow: 0 16px 34px rgba(20, 41, 74, 0.16);
    }

    .support-card:hover .icon-wrap img,
    .support-card:focus-within .icon-wrap img {
      transform: translateY(-1px) scale(1.03);
    }

    .support-card:hover .support-btn,
    .support-card:focus-within .support-btn {
      transform: translateY(-1px);
      box-shadow: 0 8px 18px rgba(20, 41, 74, 0.16);
    }
  }

  @media (max-width: 1200px) {
    .cards-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .support-cards {
      padding: 46px 0 56px;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

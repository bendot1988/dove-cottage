---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import QuickLinksFab from "../components/QuickLinksFab.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = "Dove Cottage",
  description = "Dove Cottage Day Hospice provides free palliative care and support for families across Leicestershire, Nottinghamshire and Lincolnshire.",
  noindex = false
} = Astro.props;

const clampText = (input: string, maxLength: number) => {
  const normalized = input.replace(/\s+/g, " ").trim();
  if (normalized.length <= maxLength) return normalized;
  const sliced = normalized.slice(0, maxLength - 1);
  const safeBoundary = sliced.lastIndexOf(" ");
  const trimmed = (safeBoundary > Math.floor(maxLength * 0.6) ? sliced.slice(0, safeBoundary) : sliced).trim();
  return `${trimmed}…`;
};

const seoTitle = clampText(title, 60);
const seoDescription = clampText(description, 160);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {noindex && <meta name="googlebot" content="noindex, nofollow" />}
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <QuickLinksFab />
    <script is:inline>
      (() => {
        const hash = window.location.hash || "";
        const tokenKeys = ["recovery_token=", "invite_token=", "confirmation_token="];
        const hasIdentityToken = tokenKeys.some((key) => hash.includes(key));

        if (hasIdentityToken && !window.location.pathname.startsWith("/admin")) {
          window.location.replace(`/admin/${hash}`);
        }
      })();
    </script>
  </body>
</html>

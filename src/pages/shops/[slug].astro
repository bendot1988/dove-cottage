---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { marked } from "marked";
import { resolveSanityImageUrl, sanityClient } from "../../lib/sanity";

export async function getStaticPaths() {
  const shops = await getCollection("shops", ({ data }) => !data.draft);
  return shops.map((shop) => ({
    params: { slug: shop.slug },
    props: { shop }
  }));
}

const { shop } = Astro.props as { shop: CollectionEntry<"shops"> };
const isCotgravePage = shop.slug === "cotgrave";

const cotgravePage = isCotgravePage
  ? await sanityClient.fetch(
      `
        *[_type == "cotgraveShopPage" && _id == "cotgraveShopPage.main"][0]{
          title,
          heroLocation,
          heroTagline,
          shopInfo,
          callout,
          shopMainImage,
          shopMainImageAlt,
          openingHours,
          gallery,
          buttonColour,
          phone,
          address,
          mapEmbedUrl,
          donationsBlurb,
          facebookLink,
          instagramLink,
          htmlTest
        }
      `
    )
  : null;

const getGalleryImageUrl = (value: unknown) =>
  resolveSanityImageUrl(value, typeof value === "string" ? value : "");

const shopData = {
  ...shop.data,
  title: cotgravePage?.title || shop.data.title,
  hero_location: cotgravePage?.heroLocation || shop.data.hero_location,
  hero_tagline: cotgravePage?.heroTagline || shop.data.hero_tagline,
  shop_info: cotgravePage?.shopInfo || shop.data.shop_info,
  callout: cotgravePage?.callout || shop.data.callout,
  shop_main_image: cotgravePage ? resolveSanityImageUrl(cotgravePage.shopMainImage, shop.data.shop_main_image) : shop.data.shop_main_image,
  opening_hours: cotgravePage?.openingHours || shop.data.opening_hours,
  gallery: cotgravePage?.gallery?.length
    ? cotgravePage.gallery.map(getGalleryImageUrl).filter(Boolean)
    : shop.data.gallery,
  button_colour: cotgravePage?.buttonColour || shop.data.button_colour,
  phone: cotgravePage?.phone || shop.data.phone,
  address: cotgravePage?.address || shop.data.address,
  map_embed_url: cotgravePage?.mapEmbedUrl || shop.data.map_embed_url,
  donations_blurb: cotgravePage?.donationsBlurb || shop.data.donations_blurb,
  facebook_link: cotgravePage?.facebookLink || shop.data.facebook_link,
  instagram_link: cotgravePage?.instagramLink || shop.data.instagram_link,
  html_test: cotgravePage?.htmlTest || shop.data.html_test,
};

const allShops = await getCollection("shops", ({ data }) => !data.draft);
const otherShops = allShops
  .filter((s) => s.slug !== shop.slug)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const telHref = `tel:${shopData.phone.replace(/\s+/g, "")}`;
const mapSrc =
  shopData.map_embed_url?.trim() ||
  `https://www.google.com/maps?q=${encodeURIComponent(shopData.address)}&output=embed`;

const heroLine1 = shopData.hero_location ?? shopData.title;
const heroLine2 = shopData.hero_location
  ? (shopData.hero_tagline ?? "Hospice Shop")
  : null;
const shopSeoDescription = `${shopData.title} charity shop at ${shopData.address}. ${shopData.donations_blurb ?? "Shop pre-loved items and support Dove Cottage Day Hospice."}`;
---

<BaseLayout title={`${shopData.title} | Our Shops | Dove Cottage`} description={shopSeoDescription}>
  <section class="hospice-svc-hero shop-hero" aria-label={heroLine1}>
    <img
      class="hospice-svc-hero-bg"
      src={shopData.shop_main_image}
      alt=""
      width="1920"
      height="720"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
    <div class="container hospice-svc-hero-inner">
      <a class="interior-hero-eyebrow" href="/shops/">
        <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
        Our Shops
      </a>
      <h1>{heroLine1}</h1>
      <p class="hospice-svc-hero-dek">
        {heroLine2 ?? shopData.address}
      </p>
    </div>
  </section>

  <div class="motion-scope shop-page">
    <section class="shop-main">
      <div class="container shop-layout">
        <div class="shop-primary">
          <p class="shop-eyebrow">About the shop</p>
          <div class="shop-story rich-content" set:html={marked.parse(shopData.shop_info)} />

          {
            shopData.callout && (
              <aside class="shop-callout" aria-label="How your purchase helps">
                <span class="shop-callout-icon" aria-hidden="true">♥</span>
                <div class="shop-callout-body rich-content" set:html={marked.parse(shopData.callout)} />
              </aside>
            )
          }

          {
            shopData.gallery.length > 0 && (
              <div class="shop-gallery-block">
                <h2 class="shop-gallery-title">Gallery</h2>
                <div class="shop-gallery-grid cards-grid">
                  {shopData.gallery.map((image, i) => (
                    <figure class="shop-gallery-item">
                      <img
                        src={image}
                        alt=""
                        loading={i < 2 ? "eager" : "lazy"}
                        decoding="async"
                      />
                    </figure>
                  ))}
                </div>
              </div>
            )
          }

          {shopData.html_test && <div class="shop-custom rich-content" set:html={shopData.html_test} />}
        </div>

        <aside class="visit-card" aria-label="Visit this shop">
          <h2 class="visit-title">Visit us</h2>
          <div class="visit-map">
            <iframe
              src={mapSrc}
              title={`Map of ${shopData.title}`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            />
          </div>
          <ul class="visit-list">
            <li>
              <span class="visit-icon" aria-hidden="true">📍</span>
              <span>{shopData.address}</span>
            </li>
            {
              shopData.facebook_link && (
                <li>
                  <span class="visit-icon" aria-hidden="true">f</span>
                  <a href={shopData.facebook_link} target="_blank" rel="noreferrer">
                    Facebook
                  </a>
                </li>
              )
            }
            {
              shopData.instagram_link && (
                <li>
                  <span class="visit-icon visit-icon-ig" aria-hidden="true">◎</span>
                  <a href={shopData.instagram_link} target="_blank" rel="noreferrer">
                    Instagram
                  </a>
                </li>
              )
            }
            <li>
              <span class="visit-icon" aria-hidden="true">☎</span>
              <a href={telHref}>{shopData.phone}</a>
            </li>
            {
              shopData.donations_blurb && (
                <li class="visit-donations">
                  <span class="visit-icon" aria-hidden="true">♥</span>
                  <span class="visit-donations-text">{shopData.donations_blurb}</span>
                </li>
              )
            }
            <li class="visit-hours">
              <span class="visit-icon" aria-hidden="true">🕐</span>
              <div class="visit-hours-body rich-content" set:html={marked.parse(shopData.opening_hours)} />
            </li>
          </ul>
          <a href="/donate/" class="btn btn-primary btn-shine visit-donate">Donate to support our hospice</a>
        </aside>
      </div>
    </section>

    {
      otherShops.length > 0 && (
        <section class="shop-other">
          <div class="container">
            <h2 class="shop-other-title">Other locations</h2>
            <div class="shop-other-grid cards-grid">
              {otherShops.map((s) => (
                <a href={`/shops/${s.slug}/`} class="shop-other-card">
                  <div class="shop-other-image" style={`background-image:url('${s.data.shop_main_image}')`} />
                  <span class="shop-other-label">{s.data.title}</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }
  </div>

  <script>
    import { initMotionScrollReveal } from "../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

<style>
  .shop-page {
    background: var(--color-lavender);
  }

  .shop-main {
    padding: 48px 0 56px;
  }

  .shop-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 28px;
    align-items: start;
  }

  .shop-eyebrow {
    margin: 0 0 10px;
    font-size: var(--type-micro);
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-steel-blue);
  }

  .shop-story {
    color: #3a4f6a;
    font-size: var(--type-body-large);
    line-height: 1.65;
  }

  .shop-story :global(p) {
    margin: 0 0 16px;
  }

  .shop-story :global(strong) {
    color: #1a3050;
  }

  .shop-callout {
    margin-top: 22px;
    display: flex;
    gap: 14px;
    padding: 18px 20px;
    border-radius: 14px;
    background: var(--color-alice-blue);
    border: 1px solid #d0e0f4;
  }

  .shop-callout-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: var(--color-golden-yellow);
    color: #1a3050;
    font-size: 1.25rem;
    line-height: 1;
  }

  .shop-callout-body {
    flex: 1;
    margin: 0;
    color: #2c3f58;
    font-size: var(--type-body);
    line-height: 1.55;
  }

  .shop-callout-body :global(p) {
    margin: 0;
  }

  .shop-gallery-block {
    margin-top: 36px;
  }

  .shop-gallery-title {
    margin: 0 0 16px;
    font-size: var(--type-section-title);
    color: var(--color-steel-blue);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .shop-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .shop-gallery-item {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #dce5f2;
    background: #fff;
    box-shadow: 0 4px 14px rgba(19, 47, 82, 0.06);
    transition:
      transform 0.25s var(--motion-ease-out, ease),
      box-shadow 0.25s ease;
  }

  .shop-gallery-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 22px rgba(19, 47, 82, 0.1);
  }

  .shop-gallery-item img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .shop-custom {
    margin-top: 22px;
    padding: 16px 18px;
    background: #fff;
    border-radius: 12px;
    border: 1px solid #dce5f2;
    font-size: var(--type-body);
    color: #3a4f6a;
  }

  .visit-card {
    position: sticky;
    top: 16px;
    background: #fff;
    border-radius: 16px;
    border: 1px solid #dde6f4;
    padding: 18px;
    box-shadow: 0 12px 32px rgba(18, 44, 83, 0.08);
  }

  .visit-title {
    margin: 0 0 14px;
    font-size: var(--type-card-title);
    color: var(--color-steel-blue);
    font-weight: 700;
  }

  .visit-map {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #e2e9f5;
    aspect-ratio: 4/3;
    background: #e8eef8;
  }

  .visit-map iframe {
    width: 100%;
    height: 100%;
    min-height: 200px;
    border: 0;
    display: block;
  }

  .visit-list {
    list-style: none;
    margin: 16px 0 18px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: var(--type-body-small);
    color: #344860;
  }

  .visit-list li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .visit-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: var(--color-ghost-white);
    color: var(--color-steel-blue);
    font-weight: 700;
    font-size: 0.85rem;
  }

  .visit-icon-ig {
    font-size: 1rem;
  }

  .visit-list a {
    color: var(--color-steel-blue);
    font-weight: 700;
    text-decoration: none;
  }

  .visit-list a:hover,
  .visit-list a:focus-visible {
    text-decoration: underline;
  }

  .visit-donations {
    align-items: flex-start;
  }

  .visit-donations-text {
    line-height: 1.5;
  }

  .visit-hours {
    align-items: flex-start;
  }

  .visit-hours-body {
    flex: 1;
    line-height: 1.5;
  }

  .visit-hours-body :global(p) {
    margin: 0 0 6px;
  }

  .visit-hours-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .visit-hours-body :global(strong) {
    color: #1a3050;
  }

  .visit-donate {
    width: 100%;
    border-radius: 999px;
    height: 48px;
    font-weight: 700;
    text-decoration: none;
    text-align: center;
  }

  .shop-other {
    padding: 8px 0 48px;
  }

  .shop-other-title {
    margin: 0 0 20px;
    text-align: center;
    font-size: var(--type-section-title);
    color: var(--color-steel-blue);
    font-weight: 700;
  }

  .shop-other-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .shop-other-card {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    min-height: 160px;
    box-shadow: 0 8px 20px rgba(18, 44, 83, 0.12);
    transition:
      transform 0.25s var(--motion-ease-out, ease),
      box-shadow 0.25s ease;
  }

  .shop-other-card:hover,
  .shop-other-card:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 14px 28px rgba(18, 44, 83, 0.16);
  }

  .shop-other-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .shop-other-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 35%, rgba(16, 34, 58, 0.88) 100%);
  }

  .shop-other-label {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    z-index: 1;
    font-weight: 800;
    font-size: var(--type-body);
    line-height: 1.25;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.45);
  }

  .rich-content :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .shop-layout {
      grid-template-columns: 1fr;
    }

    .visit-card {
      position: static;
    }

    .shop-gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .shop-gallery-grid {
      grid-template-columns: 1fr;
    }

    .shop-other-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

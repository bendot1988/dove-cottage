---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { marked } from "marked";

export async function getStaticPaths() {
  const shops = await getCollection("shops", ({ data }) => !data.draft);
  return shops.map((shop) => ({
    params: { slug: shop.slug },
    props: { shop }
  }));
}

const { shop } = Astro.props as { shop: CollectionEntry<"shops"> };
---

<BaseLayout title={`${shop.data.title} | Our Shops | Dove Cottage`}>
  <section class="shop-detail">
    <div class="container">
      <p class="back"><a href="/shops/">← Back to Our Shops</a></p>
      <h1>{shop.data.title}</h1>

      <img class="hero-image" src={shop.data.shop_main_image} alt={shop.data.title} />

      <div class="detail-grid">
        <article class="panel">
          <h2>Shop Info</h2>
          <div class="rich-content" set:html={marked.parse(shop.data.shop_info)} />
        </article>

        <article class="panel">
          <h2>Opening Hours</h2>
          <div class="rich-content" set:html={marked.parse(shop.data.opening_hours)} />
        </article>
      </div>

      <article class="panel contact-panel">
        <h2>Contact Details</h2>
        <p><strong>Phone:</strong> <a href={`tel:${shop.data.phone.replace(/\s+/g, "")}`}>{shop.data.phone}</a></p>
        <p><strong>Address:</strong> {shop.data.address}</p>
        <p class="social-links">
          {shop.data.facebook_link && (
            <a href={shop.data.facebook_link} target="_blank" rel="noreferrer">Facebook</a>
          )}
          {shop.data.instagram_link && (
            <a href={shop.data.instagram_link} target="_blank" rel="noreferrer">Instagram</a>
          )}
        </p>
      </article>

      {shop.data.gallery.length > 0 && (
        <section class="gallery">
          <h2>Gallery</h2>
          <div class="gallery-grid">
            {shop.data.gallery.map((image) => <img src={image} alt="" loading="lazy" />)}
          </div>
        </section>
      )}

      {shop.data.html_test && <section class="panel custom-html" set:html={shop.data.html_test} />}
    </div>
  </section>
</BaseLayout>

<style>
  .shop-detail {
    background: var(--color-lavender);
    padding: 56px 0 72px;
  }

  .container {
    width: min(1100px, 95%);
    margin: 0 auto;
  }

  .back {
    margin: 0 0 10px;
  }

  .back a {
    color: var(--color-steel-blue);
    text-decoration: none;
    font-weight: 700;
  }

  h1 {
    margin: 0 0 18px;
    font-size: var(--type-section-title);
    color: #102a4e;
  }

  .hero-image {
    width: 100%;
    border-radius: 14px;
    border: 1px solid #dce5f2;
    margin-bottom: 18px;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .panel {
    background: #fff;
    border: 1px solid #dce5f2;
    border-radius: 14px;
    padding: 18px;
  }

  h2 {
    margin: 0 0 10px;
    font-size: var(--type-card-title);
    color: #15345f;
  }

  .rich-content {
    color: #3a4f6a;
    font-size: var(--type-body);
    line-height: 1.6;
  }

  .rich-content :global(p) {
    margin: 0 0 10px;
  }

  .contact-panel p {
    margin: 0 0 8px;
    color: #344860;
    font-size: var(--type-body);
  }

  .contact-panel a {
    color: var(--color-steel-blue);
  }

  .social-links {
    display: flex;
    gap: 12px;
  }

  .gallery {
    margin-top: 18px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .gallery-grid img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid #dce5f2;
    background: #fff;
  }

  .custom-html {
    margin-top: 18px;
  }

  @media (max-width: 900px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

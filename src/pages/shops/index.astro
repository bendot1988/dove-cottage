---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { marked } from "marked";

const shops = (await getCollection("shops", ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout title="Our Shops | Dove Cottage">
  <section class="shops-listing">
    <div class="container">
      <h1>Our Shops</h1>
      <p class="intro">
        Visit our charity shops to support Dove Cottage Day Hospice. Every purchase helps us continue
        to provide free specialist care.
      </p>

      {shops.length === 0 ? (
        <p>No shop entries published yet.</p>
      ) : (
        <div class="shops-grid">
          {shops.map((shop) => (
            <article class="shop-card">
              <a href={`/shops/${shop.slug}/`} class="image-link">
                <img src={shop.data.shop_main_image} alt={shop.data.title} loading="lazy" />
              </a>
              <div class="shop-card-body">
                <h2>
                  <a href={`/shops/${shop.slug}/`}>{shop.data.title}</a>
                </h2>
                <div class="snippet" set:html={marked.parse(shop.data.shop_info)} />
                <p class="meta">{shop.data.address}</p>
                <a href={`/shops/${shop.slug}/`} class="shop-cta" style={`--shop-btn-color:${shop.data.button_colour};`}>
                  View Shop Details
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .shops-listing {
    background: var(--color-lavender);
    padding: 56px 0 72px;
  }

  h1 {
    margin: 0;
    font-size: var(--type-section-title);
    color: var(--color-steel-blue);
  }

  .intro {
    margin: 12px 0 24px;
    color: #3a4e6a;
    font-size: var(--type-body-large);
    max-width: 860px;
  }

  .shops-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .shop-card {
    background: #fff;
    border: 1px solid #dde6f4;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 18px rgba(18, 44, 83, 0.08);
    display: flex;
    flex-direction: column;
  }

  .image-link img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .shop-card-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  h2 {
    margin: 0 0 10px;
    font-size: var(--type-card-title);
  }

  h2 a {
    color: #102a4e;
    text-decoration: none;
  }

  .snippet {
    color: #3f5370;
    font-size: var(--type-body);
    line-height: 1.55;
    flex: 1;
  }

  .snippet :global(p) {
    margin: 0 0 10px;
  }

  .meta {
    margin: 0 0 12px;
    color: #5f7190;
    font-size: var(--type-body-small);
  }

  .shop-cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    height: 42px;
    padding: 0 18px;
    text-decoration: none;
    background: var(--shop-btn-color, #2d6fb3);
    color: #fff;
    font-size: var(--type-button);
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .shops-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .shops-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

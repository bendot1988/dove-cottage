---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("newsletters", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.issueDate.getTime() - a.data.issueDate.getTime()
);

const dateLabel = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
---

<BaseLayout title="Newsletter archive | Dove Cottage">
  <div class="motion-scope">
    <section class="nl-hero" aria-label="Newsletter archive">
      <img
        class="nl-hero-bg"
        src="/images/uploads/news/latest-news-featured.png"
        alt="Printed Dove Cottage newsletter copies on a wooden table"
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="nl-hero-overlay" aria-hidden="true"></div>
      <div class="container nl-hero-inner">
        <a class="interior-hero-eyebrow nl-hero-back" href="/news/">
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          News &amp; Events
        </a>
        <h1>Newsletter <span class="nl-hero-highlight">Archive</span></h1>
        <p class="nl-hero-dek">Download past issues of our newsletter (PDF).</p>
      </div>
    </section>

    <section class="nl-listing" aria-label="Past newsletters">
      <div class="container">
        {entries.length === 0 ? (
          <p class="nl-empty">No newsletters have been published yet.</p>
        ) : (
          <ul class="nl-grid">
            {entries.map((entry) => (
              <li class="nl-card">
                <h2 class="nl-card-title">{entry.data.title}</h2>
                <p class="nl-card-meta">
                  <time datetime={entry.data.issueDate.toISOString()}>{dateLabel(entry.data.issueDate)}</time>
                </p>
                {entry.data.excerpt && <p class="nl-card-excerpt">{entry.data.excerpt}</p>}
                <a class="nl-download" href={entry.data.file} download>
                  {entry.data.fileLabel}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </div>
  <script>
    import { initMotionScrollReveal } from "../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

<style>
  .nl-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: min(44vh, 380px);
    padding: clamp(2.5rem, 6vw, 3.25rem) 0 clamp(2rem, 5vw, 2.5rem);
    color: #fff;
    overflow: hidden;
  }

  .nl-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .nl-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(105deg, rgba(8, 22, 48, 0.88) 0%, rgba(8, 22, 48, 0.62) 42%, rgba(8, 22, 48, 0.35) 100%);
  }

  .nl-hero-inner {
    position: relative;
    z-index: 2;
    text-align: left;
  }

  .nl-hero-back.interior-hero-eyebrow {
    text-decoration: none;
  }

  .nl-hero h1 {
    margin: 0.5rem 0 0.65rem;
    font-size: var(--type-hero-title);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .nl-hero-highlight {
    color: var(--color-golden-yellow);
  }

  .nl-hero-dek {
    margin: 0;
    max-width: 40rem;
    font-size: var(--type-body-large);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.92);
  }

  .nl-listing {
    padding: clamp(2rem, 5vw, 3rem) 0 clamp(3rem, 8vw, 4.5rem);
    background: var(--color-alice-blue, #f4f7fc);
  }

  .nl-empty {
    margin: 0;
    font-size: var(--type-body);
    color: #2f3f5a;
  }

  .nl-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  @media (min-width: 768px) {
    .nl-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .nl-card {
    margin: 0;
    padding: 1.35rem 1.5rem 1.5rem;
    background: #fff;
    border: 1px solid #d9e3f0;
    border-radius: 14px;
    box-shadow: 0 6px 18px rgba(18, 44, 83, 0.06);
    display: flex;
    flex-direction: column;
    height: 100%;
    min-width: 0;
  }

  .nl-card-title {
    margin: 0 0 0.35rem;
    font-size: var(--type-card-title);
    font-weight: 800;
    color: #0f2240;
    text-align: center;
  }

  .nl-card-meta {
    margin: 0 0 0.75rem;
    font-size: var(--type-body-small);
    font-weight: 600;
    color: #5a6b85;
    text-align: center;
  }

  .nl-card-excerpt {
    margin: 0 0 1rem;
    font-size: var(--type-body);
    line-height: 1.55;
    color: #2f3f5a;
    text-align: center;
  }

  .nl-download {
    display: block;
    width: 100%;
    box-sizing: border-box;
    margin-top: auto;
    padding: 14px 18px;
    text-align: center;
    font-size: var(--type-body);
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    background: var(--color-steel-blue-1, #1d508d);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    transition:
      background 0.18s ease,
      box-shadow 0.18s ease;
  }

  .nl-download:hover,
  .nl-download:focus-visible {
    background: #163a66;
    box-shadow: 0 4px 14px rgba(16, 38, 72, 0.2);
  }

  .nl-download:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
  }
</style>

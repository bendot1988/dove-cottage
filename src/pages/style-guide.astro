---
import BaseLayout from "../layouts/BaseLayout.astro";
import { toTitleCase } from "../lib/titleCase";

const colorTokens = [
  { name: "text-primary", value: "#10233c", cssVar: "--text-primary", note: "Default body and headings" },
  { name: "golden-yellow", value: "#fedc06", cssVar: "--color-golden-yellow" },
  { name: "lavender", value: "#ebeef5", cssVar: "--color-lavender" },
  { name: "alice-blue", value: "#eaf1fb", cssVar: "--color-alice-blue" },
  { name: "old-lace", value: "#fffbe6", cssVar: "--color-old-lace" },
  { name: "ghost-white", value: "#f5f9ff", cssVar: "--color-ghost-white" },
  { name: "white", value: "#ffffff", cssVar: "--color-white" },
  { name: "teal", value: "#1d508d", cssVar: "--color-teal" },
  { name: "steel-blue", value: "#2751a0", cssVar: "--color-steel-blue" },
  { name: "steel-blue-1", value: "#1d65b2", cssVar: "--color-steel-blue-1" },
  { name: "steel-blue-2", value: "#2c6eb4", cssVar: "--color-steel-blue-2" },
  { name: "dark-orchid", value: "#6b3fa0", cssVar: "--color-dark-orchid" },
  { name: "dark-slate-gray", value: "#2e7d4f", cssVar: "--color-dark-slate-gray" },
  { name: "fire-brick", value: "#c05e1a", cssVar: "--color-fire-brick" }
];

const typeTokens = [
  "--type-hero-title",
  "--type-section-title",
  "--type-card-title",
  "--type-subtitle",
  "--type-body-large",
  "--type-body",
  "--type-body-small",
  "--type-micro",
  "--type-nav",
  "--type-button",
  "--type-button-small"
];

const radiusRows = [
  { px: "6px", use: "Default `.btn` corners" },
  { px: "8px", use: "Swatch chips, small UI" },
  { px: "10px", use: "Inline samples, type rows" },
  { px: "12px", use: "Motion demo, soft cards" },
  { px: "14px", use: "Style guide panels" },
  { px: "16px", use: "Homepage service cards" },
  { px: "999px", use: "Pills, tags, primary CTAs, hero row buttons" }
];

const titleCaseExample = toTitleCase("we'd love to hear from you");
---

<BaseLayout title="Style guide | Dove Cottage" noindex={true}>
  <section class="style-guide" aria-label="Dove Cottage design system">
    <div class="container">
      <header class="guide-header">
        <p class="guide-eyebrow">Internal — not indexed</p>
        <h1>Style guide</h1>
        <p>
          This page documents tokens and patterns aligned with the <strong>homepage</strong> so
          new sections stay visually consistent. It is <strong>excluded from search</strong> via
          <code>noindex, nofollow</code> in <code>BaseLayout</code> (<code>/style-guide/</code>).
        </p>
      </header>

      <section class="panel" aria-labelledby="sg-colors">
        <h2 id="sg-colors">Brand colors</h2>
        <p class="panel-lede">Defined in <code>src/styles/global.css</code> on <code>:root</code>. Prefer CSS variables, not one-off hex, except where a component bakes a specific value (e.g. hero buttons).</p>
        <div class="swatches">
          {
            colorTokens.map((color) => (
              <article class="swatch">
                <div class="swatch-chip" style={`background:${color.value};`}></div>
                <h3>{color.name}</h3>
                <p>{color.value}</p>
                <small>{color.cssVar}</small>
                {"note" in color && color.note && <small class="swatch-note">{color.note}</small>}
              </article>
            ))
          }
        </div>
      </section>

      <section class="panel" aria-labelledby="sg-titles">
        <h2 id="sg-titles">Typography &amp; title hierarchy</h2>
        <p class="panel-lede">
          Font family sitewide: <strong>Montserrat</strong> (see <code>global.css</code>).
          Homepage section titles and hero copy use the tokens below; long headings use
          <strong>title case in content</strong> (major words capitalised, small words like “and”
          lowercased in the middle), matching the homepage JSON style.
        </p>

        <h3 class="sg-subh">Level map</h3>
        <ul class="sg-list">
          <li>
            <strong>Hero (H1)</strong> — <code>--type-hero-title</code>, weight 700, tight letter-spacing
            (<code>-0.03em</code> in <code>HeroSection.astro</code>).
          </li>
          <li>
            <strong>Page / section (H2)</strong> — <code>--type-section-title</code>, for primary section
            titles on coloured or white bands.
          </li>
          <li>
            <strong>Card / block (H3)</strong> — <code>--type-card-title</code> or the care-card clamp
            in <code>CareServicesSection.astro</code>.
          </li>
          <li>
            <strong>Eyebrow / kicker</strong> — <code>--type-micro</code>, <strong>uppercase</strong>, wide
            letter-spacing (<code>0.1em</code>–<code>0.12em</code>), often steel-blue, as on the shops
            section.
          </li>
        </ul>

        <div class="sg-demo-hero" role="img" aria-label="Hero title sample">
          <h2 class="sg-demo-hero-title">Supporting You Through Every Step of Your Journey</h2>
          <p class="sg-demo-hero-body">
            We provide free, compassionate care for local families. Body large on a dark overlay
            uses <code>--type-body-large</code>.
          </p>
        </div>

        <div class="sg-demo-section">
          <p class="sg-demo-eyebrow">Supporting our community</p>
          <h2 class="sg-demo-h2">Our Local Charity Shops</h2>
          <p class="sg-demo-intro">
            Intro and lede: <code>--type-body-large</code>, line-height ~1.55–1.6, colour around
            <code>#364861</code> / <code>#495d78</code> for secondary text.
          </p>
        </div>
      </section>

      <section class="panel" aria-labelledby="sg-radius">
        <h2 id="sg-radius">Border radius</h2>
        <p class="panel-lede">
          No single global token: components pick radii for purpose. Pills and tags use
          <code>999px</code>; cards and panels cluster at <code>12–16px</code>.
        </p>
        <div class="radius-table" role="table" aria-label="Border radius uses">
          <div class="radius-row radius-row-head" role="row">
            <span role="columnheader">Radius</span>
            <span role="columnheader">Typical use</span>
          </div>
          {radiusRows.map((r) => (
            <div class="radius-row" role="row">
              <code role="cell">{r.px}</code>
              <span role="cell">{r.use}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="panel" aria-labelledby="sg-surfaces">
        <h2 id="sg-surfaces">Surfaces, borders &amp; depth</h2>
        <p class="panel-lede">Common patterns from the homepage and inner pages.</p>
        <ul class="sg-list">
          <li>
            <strong>Section background</strong> — <code>--color-lavender</code> for alternating bands;
            white for contrast sections (e.g. shops).
          </li>
          <li>
            <strong>Card border</strong> — <code>1px</code> solid e.g. <code>#d9e3f0</code>,
            <code>#dce5f2</code>, or <code>#e5ebf5</code>.
          </li>
          <li>
            <strong>Card shadow (service cards)</strong> —
            <code>0 6px 16px rgba(19, 47, 82, 0.08)</code>.
          </li>
        </ul>
        <div class="sg-surface-bar sg-surface-lavender">Lavender section</div>
        <div class="sg-surface-bar sg-surface-white">White panel with border + shadow (see cards)</div>
      </section>

      <section class="panel" aria-labelledby="sg-layout">
        <h2 id="sg-layout">Layout &amp; container</h2>
        <p class="panel-lede">
          Homepage sections use a centred container <code>width: min(1200px, 95%)</code> with
          <code>margin: 0 auto</code>. Some inner pages (e.g. contact) add horizontal padding:
          <code>clamp(1.125rem, 4.2vw, 1.5rem)</code> on the same max-width shell.
        </p>
        <p class="panel-lede">This guide uses the same <code>min(1200px, 95%)</code> pattern.</p>
      </section>

      <section class="panel" aria-labelledby="sg-tags">
        <h2 id="sg-tags">Service tags (care cards)</h2>
        <p class="panel-lede">Pill tags on the homepage care grid (<code>CareServicesSection.astro</code>).</p>
        <div class="sg-tags">
          <span class="sg-tag sg-tag-blue">Tue–Thu | 10am–3pm</span>
          <span class="sg-tag sg-tag-green">Mondays | 10am–1pm</span>
          <span class="sg-tag sg-tag-orange">Dementia Support</span>
          <span class="sg-tag sg-tag-purple">Counselling</span>
        </div>
      </section>

      <section class="panel" aria-labelledby="sg-titles-utility">
        <h2 id="sg-titles-utility">Title case helper (optional)</h2>
        <p class="panel-lede">
          For a few pages, headings are normalised with <code>toTitleCase</code> in
          <code>src/lib/titleCase.ts</code> (AP-style, small words mid-phrase). Use only for
          <strong>short labels and headings</strong>, not for body copy.
        </p>
        <p class="sg-code-line">
          <code>we'd love to hear from you</code> → <strong>{titleCaseExample}</strong>
        </p>
      </section>

      <section class="panel">
        <h2>Typography scale (tokens)</h2>
        <p class="panel-lede">Sample line in each size.</p>
        <div class="type-list">
          {
            typeTokens.map((token) => (
              <div class="type-row">
                <span class="token">{token}</span>
                <p style={`font-size:var(${token});`}>The quick brown fox jumps over the lazy dog.</p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="panel">
        <h2>Buttons</h2>
        <div class="button-row">
          <button class="btn btn-primary" type="button">Primary Action</button>
          <button class="btn btn-secondary" type="button">Secondary Action</button>
          <button class="btn btn-ghost" type="button">Ghost Action</button>
          <button class="btn btn-primary btn-shine" type="button">Donate CTA (Shine)</button>
        </div>
        <p class="button-note">
          Base <code>.btn</code> uses <code>border-radius: 6px</code> in <code>src/styles/_buttons.css</code>.
          Reserve <code>.btn-shine</code> for main donation-style CTAs.
        </p>
        <p class="button-note">
          Brand note: homepage Day Care cards use <strong>simple text-style buttons with a yellow underline</strong>
          (see <code>.card-link</code> / <code>.card-link-text</code> pattern below).
        </p>
      </section>

      <section class="panel" aria-labelledby="sg-card-link">
        <h2 id="sg-card-link">Card link (“Find out more”)</h2>
        <p class="panel-lede">
          Homepage care cards (<code>CareServicesSection.astro</code>) use a text-style CTA: bold
          <code>--color-steel-blue</code>, with a <strong>yellow bar</strong> on the label only
          (<code>::after</code> on <code>.card-link-text</code>), and the
          <strong>arrow</strong> outside that underline. The bar animates in on
          <code>:hover</code> and <code>:focus-visible</code>.
        </p>
        <article class="sg-service-card">
          <div class="sg-service-card__content">
            <h3 class="sg-service-card__title">Day Care</h3>
            <p class="sg-service-card__desc">
              Expert nursing support in a home-from-home environment, matching real card copy length.
            </p>
            <a href="#sg-card-link" class="card-link">
              <span class="card-link-text">Find Out More</span>
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
        <p class="button-note">
          Copy the same structure: <code>class="card-link"</code> on the
          <code>&lt;a&gt;</code>, <code>class="card-link-text"</code> on the text span, then the
          arrow in a second span so the yellow rule never sits under the arrow.
        </p>
      </section>

      <section class="panel">
        <h2>Spacing rhythm (reference steps)</h2>
        <div class="spacing-row">
          <div class="space space-8">8</div>
          <div class="space space-12">12</div>
          <div class="space space-16">16</div>
          <div class="space space-24">24</div>
          <div class="space space-32">32</div>
          <div class="space space-48">48</div>
        </div>
        <p class="button-note">Use as a common scale, not hard tokens — pair with section padding (e.g. <code>clamp(3.75rem, 9vw, 6rem)</code> on homepage sections).</p>
      </section>

      <section class="panel motion-guide">
        <h2>Motion &amp; animation</h2>
        <p class="motion-lead">
          Motion is calm and supportive: short fades with a soft ease-out, modest vertical travel, and
          no autoplaying distractions. Always respect <code>prefers-reduced-motion</code> (handled in
          CSS and in the scroll script).
        </p>

        <h3 class="motion-sub">Design tokens</h3>
        <p class="motion-note">
          Defined on <code>:root</code> in <code>src/styles/global.css</code>. Use these when adding
          new animations so timing stays consistent.
        </p>
        <div class="motion-token-table" role="table" aria-label="Motion tokens">
          <div class="motion-token-row motion-token-head" role="row">
            <span role="columnheader">Token</span>
            <span role="columnheader">Role</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-ease-out</code>
            <span role="cell">Primary easing for entrances (cubic-bezier)</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-duration-reveal</code>
            <span role="cell">Section scroll reveal (opacity + transform)</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-duration-stagger</code>
            <span role="cell">Card / grid item fade-up after section is visible</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-duration-hero</code>
            <span role="cell">Hero headline / body / CTA row (<code>HeroSection.astro</code>)</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-duration-video</code>
            <span role="cell">Video embed emphasis when its section appears</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-distance</code>
            <span role="cell">Vertical shift for scroll reveals and <code>motion-fade-up</code></span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-distance-hero</code>
            <span role="cell">Hero line stagger distance</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-stagger-step</code>
            <span role="cell">Delay step between grid columns (multiples used for nth-child)</span>
          </div>
        </div>

        <h3 class="motion-sub">Scroll reveal (site-wide)</h3>
        <ol class="motion-steps">
          <li>
            Wrap the page content that should participate in motion with
            <code>class="motion-scope"</code> (the homepage also uses <code>page-home</code> for any
            legacy hooks).
          </li>
          <li>
            Use normal <code>&lt;section&gt;</code> blocks. These are excluded from scroll reveal so
            the hero can use its own treatment:
            <code>.hero-section</code>, <code>.contact-hero</code>, <code>.donate-hero</code>,
            <code>.shop-hero</code>, <code>.hospice-svc-hero</code>, <code>.archive-hero</code>.
          </li>
          <li>
            Import and call <code>initMotionScrollReveal()</code> from
            <code>src/scripts/motion-scroll-reveal.ts</code> (optional selector; default
            <code>".motion-scope"</code>).
          </li>
          <li>
            Use the same grid class names as the homepage for staggered children:
            <code>.cards-grid</code>, <code>.impact-grid</code>, <code>.featured-grid</code>, plus
            <code>.reach-grid &gt; .main-card</code> and <code>.side-stack &gt; .side-card</code>, and
            <code>.video-frame</code> for video blocks.
          </li>
        </ol>

        <pre class="code-block" tabindex="0"><code>&lt;div class="motion-scope"&gt;
  &lt;HeroSection /&gt; &lt;!-- .hero-section: not observed --&gt;
  &lt;section&gt;…&lt;/section&gt;
&lt;/div&gt;
&lt;script&gt;
  import &#123; initMotionScrollReveal &#125; from "../scripts/motion-scroll-reveal.ts";
  initMotionScrollReveal();
&lt;/script&gt;</code></pre>

        <h3 class="motion-sub">Hero stagger</h3>
        <p class="motion-note">
          Apply <code>class="hero-animate"</code> to the hero title, supporting copy, and CTA row in
          <code>HeroSection.astro</code>. Keyframes use <code>--motion-duration-hero</code>,
          <code>--motion-ease-out</code>, and <code>--motion-distance-hero</code>.
        </p>

        <h3 class="motion-sub">Live example (scroll reveal)</h3>
        <p class="motion-note">
          Scroll this panel: sections below use the same classes as the homepage. A second section
          includes a <code>.cards-grid</code> to show stagger.
        </p>

        <div class="motion-demo motion-scope">
          <section class="motion-demo-block">
            <h4 class="motion-demo-title">Sample section A</h4>
            <p class="motion-demo-copy">
              This block uses <code>reveal-on-scroll</code> and <code>is-visible</code> once it
              enters the viewport.
            </p>
          </section>
          <section class="motion-demo-block">
            <h4 class="motion-demo-title">Sample section B (grid stagger)</h4>
            <div class="cards-grid motion-demo-cards">
              <article class="motion-demo-card">Card one</article>
              <article class="motion-demo-card">Card two</article>
              <article class="motion-demo-card">Card three</article>
            </div>
          </section>
        </div>
      </section>
    </div>
  </section>

  <script>
    import { initMotionScrollReveal } from "../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal(".motion-demo");
  </script>
</BaseLayout>

<style>
  .style-guide {
    background: var(--color-lavender);
    min-height: 100vh;
    padding: 42px 0 70px;
  }

  .guide-eyebrow {
    margin: 0 0 8px;
    font-size: var(--type-micro);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-steel-blue-1);
  }

  .guide-header h1 {
    margin: 0;
    font-size: var(--type-section-title);
    color: var(--text-primary, #10233c);
  }

  .guide-header p {
    margin: 10px 0 0;
    font-size: var(--type-body-large);
    color: #364861;
    max-width: 72ch;
    line-height: 1.55;
  }

  .panel {
    background: #fff;
    border: 1px solid #dce5f2;
    border-radius: 14px;
    margin-top: 22px;
    padding: 20px 22px 22px;
  }

  .panel h2 {
    margin: 0 0 8px;
    font-size: var(--type-card-title);
    color: var(--text-primary, #10233c);
  }

  .panel-lede {
    margin: 0 0 16px;
    font-size: var(--type-body);
    line-height: 1.55;
    color: #3f5370;
  }

  .panel-lede:last-of-type {
    margin-bottom: 0;
  }

  .sg-subh {
    margin: 20px 0 10px;
    font-size: var(--type-subtitle);
    color: #10243d;
  }

  .sg-list {
    margin: 0 0 16px;
    padding-left: 1.2rem;
    color: #334862;
    font-size: var(--type-body);
    line-height: 1.6;
  }

  .sg-list li {
    margin-bottom: 8px;
  }

  .sg-demo-hero {
    border-radius: 12px;
    padding: 28px 24px;
    background: linear-gradient(105deg, rgba(16, 34, 58, 0.92) 0%, rgba(16, 34, 58, 0.75) 100%);
    color: #fff;
    margin-top: 16px;
  }

  .sg-demo-hero-title {
    margin: 0;
    font-size: var(--type-hero-title);
    line-height: 1.2;
    letter-spacing: -0.03em;
    font-weight: 700;
  }

  .sg-demo-hero-body {
    margin: 12px 0 0;
    font-size: var(--type-body-large);
    line-height: 1.6;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.95);
  }

  .sg-demo-section {
    margin-top: 20px;
    padding: 20px 0 0;
    border-top: 1px solid #e2e8f2;
  }

  .sg-demo-eyebrow {
    margin: 0 0 6px;
    font-size: var(--type-micro);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-steel-blue-1);
  }

  .sg-demo-h2 {
    margin: 0 0 10px;
    font-size: var(--type-section-title);
    line-height: 1.2;
    color: #0f2240;
  }

  .sg-demo-intro {
    margin: 0;
    font-size: var(--type-body-large);
    line-height: 1.55;
    color: #364861;
  }

  .radius-table {
    border: 1px solid #e7edf7;
    border-radius: 10px;
    overflow: hidden;
    font-size: var(--type-body-small);
  }

  .radius-row {
    display: grid;
    grid-template-columns: minmax(0, 0.4fr) minmax(0, 1.6fr);
    gap: 10px;
    padding: 10px 12px;
    border-top: 1px solid #eef3fa;
    align-items: start;
  }

  .radius-row:first-child {
    border-top: none;
  }

  .radius-row-head {
    background: #f5f8fd;
    font-weight: 700;
    color: #10243d;
    font-size: var(--type-micro);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .radius-row code {
    font-size: 0.9rem;
  }

  .sg-surface-bar {
    margin-top: 10px;
    padding: 16px 18px;
    border-radius: 12px;
    font-size: var(--type-body-small);
    font-weight: 600;
  }

  .sg-surface-lavender {
    background: var(--color-lavender);
    color: #1e3a5f;
  }

  .sg-surface-white {
    background: #fff;
    color: #334862;
    border: 1px solid #d9e3f0;
    box-shadow: 0 6px 16px rgba(19, 47, 82, 0.08);
  }

  .sg-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .sg-tag {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    border-radius: 999px;
    padding: 5px 14px;
    font-size: var(--type-micro);
    line-height: 1;
    font-weight: 700;
    color: #fff;
  }

  .sg-tag-blue {
    background: #2d6fb3;
  }

  .sg-tag-green {
    background: var(--color-dark-slate-gray);
  }

  .sg-tag-orange {
    background: var(--color-fire-brick);
  }

  .sg-tag-purple {
    background: var(--color-dark-orchid);
  }

  .sg-code-line {
    margin: 0;
    font-size: var(--type-body);
    color: #10243d;
  }

  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(165px, 1fr));
    gap: 14px;
  }

  .swatch {
    border: 1px solid #e5ebf5;
    border-radius: 10px;
    padding: 10px;
    background: #fbfdff;
  }

  .swatch-chip {
    height: 70px;
    border-radius: 8px;
    border: 1px solid rgba(15, 30, 48, 0.09);
  }

  .swatch h3 {
    margin: 10px 0 4px;
    font-size: var(--type-body);
  }

  .swatch p,
  .swatch small {
    margin: 0;

---
import BaseLayout from "../layouts/BaseLayout.astro";

const colorTokens = [
  { name: "golden-yellow", value: "#fedc06", cssVar: "--color-golden-yellow" },
  { name: "lavender", value: "#ebeef5", cssVar: "--color-lavender" },
  { name: "alice-blue", value: "#eaf1fb", cssVar: "--color-alice-blue" },
  { name: "old-lace", value: "#fffbe6", cssVar: "--color-old-lace" },
  { name: "ghost-white", value: "#f5f9ff", cssVar: "--color-ghost-white" },
  { name: "white", value: "#ffffff", cssVar: "--color-white" },
  { name: "teal", value: "#1d508d", cssVar: "--color-teal" },
  { name: "steel-blue", value: "#2751a0", cssVar: "--color-steel-blue" },
  { name: "steel-blue-1", value: "#1d65b2", cssVar: "--color-steel-blue-1" },
  { name: "steel-blue-2", value: "#2c6eb4", cssVar: "--color-steel-blue-2" },
  { name: "dark-orchid", value: "#6b3fa0", cssVar: "--color-dark-orchid" },
  { name: "dark-slate-gray", value: "#2e7d4f", cssVar: "--color-dark-slate-gray" },
  { name: "fire-brick", value: "#c05e1a", cssVar: "--color-fire-brick" }
];

const typeTokens = [
  "--type-hero-title",
  "--type-section-title",
  "--type-card-title",
  "--type-subtitle",
  "--type-body-large",
  "--type-body",
  "--type-body-small",
  "--type-micro",
  "--type-nav",
  "--type-button",
  "--type-button-small"
];
---

<BaseLayout title="Style Guide | Dove Cottage" noindex={true}>
  <section class="style-guide">
    <div class="container">
      <header class="guide-header">
        <h1>Dove Cottage Style Guide</h1>
        <p>
          Reference for global tokens, typography scale, button styles, spacing rhythm, and motion so
          the same patterns can be reused across the site.
        </p>
      </header>

      <section class="panel">
        <h2>Brand Colors</h2>
        <div class="swatches">
          {
            colorTokens.map((color) => (
              <article class="swatch">
                <div class="swatch-chip" style={`background:${color.value};`}></div>
                <h3>{color.name}</h3>
                <p>{color.value}</p>
                <small>{color.cssVar}</small>
              </article>
            ))
          }
        </div>
      </section>

      <section class="panel">
        <h2>Typography Scale</h2>
        <div class="type-list">
          {
            typeTokens.map((token) => (
              <div class="type-row">
                <span class="token">{token}</span>
                <p style={`font-size:var(${token});`}>The quick brown fox jumps over the lazy dog.</p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="panel">
        <h2>Buttons</h2>
        <div class="button-row">
          <button class="btn btn-primary" type="button">Primary Action</button>
          <button class="btn btn-secondary" type="button">Secondary Action</button>
          <button class="btn btn-ghost" type="button">Ghost Action</button>
          <button class="btn btn-primary btn-shine" type="button">Donate CTA (Shine)</button>
        </div>
        <p class="button-note">
          Use <code>.btn-shine</code> only on main donation CTAs to create a soft, repeating light
          sweep that draws attention.
        </p>
      </section>

      <section class="panel">
        <h2>Spacing Rhythm</h2>
        <div class="spacing-row">
          <div class="space space-8">8</div>
          <div class="space space-12">12</div>
          <div class="space space-16">16</div>
          <div class="space space-24">24</div>
          <div class="space space-32">32</div>
          <div class="space space-48">48</div>
        </div>
      </section>

      <section class="panel motion-guide">
        <h2>Motion &amp; animation</h2>
        <p class="motion-lead">
          Motion is calm and supportive: short fades with a soft ease-out, modest vertical travel, and
          no autoplaying distractions. Always respect <code>prefers-reduced-motion</code> (handled in
          CSS and in the scroll script).
        </p>

        <h3 class="motion-sub">Design tokens</h3>
        <p class="motion-note">
          Defined on <code>:root</code> in <code>src/styles/global.css</code>. Use these when adding
          new animations so timing stays consistent.
        </p>
        <div class="motion-token-table" role="table" aria-label="Motion tokens">
          <div class="motion-token-row motion-token-head" role="row">
            <span role="columnheader">Token</span>
            <span role="columnheader">Role</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-ease-out</code>
            <span role="cell">Primary easing for entrances (cubic-bezier)</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-duration-reveal</code>
            <span role="cell">Section scroll reveal (opacity + transform)</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-duration-stagger</code>
            <span role="cell">Card / grid item fade-up after section is visible</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-duration-hero</code>
            <span role="cell">Hero headline / body / CTA row (see <code>HeroSection.astro</code>)</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-duration-video</code>
            <span role="cell">Video embed emphasis when its section appears</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-distance</code>
            <span role="cell">Vertical shift for scroll reveals and <code>motion-fade-up</code></span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-distance-hero</code>
            <span role="cell">Hero line stagger distance</span>
          </div>
          <div class="motion-token-row" role="row">
            <code role="cell">--motion-stagger-step</code>
            <span role="cell">Delay step between grid columns (multiples used for nth-child)</span>
          </div>
        </div>

        <h3 class="motion-sub">Scroll reveal (site-wide)</h3>
        <ol class="motion-steps">
          <li>
            Wrap the page content that should participate in motion with
            <code>class="motion-scope"</code> (the homepage also uses <code>page-home</code> for any
            legacy hooks).
          </li>
          <li>
            Use normal <code>&lt;section&gt;</code> blocks. Sections named with
            <code>.hero-section</code> are excluded from scroll reveal so the hero can use its own
            entrance animation.
          </li>
          <li>
            Import and call <code>initMotionScrollReveal()</code> from
            <code>src/scripts/motion-scroll-reveal.ts</code> (optional selector; default
            <code>".motion-scope"</code>).
          </li>
          <li>
            Use the same grid class names as the homepage for staggered children:
            <code>.cards-grid</code>, <code>.impact-grid</code>, <code>.featured-grid</code>, plus
            <code>.reach-grid &gt; .main-card</code> and <code>.side-stack &gt; .side-card</code>, and
            <code>.video-frame</code> for video blocks.
          </li>
        </ol>

        <pre class="code-block" tabindex="0"><code>&lt;div class="motion-scope"&gt;
  &lt;HeroSection /&gt; &lt;!-- .hero-section: not observed --&gt;
  &lt;section&gt;…&lt;/section&gt;
&lt;/div&gt;
&lt;script&gt;
  import &#123; initMotionScrollReveal &#125; from "../scripts/motion-scroll-reveal.ts";
  initMotionScrollReveal();
&lt;/script&gt;</code></pre>

        <h3 class="motion-sub">Hero stagger</h3>
        <p class="motion-note">
          Apply <code>class="hero-animate"</code> to the hero title, supporting copy, and CTA row in
          <code>HeroSection.astro</code>. Keyframes use <code>--motion-duration-hero</code>,
          <code>--motion-ease-out</code>, and <code>--motion-distance-hero</code>.
        </p>

        <h3 class="motion-sub">Live example (scroll reveal)</h3>
        <p class="motion-note">
          Scroll this panel: sections below use the same classes as the homepage. A second section
          includes a <code>.cards-grid</code> to show stagger.
        </p>

        <div class="motion-demo motion-scope">
          <section class="motion-demo-block">
            <h4 class="motion-demo-title">Sample section A</h4>
            <p class="motion-demo-copy">
              This block uses <code>reveal-on-scroll</code> and <code>is-visible</code> once it
              enters the viewport.
            </p>
          </section>
          <section class="motion-demo-block">
            <h4 class="motion-demo-title">Sample section B (grid stagger)</h4>
            <div class="cards-grid motion-demo-cards">
              <article class="motion-demo-card">Card one</article>
              <article class="motion-demo-card">Card two</article>
              <article class="motion-demo-card">Card three</article>
            </div>
          </section>
        </div>
      </section>
    </div>
  </section>

  <script>
    import { initMotionScrollReveal } from "../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal(".motion-demo");
  </script>
</BaseLayout>

<style>
  .style-guide {
    background: var(--color-lavender);
    min-height: 100vh;
    padding: 42px 0 70px;
  }

  .container {
    width: min(1200px, 95%);
    margin: 0 auto;
  }

  .guide-header h1 {
    margin: 0;
    font-size: var(--type-section-title);
    color: var(--color-steel-blue);
  }

  .guide-header p {
    margin: 10px 0 0;
    font-size: var(--type-body-large);
    color: #334862;
  }

  .panel {
    background: #fff;
    border: 1px solid #dce5f2;
    border-radius: 14px;
    margin-top: 22px;
    padding: 20px;
  }

  .panel h2 {
    margin: 0 0 14px;
    font-size: var(--type-card-title);
    color: #10243d;
  }

  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(165px, 1fr));
    gap: 14px;
  }

  .swatch {
    border: 1px solid #e5ebf5;
    border-radius: 10px;
    padding: 10px;
    background: #fbfdff;
  }

  .swatch-chip {
    height: 70px;
    border-radius: 8px;
    border: 1px solid rgba(15, 30, 48, 0.09);
  }

  .swatch h3 {
    margin: 10px 0 4px;
    font-size: var(--type-body);
  }

  .swatch p,
  .swatch small {
    margin: 0;
    display: block;
    color: #4a5e78;
    font-size: var(--type-body-small);
    line-height: 1.45;
  }

  .type-list {
    display: grid;
    gap: 12px;
  }

  .type-row {
    border: 1px solid #e7edf7;
    border-radius: 10px;
    padding: 10px 12px;
  }

  .token {
    display: block;
    font-size: var(--type-micro);
    color: #48617e;
    margin-bottom: 6px;
  }

  .type-row p {
    margin: 0;
    color: #132746;
    line-height: 1.35;
    font-weight: 600;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button-row .btn {
    border-radius: 999px;
  }

  .button-note {
    margin: 12px 0 0;
    color: #4a5e78;
    font-size: var(--type-body-small);
  }

  .spacing-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 10px;
  }

  .space {
    width: 56px;
    background: var(--color-steel-blue-1);
    color: #fff;
    border-radius: 8px 8px 0 0;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    padding-bottom: 5px;
    font-size: var(--type-micro);
    font-weight: 700;
  }

  .space-8 {
    height: 24px;
  }
  .space-12 {
    height: 30px;
  }
  .space-16 {
    height: 36px;
  }
  .space-24 {
    height: 44px;
  }
  .space-32 {
    height: 52px;
  }
  .space-48 {
    height: 68px;
  }

  .motion-guide .motion-lead {
    margin: 0 0 16px;
    color: #334862;
    font-size: var(--type-body-large);
    line-height: 1.55;
  }

  .motion-guide .motion-lead code {
    font-size: 0.92em;
  }

  .motion-sub {
    margin: 22px 0 8px;
    font-size: var(--type-subtitle);
    color: #10243d;
    font-weight: 700;
  }

  .motion-sub:first-of-type {
    margin-top: 0;
  }

  .motion-note {
    margin: 0 0 12px;
    color: #4a5e78;
    font-size: var(--type-body-small);
    line-height: 1.5;
  }

  .motion-token-table {
    border: 1px solid #e7edf7;
    border-radius: 10px;
    overflow: hidden;
    font-size: var(--type-body-small);
  }

  .motion-token-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: 10px;
    padding: 10px 12px;
    border-top: 1px solid #eef3fa;
    align-items: start;
  }

  .motion-token-row:first-child {
    border-top: none;
  }

  .motion-token-head {
    background: #f5f8fd;
    font-weight: 700;
    color: #10243d;
    font-size: var(--type-micro);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .motion-token-row code {
    font-size: 0.88rem;
    word-break: break-word;
  }

  .motion-steps {
    margin: 0 0 16px;
    padding-left: 1.2rem;
    color: #334862;
    font-size: var(--type-body);
    line-height: 1.55;
  }

  .motion-steps li {
    margin-bottom: 8px;
  }

  .motion-steps code {
    font-size: 0.9em;
  }

  .code-block {
    margin: 0 0 18px;
    padding: 14px 16px;
    background: #0f1f33;
    color: #e8f0ff;
    border-radius: 10px;
    font-size: var(--type-body-small);
    line-height: 1.5;
    overflow-x: auto;
  }

  .code-block code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .motion-demo {
    margin-top: 12px;
    padding: 18px;
    background: var(--color-lavender);
    border-radius: 12px;
    border: 1px dashed #c5d4eb;
  }

  .motion-demo-block {
    background: #fff;
    border-radius: 12px;
    padding: 16px 18px;
    margin-bottom: 14px;
    border: 1px solid #e5ebf5;
  }

  .motion-demo-block:last-child {
    margin-bottom: 0;
  }

  .motion-demo-title {
    margin: 0 0 8px;
    font-size: var(--type-body);
    color: var(--color-steel-blue);
  }

  .motion-demo-copy {
    margin: 0;
    color: #4a5e78;
    font-size: var(--type-body-small);
    line-height: 1.5;
  }

  .motion-demo-cards {
    margin-top: 12px;
  }

  .motion-demo-card {
    margin: 0;
    padding: 14px;
    background: #fbfdff;
    border: 1px solid #e5ebf5;
    border-radius: 10px;
    font-size: var(--type-body-small);
    font-weight: 600;
    color: #132746;
  }
</style>

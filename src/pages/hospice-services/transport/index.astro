---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import SubpageReviewCarousel from "../../../components/SubpageReviewCarousel.astro";
import fallbackData from "../../../data/transport.json";
import fallbackContact from "../../../data/contact.json";
import { resolveSanityImageUrl, sanityClient } from "../../../lib/sanity";
import { fetchSingletonPageJson } from "../../../lib/sanitySingleton";
import { toTitleCase } from "../../../lib/titleCase";

const structuredData = await sanityClient.fetch(`
  *[_type == "transportPage"][0]{
    pageTitle,
    heroImage,
    heroImageAlt,
    parentNavLabel,
    parentNavHref,
    heroH1,
    heroShortDescription,
    mainIntro1,
    mainIntro2,
    sectionImage1,
    serviceHeading,
    serviceBody,
    additionalHeading,
    additionalIntro,
    additionalServices,
    referralIntro,
    referralCta,
    referralCtaHref,
    referralOutro,
    sideFormLinkText,
    sideFormHint
  }
`);
const singletonData = (await fetchSingletonPageJson<typeof fallbackData>("transport")) ?? null;

const normalizeSectionImage = (value: unknown, fallbackSrc: string, fallbackAlt: string) => {
  if (!value) return { src: fallbackSrc, alt: fallbackAlt };
  if (typeof value === "object" && value !== null && "src" in value) {
    const typed = value as { src?: unknown; alt?: unknown };
    return {
      src: typeof typed.src === "string" && typed.src ? typed.src : fallbackSrc,
      alt: typeof typed.alt === "string" && typed.alt ? typed.alt : fallbackAlt,
    };
  }
  const typed = value as { image?: unknown; alt?: unknown };
  return {
    src: resolveSanityImageUrl(typed.image, fallbackSrc),
    alt: typeof typed.alt === "string" && typed.alt ? typed.alt : fallbackAlt,
  };
};

const mergeTransportForSite = (
  structured: typeof structuredData,
  singleton: typeof singletonData,
  fallback: typeof fallbackData
) => {
  const source = structured ?? singleton;
  if (!source) return fallback;
  return {
    ...fallback,
    ...source,
    heroImage: resolveSanityImageUrl(source.heroImage, fallback.heroImage),
    additionalServices: source.additionalServices ?? fallback.additionalServices,
    sectionImage1: normalizeSectionImage(
      source.sectionImage1,
      fallback.sectionImage1.src,
      fallback.sectionImage1.alt
    ),
  };
};

const p = mergeTransportForSite(structuredData, singletonData, fallbackData);
const c = (await fetchSingletonPageJson<typeof fallbackContact>("contact")) ?? fallbackContact;
const telHref = `tel:${c.trustPhone.replace(/\s+/g, "")}`;

const layoutTitle = p.pageTitle
  .split(/\s*\|\s*/)
  .map((part) => toTitleCase(part.trim()))
  .join(" | ");

const parentLabel = p.parentNavLabel;
const asideTitle = toTitleCase("Get in touch");
const phoneLabel = toTitleCase("Phone");
const formLabel = toTitleCase("Enquiry");
---

<BaseLayout title={layoutTitle}>
  <div class="svc-page">
    <section class="hospice-svc-hero" aria-label={p.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={p.heroImage}
        alt={p.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={p.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {parentLabel}
        </a>
        <h1>{p.heroH1}</h1>
        <p class="hospice-svc-hero-dek">{p.heroShortDescription}</p>
      </div>
    </section>

    <div class="motion-scope">
      <SubpageReviewCarousel />

      <section class="svc-main" aria-label={p.heroH1}>
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            <p class="svc-lede">{p.mainIntro1}</p>
            <p class="svc-lede">{p.mainIntro2}</p>

            {
              p.sectionImage1?.src && (
                <figure class="svc-figure">
                  <img
                    class="svc-figure__img"
                    src={p.sectionImage1.src}
                    alt={p.sectionImage1.alt}
                    width="1200"
                    height="675"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              )
            }

            <div class="svc-card" role="group" aria-labelledby="transport-heading">
              <h2 class="svc-card__title" id="transport-heading">
                {p.serviceHeading}
              </h2>
              <p class="svc-body">{p.serviceBody}</p>
            </div>

            <div class="svc-card svc-card--tight" role="group" aria-labelledby="additional-heading">
              <h2 class="svc-card__title" id="additional-heading">
                {p.additionalHeading}
              </h2>
              <p class="svc-body">{p.additionalIntro}</p>
              <ul class="svc-list">
                {p.additionalServices.map((item) => (
                  <li>
                    <a class="transport-service-link" href={item.href}>
                      <span class="transport-service-link__text">{item.label}</span>
                      <span aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <p class="svc-body">
              {p.referralIntro}{" "}
              <a class="svc-inline-link" href={p.referralCtaHref}>
                {p.referralCta}
              </a>{" "}
              {p.referralOutro}
            </p>
          </div>

          <aside class="svc-side" aria-label={asideTitle}>
            <div class="side-card">
              <h2 class="side-card-title">{asideTitle}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{phoneLabel}</span>
                    <a class="side-value side-link" href={telHref}>{c.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{formLabel}</span>
                    <a class="side-value side-link" href="/contact/">
                      {p.sideFormLinkText}
                    </a>
                    <p class="svc-side-hint">{p.sideFormHint}</p>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(c.sideCharityFooter)}</p>
            </div>
            <ArchiveSidebarPeek filterId="hospice-services" excludePath="/hospice-services/transport" />
          </aside>
        </div>
      </section>
    </div>
  </div>
  <script>
    import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

<style>
  .transport-service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 700;
    color: var(--color-steel-blue);
    text-decoration: none;
  }

  .transport-service-link__text {
    position: relative;
  }

  .transport-service-link__text::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.06em;
    height: 0.34em;
    background: rgba(254, 220, 6, 0.9);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.2s var(--motion-ease-out);
    z-index: -1;
  }

  .transport-service-link:hover .transport-service-link__text::after,
  .transport-service-link:focus-visible .transport-service-link__text::after {
    transform: scaleX(1);
  }

  .transport-service-link:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
    border-radius: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .transport-service-link__text::after {
      transition: none;
      transform: scaleX(1);
    }
  }
</style>

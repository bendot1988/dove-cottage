---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import SubpageReviewCarousel from "../../../components/SubpageReviewCarousel.astro";
import fallbackData from "../../../data/mens-shed.json";
import fallbackContact from "../../../data/contact.json";
import { resolveSanityImageUrl, sanityClient } from "../../../lib/sanity";
import { fetchSingletonPageJson } from "../../../lib/sanitySingleton";
import { toTitleCase } from "../../../lib/titleCase";

const structuredPage = await sanityClient.fetch(`*[_type == "mensShedPage" && _id == "mensShedPage.main"][0]`);
const singletonPage = (await fetchSingletonPageJson<typeof fallbackData>("mens_shed")) ?? null;
const p = {
  ...fallbackData,
  ...(singletonPage ?? {}),
  ...(structuredPage ?? {}),
  heroImage: resolveSanityImageUrl(
    structuredPage?.heroImage,
    singletonPage?.heroImage || fallbackData.heroImage
  ),
};
const c = (await fetchSingletonPageJson<typeof fallbackContact>("contact")) ?? fallbackContact;
const telHref = `tel:${c.trustPhone.replace(/\s+/g, "")}`;

const layoutTitle = p.pageTitle
  .split(/\s*\|\s*/)
  .map((part) => toTitleCase(part.trim()))
  .join(" | ");

const parentLabel = p.parentNavLabel;
const asideTitle = toTitleCase("Get in touch");
const phoneLabel = toTitleCase("Phone");
const formLabel = toTitleCase("Enquiry");
const line = (row: { text: string } | string) => (typeof row === "string" ? row : row.text);
---

<BaseLayout title={layoutTitle}>
  <div class="svc-page mens-shed-page">
    <section class="hospice-svc-hero" aria-label={p.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={p.heroImage}
        alt={p.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={p.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {parentLabel}
        </a>
        <h1>{p.heroH1}</h1>
        <p class="hospice-svc-hero-dek">{p.heroShortDescription}</p>
      </div>
    </section>

    <div class="motion-scope">
      <SubpageReviewCarousel />

      <section class="svc-main" aria-label={p.heroH1}>
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            <h2 class="svc-section-h2">{p.whatHeading}</h2>
            <p class="svc-lede">{p.whatBody}</p>

            <div class="svc-card" role="group" aria-labelledby="who-heading">
              <h3 class="svc-card__title" id="who-heading">
                {p.whoHeading}
              </h3>
              <ul class="svc-list">
                {p.whoList.map((row) => (
                  <li>{line(row)}</li>
                ))}
              </ul>
            </div>

            <h2 class="svc-section-h2">{p.helpHeading}</h2>
            <p class="svc-body">{p.helpBody}</p>

            <div class="svc-card" role="group" aria-labelledby="benefits-heading">
              <h3 class="svc-card__title" id="benefits-heading">
                {p.benefitsHeading}
              </h3>
              <ul class="svc-list">
                {p.benefitsList.map((row) => (
                  <li>{line(row)}</li>
                ))}
              </ul>
            </div>

            <p class="svc-body">{p.attendanceBody}</p>
            <p class="svc-body">{p.locationBody}</p>

            <blockquote class="mens-shed-quote">
              <p>{p.quoteText}</p>
              <cite>{p.quoteAttribution}</cite>
            </blockquote>

            <div class="svc-card" id="mens-shed-enquiry-form">
              <div class="form-embed-card">
                <div class="beacon-form" data-account="dovecottagedayhospice" data-form="fe636194"></div>
              </div>
            </div>

          </div>

          <aside class="svc-side" aria-label={asideTitle}>
            <div class="side-card">
              <h2 class="side-card-title">{asideTitle}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{phoneLabel}</span>
                    <a class="side-value side-link" href={telHref}>{c.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{formLabel}</span>
                    <a class="side-value side-link" href="/contact/">
                      {p.sideFormLinkText}
                    </a>
                    <p class="svc-side-hint">{p.sideFormHint}</p>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(c.sideCharityFooter)}</p>
            </div>
            <ArchiveSidebarPeek filterId="counselling-support" excludePath="/hospice-services/mens-shed" />
          </aside>
        </div>
      </section>
    </div>
  </div>
  <script is:inline>
    !function(e,t){if(!e.getElementById(t)){var c=e.createElement("script");c.id=t,c.src="https://static.beaconproducts.co.uk/js-sdk/production/beaconcrm.min.js",e.getElementsByTagName("head")[0].appendChild(c)}}(document,"beacon-js-sdk");
  </script>
  <script>
    import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

<style>
  .mens-shed-page .svc-section-h2:first-of-type {
    margin-top: 0;
  }

  .mens-shed-quote {
    margin: 1.15rem 0 1.2rem;
    padding: 0.95rem 1rem;
    border-left: 4px solid rgba(29, 101, 178, 0.4);
    background: #f6f9fe;
    color: #29415f;
    border-radius: 10px;
  }

  .mens-shed-quote p {
    margin: 0 0 0.5rem;
    font-style: italic;
    line-height: 1.6;
  }

  .mens-shed-quote cite {
    display: block;
    font-size: var(--type-body-small);
    font-style: normal;
    font-weight: 700;
    color: #385677;
  }

  .form-embed-card {
    background: #fff;
    border: 1px solid #d9e3f0;
    border-radius: 16px;
    padding: 10px;
    box-shadow: 0 8px 22px rgba(18, 44, 83, 0.07);
  }

  :global(.beacon-form) {
    width: 100%;
    min-height: 560px;
  }

</style>

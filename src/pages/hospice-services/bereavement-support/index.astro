---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import b from "../../../data/bereavement-support.json";
import contact from "../../../data/contact.json";
import { toTitleCase } from "../../../lib/titleCase";

const c = contact;
const telHref = `tel:${c.trustPhone.replace(/\s+/g, "")}`;

const layoutTitle = b.pageTitle
  .split(/\s*\|\s*/)
  .map((part) => toTitleCase(part.trim()))
  .join(" | ");

const parentLabel = b.parentNavLabel;
const trustDonate = toTitleCase(c.trustDonateLabel);
const trustCharity = toTitleCase(c.trustCharityLine);
const asideTitle = toTitleCase("Get in touch");
const phoneLabel = toTitleCase("Phone");
const formLabel = toTitleCase("Enquiry");

const line = (row: { text: string } | string) => (typeof row === "string" ? row : row.text);
const introBlocks = [b.mainIntro1, b.mainIntro2].filter((p) => p?.trim().length);
---

<BaseLayout title={layoutTitle}>
  <div class="svc-page">
    <section class="hospice-svc-hero" aria-label={b.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={b.heroImage}
        alt={b.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={b.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {parentLabel}
        </a>
        <h1>
          {b.heroH1}
        </h1>
        <p class="hospice-svc-hero-dek">
          {b.heroShortDescription}
        </p>
      </div>
    </section>

    <div class="motion-scope">
      <div class="contact-trust" aria-label="Key details">
        <div class="container contact-trust-inner">
          <span class="contact-trust-charity">{trustCharity}</span>
          <div class="contact-trust-actions">
            <a class="contact-trust-phone" href={telHref}>☎ {c.trustPhoneDisplay}</a>
            <a href={c.trustDonateUrl} class="btn btn-primary btn-shine contact-trust-donate">{trustDonate}</a>
          </div>
        </div>
      </div>

      <section class="svc-main" aria-label={b.heroH1}>
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            {introBlocks.map((para) => <p class="svc-lede">{para}</p>)}

            {
              b.sectionImages?.afterIntro && (
                <figure class="svc-figure">
                  <img
                    class="svc-figure__img"
                    src={b.sectionImages.afterIntro.src}
                    alt={b.sectionImages.afterIntro.alt}
                    width="1200"
                    height="675"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              )
            }

            <div class="svc-card" role="group" aria-label={b.whoHeading}>
              <h2 class="svc-card__title" id="who-heading">
                {b.whoHeading}
              </h2>
              <ul class="svc-list">
                {b.whoList.map((row) => (
                  <li>{line(row)}</li>
                ))}
              </ul>
            </div>

            <div class="svc-card svc-card--callout" role="note">
              <p class="svc-callout">{b.callout}</p>
            </div>

            {
              b.sectionImages?.afterCallout && (
                <figure class="svc-figure">
                  <img
                    class="svc-figure__img"
                    src={b.sectionImages.afterCallout.src}
                    alt={b.sectionImages.afterCallout.alt}
                    width="1200"
                    height="675"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              )
            }

            <div class="svc-card">
              <h2 class="svc-card__title" id="anticipatory-heading">
                {b.anticipatoryHeading}
              </h2>
              <p class="svc-body">{b.anticipatoryBody1}</p>
              <p class="svc-body">{b.anticipatoryBody2}</p>
            </div>

            <div class="svc-card">
              <h2 class="svc-card__title" id="nurse-heading">
                {b.nurseHeading}
              </h2>
              <p class="svc-body">{b.nurseIntro}</p>
              <p class="svc-body svc-body--tight-top">{b.nurseListIntro}</p>
              <ul class="svc-list">
                {b.nurseList.map((row) => (
                  <li>{line(row)}</li>
                ))}
              </ul>
              <p class="svc-body">{b.nurseFoot}</p>
            </div>

            {
              b.sectionImages?.beforeSupportGroups && (
                <figure class="svc-figure">
                  <img
                    class="svc-figure__img"
                    src={b.sectionImages.beforeSupportGroups.src}
                    alt={b.sectionImages.beforeSupportGroups.alt}
                    width="1200"
                    height="675"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              )
            }

            <h2 class="svc-section-h2" id="groups-heading">
              {b.dropInHeading}
            </h2>
            <p class="svc-lede svc-lede--after-h2">{b.dropInIntro}</p>
            <div class="svc-group-grid">
              {
                b.dropInGroups.map((g) => (
                  <div class="svc-card svc-card--tight" role="group" aria-label={g.title}>
                    <h3 class="svc-card__subtitle">{g.title}</h3>
                    <ul class="svc-list">
                      {g.bullets.map((row) => (
                        <li>{line(row)}</li>
                      ))}
                    </ul>
                  </div>
                ))
              }
            </div>
            <p class="svc-footnote">{b.dropInFoot}</p>

            <div class="svc-card">
              <h2 class="svc-card__title" id="counselling-heading">
                {b.counsellingHeading}
              </h2>
              <p class="svc-body">{b.counsellingBody}</p>
              <p class="svc-body">
                <a class="svc-inline-link" href={b.counsellingCtaHref}>
                  {b.counsellingCta}
                </a>
              </p>
            </div>
          </div>

          <aside class="svc-side" aria-label={asideTitle}>
            <div class="side-card">
              <h2 class="side-card-title">{asideTitle}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{phoneLabel}</span>
                    <a class="side-value side-link" href={telHref}>{c.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{formLabel}</span>
                    <a class="side-value side-link" href="/contact/">
                      {b.sideFormLinkText}
                    </a>
                    <p class="svc-side-hint">{b.sideFormHint}</p>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(c.sideCharityFooter)}</p>
            </div>
            <ArchiveSidebarPeek filterId="hospice-services" excludePath="/hospice-services/bereavement-support" />
          </aside>
        </div>
      </section>
    </div>
  </div>
  <script>
    import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import SubpageReviewCarousel from "../../../components/SubpageReviewCarousel.astro";
import p from "../../../data/support-groups.json";
import contact from "../../../data/contact.json";
import { toTitleCase } from "../../../lib/titleCase";

const c = contact;
const telHref = `tel:${c.trustPhone.replace(/\s+/g, "")}`;

const layoutTitle = p.pageTitle
  .split(/\s*\|\s*/)
  .map((part) => toTitleCase(part.trim()))
  .join(" | ");

const parentLabel = p.parentNavLabel;
const asideTitle = toTitleCase("Get in touch");
const phoneLabel = toTitleCase("Phone");
const formLabel = toTitleCase("Enquiry");
const line = (row: { text: string } | string) => (typeof row === "string" ? row : row.text);
---

<BaseLayout title={layoutTitle}>
  <div class="svc-page support-groups-page">
    <section class="hospice-svc-hero" aria-label={p.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={p.heroImage}
        alt={p.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={p.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {parentLabel}
        </a>
        <h1>{p.heroH1}</h1>
        <p class="hospice-svc-hero-dek">{p.heroShortDescription}</p>
      </div>
    </section>

    <div class="motion-scope">
      <SubpageReviewCarousel />

      <section class="svc-main" aria-label={p.heroH1}>
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            <p class="svc-lede">{p.mainIntro1}</p>

            <h2 class="svc-section-h2">{p.groupsHeading}</h2>
            <div class="svc-group-grid">
              {
                p.groups.map((g) => (
                  <div class="svc-card svc-card--tight" role="group" aria-label={g.title}>
                    <h3 class="svc-card__subtitle">{g.title}</h3>
                    <ul class="svc-list">
                      {g.bullets.map((row) => (
                        <li>{line(row)}</li>
                      ))}
                    </ul>
                    <p class="svc-body">
                      <a class="svc-inline-link" href={g.ctaHref}>
                        {g.ctaLabel}
                      </a>
                    </p>
                  </div>
                ))
              }
            </div>

            <p class="svc-footnote">{p.detailsFoot}</p>
            <p class="svc-body">
              {p.registerInterestIntro}{" "}
              <a class="svc-inline-link" href={p.registerInterestHref}>
                {p.registerInterestCta}
              </a>
              .
            </p>
          </div>

          <aside class="svc-side" aria-label={asideTitle}>
            <div class="side-card">
              <h2 class="side-card-title">{asideTitle}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{phoneLabel}</span>
                    <a class="side-value side-link" href={telHref}>{c.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{formLabel}</span>
                    <a class="side-value side-link" href="/contact/">
                      {p.sideFormLinkText}
                    </a>
                    <p class="svc-side-hint">{p.sideFormHint}</p>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(c.sideCharityFooter)}</p>
            </div>
            <ArchiveSidebarPeek filterId="counselling-support" excludePath="/hospice-services/support-groups" />
          </aside>
        </div>
      </section>
    </div>
  </div>
  <script>
    import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

<style>
  .support-groups-page .svc-primary > .svc-lede:first-of-type {
    margin-bottom: 1.8rem;
  }

  .support-groups-page .svc-section-h2 {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .support-groups-page .svc-group-grid {
    margin-bottom: 1.2rem;
  }
</style>

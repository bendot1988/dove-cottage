---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import SubpageReviewCarousel from "../../../components/SubpageReviewCarousel.astro";
import fallbackData from "../../../data/bereavement-support-group.json";
import fallbackContact from "../../../data/contact.json";
import { fetchSingletonPageJson } from "../../../lib/sanitySingleton";
import { toTitleCase } from "../../../lib/titleCase";

const p =
  (await fetchSingletonPageJson<typeof fallbackData>("bereavement_support_group")) ?? fallbackData;
const c = (await fetchSingletonPageJson<typeof fallbackContact>("contact")) ?? fallbackContact;
const telHref = `tel:${c.trustPhone.replace(/\s+/g, "")}`;

const layoutTitle = p.pageTitle
  .split(/\s*\|\s*/)
  .map((part) => toTitleCase(part.trim()))
  .join(" | ");

const parentLabel = p.parentNavLabel;
const asideTitle = toTitleCase("Get in touch");
const phoneLabel = toTitleCase("Phone");
const formLabel = toTitleCase("Enquiry");
const line = (row: { text: string } | string) => (typeof row === "string" ? row : row.text);
const beaconAccount = (p.beaconAccount ?? "dovecottagedayhospice").trim();
const beaconFormId = (p.beaconFormId ?? "").trim();
const showBeaconForm = Boolean(beaconFormId);
---

<BaseLayout title={layoutTitle}>
  <div class="svc-page support-groups-page">
    <section class="hospice-svc-hero" aria-label={p.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={p.heroImage}
        alt={p.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={p.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {parentLabel}
        </a>
        <h1>{p.heroH1}</h1>
        <p class="hospice-svc-hero-dek">{p.heroShortDescription}</p>
      </div>
    </section>

    <div class="motion-scope">
      <SubpageReviewCarousel />

      <section class="svc-main" aria-label={p.heroH1}>
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            <p class="svc-lede">{p.mainIntro1}</p>
            <p class="svc-lede">{p.mainIntro2}</p>
            <p class="svc-lede">{p.mainIntro3}</p>

            {
              p.sectionImage1 && (
                <figure class="svc-figure">
                  <img
                    class="svc-figure__img"
                    src={p.sectionImage1.src}
                    alt={p.sectionImage1.alt}
                    width="1200"
                    height="675"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              )
            }

            <h2 class="svc-section-h2">{p.groupHeading}</h2>
            <div class="svc-group-grid">
              <div class="svc-card svc-card--tight" role="group" aria-label={p.groupHeading}>
                <ul class="svc-list">
                  {p.groupBullets.map((row) => (
                    <li>{line(row)}</li>
                  ))}
                </ul>
              </div>
            </div>

            <p class="svc-footnote">{p.detailsFoot}</p>
            <p class="svc-body">
              {p.registerInterestIntro}{" "}
              <a class="svc-inline-link" href={p.registerInterestHref}>
                {p.registerInterestCta}
              </a>{" "}
              {p.registerInterestOutro}
            </p>

            {
              showBeaconForm && (
                <div class="svc-card" id="bereavement-enquiry-form">
                  <div class="form-embed-card">
                    <div class="beacon-form" data-account={beaconAccount} data-form={beaconFormId}></div>
                  </div>
                </div>
              )
            }
          </div>

          <aside class="svc-side" aria-label={asideTitle}>
            <div class="side-card">
              <h2 class="side-card-title">{asideTitle}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{phoneLabel}</span>
                    <a class="side-value side-link" href={telHref}>{c.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{formLabel}</span>
                    <a class="side-value side-link" href="/contact/">
                      {p.sideFormLinkText}
                    </a>
                    <p class="svc-side-hint">{p.sideFormHint}</p>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(c.sideCharityFooter)}</p>
            </div>
            <ArchiveSidebarPeek filterId="counselling-support" excludePath="/hospice-services/bereavement-support-group" />
          </aside>
        </div>
      </section>
    </div>
  </div>
  <script>
    import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
  <script is:inline>
    !function(e,t){if(!e.getElementById(t)){var c=e.createElement("script");c.id=t,c.src="https://static.beaconproducts.co.uk/js-sdk/production/beaconcrm.min.js",e.getElementsByTagName("head")[0].appendChild(c)}}(document,"beacon-js-sdk");
  </script>
</BaseLayout>

<style>
  .form-embed-card {
    background: #fff;
    border: 1px solid #d9e3f0;
    border-radius: 16px;
    padding: 10px;
    box-shadow: 0 8px 22px rgba(18, 44, 83, 0.07);
  }

  :global(.beacon-form) {
    width: 100%;
    min-height: 560px;
  }

  .svc-figure {
    margin: 1rem 0 1.2rem;
  }

  .svc-figure__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 14px;
    border: 1px solid #d9e3f0;
    box-shadow: 0 10px 24px rgba(18, 44, 83, 0.08);
  }

  .support-groups-page .svc-primary > .svc-lede:first-of-type {
    margin-bottom: 0.9rem;
  }

  .support-groups-page .svc-primary > .svc-lede {
    margin-bottom: 0.8rem;
  }

  .support-groups-page .svc-section-h2 {
    margin-top: 1.1rem;
    margin-bottom: 1rem;
  }

  .support-groups-page .svc-group-grid {
    margin-bottom: 1.2rem;
  }
</style>

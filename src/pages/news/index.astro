---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout title="News & Events | Dove Cottage">
  <section class="news-listing">
    <div class="container">
      <h1>News &amp; Events</h1>
      <p class="intro">Latest updates, announcements, and events from Dove Cottage Day Hospice.</p>

      {posts.length === 0 ? (
        <p>No news posts have been published yet.</p>
      ) : (
        <div class="news-grid">
          {posts.map((post) => (
            <article class="news-card">
              {post.data.featuredImage && (
                <a href={`/news/${post.slug}/`} class="thumb-link">
                  <img src={post.data.featuredImage} alt="" loading="lazy" />
                </a>
              )}
              <div class="news-card-body">
                <p class="meta">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString("en-GB", {
                      day: "numeric",
                      month: "short",
                      year: "numeric"
                    })}
                  </time>
                </p>
                <h2>
                  <a href={`/news/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p>{post.data.excerpt}</p>
                <a href={`/news/${post.slug}/`} class="read-more">Read more →</a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .news-listing {
    background: var(--color-lavender);
    padding: 56px 0 72px;
  }

  .container {
    width: min(1200px, 95%);
    margin: 0 auto;
  }

  h1 {
    margin: 0;
    font-size: var(--type-section-title);
    color: var(--color-steel-blue);
  }

  .intro {
    margin: 12px 0 26px;
    color: #3b4f6c;
    font-size: var(--type-body-large);
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .news-card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #dde6f4;
    box-shadow: 0 8px 18px rgba(18, 44, 83, 0.08);
  }

  .thumb-link img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .news-card-body {
    padding: 16px;
  }

  .meta {
    margin: 0 0 8px;
    color: #61738d;
    font-size: var(--type-body-small);
    font-weight: 600;
  }

  h2 {
    margin: 0 0 8px;
    font-size: var(--type-card-title);
    line-height: 1.3;
  }

  h2 a {
    color: #102a4e;
    text-decoration: none;
  }

  h2 a:hover {
    text-decoration: underline;
  }

  .news-card-body p {
    margin: 0 0 12px;
    color: #3f5370;
    font-size: var(--type-body);
    line-height: 1.55;
  }

  .read-more {
    color: var(--color-steel-blue);
    text-decoration: none;
    font-weight: 700;
    font-size: var(--type-button);
  }

  .read-more:hover {
    text-decoration: underline;
  }

  @media (max-width: 980px) {
    .news-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

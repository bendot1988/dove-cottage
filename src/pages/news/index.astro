---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveSanityImageUrl, sanityClient } from "../../lib/sanity";

const posts = await sanityClient.fetch(`
  *[_type == "newsPost" && !coalesce(draft, false)] | order(publishDate desc) {
    title,
    category,
    excerpt,
    "slug": slug.current,
    featuredImage,
    eventDate,
    eventEndDate,
    eventLocation,
    publishDate
  }
`);

const events = await sanityClient.fetch(`
  *[_type == "eventPost" && !coalesce(draft, false)] | order(eventDate asc) {
    title,
    category,
    excerpt,
    "slug": slug.current,
    featuredImage,
    eventDate,
    eventEndDate,
    location
  }
`);

const postsWithImage = posts.map((post) => ({
  ...post,
  featuredImage: resolveSanityImageUrl(post.featuredImage, ""),
}));

const eventsWithImage = events.map((event) => ({
  ...event,
  featuredImage: resolveSanityImageUrl(event.featuredImage, ""),
}));

const now = new Date();
const isPastEvent = (startDate: Date, endDate?: Date) => {
  const checkDate = endDate ?? startDate;
  return checkDate.getTime() < now.getTime();
};

const formatEventDate = (startDate: Date, endDate?: Date) => {
  const base = startDate.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric"
  });
  if (!endDate) return base;
  const end = endDate.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric"
  });
  return `${base} - ${end}`;
};

const isEventsCategory = (category: string) => category.trim().toLowerCase() === "events";

const feedItems = [
  ...postsWithImage.map((post) => {
    const evStart = post.eventDate ? new Date(post.eventDate) : null;
    const evEnd = post.eventEndDate ? new Date(post.eventEndDate) : undefined;
    const hasEventSchedule = evStart != null;
    const past = hasEventSchedule ? isPastEvent(evStart, evEnd) : false;
    const publishDate = post.publishDate ? new Date(post.publishDate) : new Date();
    const sortDate = hasEventSchedule ? evStart : publishDate;
    const dateLabel = hasEventSchedule
      ? formatEventDate(evStart, evEnd)
      : publishDate.toLocaleDateString("en-GB", {
          day: "numeric",
          month: "short",
          year: "numeric"
        });
    return {
      type: "news" as const,
      feedFilter: (isEventsCategory(post.category) ? "event" : "news") as "news" | "event",
      key: `news-${post.slug}`,
      title: post.title,
      excerpt: post.excerpt,
      href: `/news/${post.slug}/`,
      image: post.featuredImage,
      category: post.category,
      eventDate: post.eventDate,
      date: sortDate,
      dateLabel,
      location: post.eventLocation?.trim() ?? "",
      past
    };
  }),
  ...eventsWithImage.map((event) => {
    const eventStart = event.eventDate ? new Date(event.eventDate) : new Date();
    const eventEnd = event.eventEndDate ? new Date(event.eventEndDate) : undefined;
    const past = isPastEvent(eventStart, eventEnd);
    return {
      type: "event" as const,
      feedFilter: "event" as const,
      key: `event-${event.slug}`,
      title: event.title,
      excerpt: event.excerpt,
      href: `/events/${event.slug}/`,
      image: event.featuredImage,
      category: event.category,
      eventDate: event.eventDate,
      date: eventStart,
      dateLabel: formatEventDate(eventStart, eventEnd),
      location: event.location,
      past
    };
  })
].sort((a, b) => b.date.getTime() - a.date.getTime());

const currentFeedItems = feedItems.filter((item) => !(item.feedFilter === "event" && item.past));
const previousEvents = feedItems.filter((item) => item.feedFilter === "event" && item.past);
---

<BaseLayout
  title="News & Events | Dove Cottage"
  description="Read the latest Dove Cottage hospice news, stories and upcoming community events across the Vale of Belvoir."
>
  <div class="motion-scope">
  <section class="news-hero" aria-label="News and events">
    <img
      class="news-hero-bg"
      src="/images/uploads/news/latest-news-featured.png"
      alt="Printed Dove Cottage newsletter copies on a wooden table"
      width="1920"
      height="720"
      loading="eager"
      fetchpriority="high"
    />
    <div class="news-hero-overlay" aria-hidden="true"></div>
    <div class="container news-hero-inner">
      <p class="interior-hero-eyebrow">News &amp; Events</p>
      <h1>
        Latest <span class="news-hero-highlight">News &amp; Events</span>
      </h1>
      <p class="news-hero-dek">Stories, updates and upcoming events from Dove Cottage Day Hospice.</p>
    </div>
  </section>

  <section class="news-listing">
    <div class="container">
      <h2>Latest updates</h2>
      <p class="intro">Use the filters below to browse news stories and events.</p>

      <div class="feed-filter" role="group" aria-label="Filter news and events">
        <button type="button" class="feed-filter__btn is-active" data-feed-filter="all" aria-pressed="true">
          News &amp; Events
        </button>
        <button type="button" class="feed-filter__btn" data-feed-filter="news" aria-pressed="false">
          News
        </button>
        <button type="button" class="feed-filter__btn" data-feed-filter="event" aria-pressed="false">
          Events
        </button>
      </div>

      {currentFeedItems.length === 0 ? (
        <p class="stream-empty">No news or events have been published yet.</p>
      ) : (
        <>
          <p class="feed-empty-message" data-feed-empty-message hidden></p>
          <div class="feed-grid cards-grid" data-feed-grid>
            {currentFeedItems.map((item) => {
              const isEventStyle = item.type === "event" || item.eventDate != null;
              return (
              <article
                class:list={["news-card", { "event-card": isEventStyle }]}
                data-feed-type={item.feedFilter}
              >
                {item.image && (
                  <a href={item.href} class="thumb-link">
                    <img src={item.image} alt="" loading="lazy" />
                  </a>
                )}
                <div class="news-card-body">
                  {isEventStyle ? (
                    <>
                      <p class="meta meta--tag-only">
                        <span class="category">{item.type === "event" ? "Event" : item.category}</span>
                      </p>
                      <div class="event-facts-card">
                        <div class="event-facts-card__row">
                          <p class="event-facts-card__label">Event dates</p>
                          <p class="event-facts-card__value">
                            <time datetime={item.date.toISOString()}>{item.dateLabel}</time>
                          </p>
                        </div>
                        {item.location ? (
                          <div class="event-facts-card__row">
                            <p class="event-facts-card__label">Location</p>
                            <p class="event-facts-card__value">{item.location}</p>
                          </div>
                        ) : null}
                      </div>
                    </>
                  ) : (
                    <p class="meta">
                      <span class="category">{item.category}</span>
                      <span>·</span>
                      <time datetime={item.date.toISOString()}>{item.dateLabel}</time>
                    </p>
                  )}
                  <h3>
                    <a href={item.href}>{item.title}</a>
                  </h3>
                  <p class="excerpt">{item.excerpt}</p>
                  <a href={item.href} class="read-more">
                    <span class="read-more-text">
                      {isEventStyle ? (item.type === "event" ? "View event" : "Read more") : "Read more"}
                    </span>
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
              );
            })}
          </div>
        </>
      )}

      {previousEvents.length > 0 && (
        <details class="previous-events">
          <summary>Previous events ({previousEvents.length})</summary>
          <p class="previous-events__intro">Browse ended events and their original details.</p>
          <div class="feed-grid cards-grid">
            {previousEvents.map((item) => (
              <article class="news-card event-card event-card--past">
                {item.image && (
                  <a href={item.href} class="thumb-link">
                    <img src={item.image} alt="" loading="lazy" />
                  </a>
                )}
                <div class="news-card-body">
                  <p class="meta meta--tag-only">
                    <span class="category">Event</span>
                  </p>
                  <p class="event-status">Previous event</p>
                  <div class="event-facts-card">
                    <div class="event-facts-card__row">
                      <p class="event-facts-card__label">Event dates</p>
                      <p class="event-facts-card__value">
                        <time datetime={item.date.toISOString()}>{item.dateLabel}</time>
                      </p>
                    </div>
                    {item.location ? (
                      <div class="event-facts-card__row">
                        <p class="event-facts-card__label">Location</p>
                        <p class="event-facts-card__value">{item.location}</p>
                      </div>
                    ) : null}
                  </div>
                  <h3>
                    <a href={item.href}>{item.title}</a>
                  </h3>
                  <p class="excerpt">{item.excerpt}</p>
                  <a href={item.href} class="read-more">
                    <span class="read-more-text">View details</span>
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </details>
      )}
    </div>
  </section>
  </div>
  <script>
    import { initMotionScrollReveal } from "../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();

    const filterButtons = Array.from(document.querySelectorAll("[data-feed-filter]"));
    const cards = Array.from(document.querySelectorAll("[data-feed-type]"));
    const feedEmptyMessage = document.querySelector("[data-feed-empty-message]");

    const applyFilter = (filter) => {
      filterButtons.forEach((btn) => {
        const active = btn.dataset.feedFilter === filter;
        btn.classList.toggle("is-active", active);
        btn.setAttribute("aria-pressed", active ? "true" : "false");
      });

      cards.forEach((card) => {
        const type = card.dataset.feedType;
        const show = filter === "all" || type === filter;
        card.hidden = !show;
      });

      if (feedEmptyMessage) {
        const visibleCount = cards.filter((card) => !card.hidden).length;
        if (visibleCount === 0 && filter === "event") {
          feedEmptyMessage.innerHTML =
            'No upcoming events at the moment. You can see our previous events below. If you are interested in starting or creating an event, please <a href="/contact/">contact us</a>.';
          feedEmptyMessage.hidden = false;
        } else {
          feedEmptyMessage.hidden = true;
          feedEmptyMessage.textContent = "";
        }
      }
    };

    if (filterButtons.length && cards.length) {
      const params = new URLSearchParams(window.location.search);
      const feed = params.get("feed");
      const initial = feed === "news" || feed === "event" ? feed : "all";
      applyFilter(initial);

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          applyFilter(button.dataset.feedFilter || "all");
        });
      });
    }
  </script>
</BaseLayout>

<style>
  .news-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: min(48vh, 400px);
    padding: clamp(2.5rem, 6vw, 3.5rem) 0 clamp(2rem, 5vw, 2.75rem);
    color: #fff;
    overflow: hidden;
  }

  .news-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .news-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(105deg, rgba(8, 22, 48, 0.88) 0%, rgba(8, 22, 48, 0.62) 42%, rgba(8, 22, 48, 0.35) 100%);
  }

  .news-hero-inner {
    position: relative;
    z-index: 2;
    text-align: left;
  }

  .news-hero h1 {
    margin: 0 0 0.75rem;
    font-size: var(--type-hero-title);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .news-hero-highlight {
    color: var(--color-golden-yellow);
  }

  .news-hero-dek {
    margin: 0;
    max-width: 40rem;
    font-size: var(--type-body-large);
    line-height: 1.55;
    text-wrap: pretty;
    color: rgba(255, 255, 255, 0.92);
  }

  .news-listing {
    background: var(--color-lavender);
    padding: 48px 0 72px;
  }

  .news-listing h2 {
    margin: 0;
    font-size: var(--type-section-title);
    color: #0f2240;
    text-align: center;
  }

  .intro {
    margin: 12px auto 26px;
    color: #364861;
    font-size: var(--type-body-large);
    max-width: 760px;
    text-align: center;
  }

  .feed-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .stream-empty {
    margin: 0;
    color: #4e627e;
    font-size: var(--type-body);
  }

  .feed-empty-message {
    margin: 0 0 14px;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid #d7e2f3;
    background: #f8fbff;
    color: #3b4f6d;
    font-size: var(--type-body);
    line-height: 1.6;
  }

  .feed-empty-message a {
    color: var(--color-steel-blue);
    font-weight: 700;
  }

  .feed-filter {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin: 0 0 18px;
  }

  .previous-events {
    margin-top: 26px;
    padding-top: 14px;
    border-top: 1px solid #cfdcf0;
  }

  .previous-events > summary {
    cursor: pointer;
    color: #15355d;
    font-size: var(--type-body);
    font-weight: 800;
    list-style: none;
  }

  .previous-events > summary::-webkit-details-marker {
    display: none;
  }

  .previous-events > summary::before {
    content: "▸";
    display: inline-block;
    margin-right: 8px;
    transition: transform 0.2s ease;
  }

  .previous-events[open] > summary::before {
    transform: rotate(90deg);
  }

  .previous-events__intro {
    margin: 10px 0 14px;
    color: #4c607c;
    font-size: var(--type-body-small);
  }

  .feed-filter__btn {
    border: 1px solid #c2d1e8;
    background: #fff;
    color: #1a3558;
    border-radius: 999px;
    padding: 0.45rem 0.75rem;
    font: inherit;
    font-size: var(--type-body-small);
    font-weight: 700;
    cursor: pointer;
    transition:
      background 0.18s var(--motion-ease-out),
      color 0.18s var(--motion-ease-out),
      border-color 0.18s var(--motion-ease-out);
  }

  .feed-filter__btn.is-active,
  .feed-filter__btn[aria-pressed="true"] {
    background: var(--color-steel-blue-1);
    border-color: var(--color-steel-blue-1);
    color: #fff;
  }

  .news-card {
    background: #fff;
    border: 1px solid #dce5f2;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 18px rgba(18, 44, 83, 0.08);
    display: flex;
    flex-direction: column;
    min-height: 100%;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .news-card[hidden] {
    display: none;
  }

  .news-card:hover,
  .news-card:focus-within {
    transform: translateY(-4px);
    border-color: #bfd0e7;
    box-shadow: 0 14px 26px rgba(18, 44, 83, 0.14);
  }

  .thumb-link {
    display: block;
    margin-top: auto;
    overflow: hidden;
  }

  .thumb-link img {
    width: 100%;
    min-height: 170px;
    max-height: 170px;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .news-card:hover .thumb-link img,
  .news-card:focus-within .thumb-link img {
    transform: scale(1.08);
  }

  .news-card-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .meta {
    margin: 0 0 8px;
    color: #61738d;
    font-size: var(--type-body-small);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .category {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-steel-blue);
    font-weight: 700;
  }

  h3 {
    margin: 0 0 8px;
    font-size: var(--type-card-title);
    line-height: 1.3;
  }

  h3 a {
    color: #102a4e;
    text-decoration: none;
  }

  h3 a:hover {
    text-decoration: underline;
  }

  .meta--tag-only {
    margin-bottom: 4px;
  }

  .event-facts-card {
    margin: 0 0 10px;
    padding: 12px 14px;
    background: #f4f7fc;
    border: 1px solid #e0e8f4;
    border-radius: 10px;
  }

  .event-facts-card__row + .event-facts-card__row {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid #dce5f2;
  }

  .event-facts-card__label {
    margin: 0 0 4px;
    font-size: var(--type-micro);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-steel-blue);
  }

  .event-facts-card__value {
    margin: 0;
    font-size: var(--type-body-small);
    font-weight: 700;
    color: #102a4e;
    line-height: 1.45;
  }

  .event-status {
    margin: 0 0 6px;
    font-size: var(--type-micro);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8e5b3e;
  }

  .event-card--past {
    opacity: 0.92;
    border-color: #e2d8cf;
  }

  .event-card--past .event-facts-card__value {
    color: #7d6b5d;
  }

  .event-card h3.is-past a {
    text-decoration: line-through;
    text-decoration-thickness: 2px;
    text-decoration-color: rgba(142, 91, 62, 0.42);
  }

  .excerpt {
    margin: 0;
    color: #425772;
    font-size: var(--type-body);
    line-height: 1.55;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    margin-top: auto;
    padding-top: 14px;
    color: var(--color-steel-blue);
    text-decoration: none;
    font-weight: 700;
    font-size: var(--type-button);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .read-more-text {
    position: relative;
  }

  .read-more-text::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 3px;
    background: var(--color-golden-yellow);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s ease;
  }

  .read-more:hover .read-more-text::after,
  .read-more:focus-visible .read-more-text::after {
    transform: scaleX(1);
  }

  @media (max-width: 980px) {
    .feed-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .feed-grid {
      grid-template-columns: 1fr;
    }

    .news-listing {
      padding: 44px 0 60px;
    }
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../components/ArchiveSidebarPeek.astro";
import SubpageReviewCarousel from "../../components/SubpageReviewCarousel.astro";
import p from "../../data/hire-our-facilities.json";
import contact from "../../data/contact.json";
import { toTitleCase } from "../../lib/titleCase";
import { fetchSingletonPageJson } from "../../lib/sanitySingleton";
import { resolveSanityImageUrl, sanityClient } from "../../lib/sanity";

const structuredPageData = await sanityClient.fetch(`
  *[_type == "hireOurFacilitiesPage"][0]{
    pageTitle,
    heroImage,
    heroImageAlt,
    parentNavLabel,
    parentNavHref,
    heroH1,
    heroShortDescription,
    introBlocks,
    sections,
    impactHeading,
    impactBody,
    formHeading,
    formIntro,
    sideFormLinkText,
    sideFormHint,
    sidebarPeekTitle,
    sidebarPeekViewAllHref,
    sidebarPeekViewAllLabel,
    sidebarPeekCards,
    gallerySections
  }
`);
const singletonPageData = (await fetchSingletonPageJson<typeof p>("hire_our_facilities")) ?? null;
const pageData = {
  ...p,
  ...(singletonPageData ?? {}),
  ...(structuredPageData ?? {}),
};
const c = (await fetchSingletonPageJson<typeof contact>("contact")) ?? contact;
const telHref = `tel:${c.trustPhone.replace(/\s+/g, "")}`;

const imageUrlFromField = (
  value?: { image?: unknown; legacyUrl?: string } | string | null,
  fallback = ""
) => {
  if (typeof value === "string") return value || fallback;
  if (!value) return fallback;
  return resolveSanityImageUrl(value.image, value.legacyUrl || fallback);
};

const sectionGalleryRows = Array.isArray(pageData.gallerySections) ? pageData.gallerySections : [];
const sectionGalleries = new Map(
  sectionGalleryRows.map((gallery) => [
    gallery.heading,
    (gallery.images ?? []).map((image) => ({
      src: imageUrlFromField(image?.image, image?.src || ""),
      alt: image?.alt || "",
    })),
  ])
);

const sidebarPeekCards = (pageData.sidebarPeekCards ?? []).map((card) => ({
  ...card,
  image: imageUrlFromField(card.image, typeof card.image === "string" ? card.image : ""),
}));

const layoutTitle = (pageData.pageTitle || p.pageTitle)
  .split(/\s*\|\s*/)
  .map((part) => toTitleCase(part.trim()))
  .join(" | ");

const asideTitle = toTitleCase("Get in touch");
const phoneLabel = toTitleCase("Phone");
const formLabel = toTitleCase("Enquiry");
const line = (row: { text: string } | string) => (typeof row === "string" ? row : row.text);
const introBlocks =
  Array.isArray(pageData.introBlocks) && pageData.introBlocks.length > 0
    ? pageData.introBlocks
    : [pageData.mainIntro1, pageData.mainIntro2, pageData.mainIntro3, pageData.mainIntro4];
const introParagraphs = introBlocks.filter((block) => block?.trim().length);
const heroImageSrc = imageUrlFromField(pageData.heroImage, p.heroImage);
const sections = Array.isArray(pageData.sections) ? pageData.sections : p.sections;
---

<BaseLayout title={layoutTitle} description={pageData.heroShortDescription}>
  <div class="svc-page">
    <section class="hospice-svc-hero" aria-label={pageData.heroH1}>
      <img class="hospice-svc-hero-bg" src={heroImageSrc} alt={pageData.heroImageAlt} width="1920" height="720" loading="eager" fetchpriority="high" />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={pageData.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {pageData.parentNavLabel}
        </a>
        <h1>{pageData.heroH1}</h1>
        <p class="hospice-svc-hero-dek">{pageData.heroShortDescription}</p>
      </div>
    </section>

    <div class="motion-scope">
      <SubpageReviewCarousel />
      <section class="svc-main" aria-label={pageData.heroH1}>
        <img src="/images/sunflower-brand-small.png" alt="" class="svc-sunflower" loading="lazy" aria-hidden="true" />
        <div class="container svc-layout">
          <div class="svc-primary">
            {introParagraphs.map((para) => <p class="svc-lede">{para}</p>)}

            {
              sections.map((section) => (
                <div class="svc-card" role="group" aria-label={section.heading}>
                  <h2 class="svc-card__title">{section.heading}</h2>
                  {section.subheading && <p class="svc-body svc-body--strong">{section.subheading}</p>}
                  {section.body && <p class="svc-body">{section.body}</p>}
                  {section.bullets?.length > 0 && (
                    <ul class="svc-list">
                      {section.bullets.map((row) => (
                        <li>{line(row)}</li>
                      ))}
                    </ul>
                  )}
                  {section.closing && <p class="svc-body">{section.closing}</p>}
                  {
                    sectionGalleries.get(section.heading)?.length > 0 && (
                      <div class="facility-gallery-grid" aria-label={`${section.heading} photos`}>
                        {sectionGalleries.get(section.heading)?.map((image) => (
                          <figure class="facility-gallery-item">
                            <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
                          </figure>
                        ))}
                      </div>
                    )
                  }
                </div>
              ))
            }

            <div class="svc-card" role="group" aria-label={pageData.impactHeading}>
              <h2 class="svc-card__title">{pageData.impactHeading}</h2>
              <p class="svc-body">{pageData.impactBody}</p>
              {
                sectionGalleries.get(pageData.impactHeading)?.length > 0 && (
                  <div class="facility-gallery-grid" aria-label={`${pageData.impactHeading} photos`}>
                    {sectionGalleries.get(pageData.impactHeading)?.map((image) => (
                      <figure class="facility-gallery-item">
                        <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
                      </figure>
                    ))}
                  </div>
                )
              }
            </div>

            <div class="svc-card" id="facility-hire-enquiry-form">
              <h2 class="svc-card__title">{pageData.formHeading}</h2>
              <p class="svc-body">{pageData.formIntro}</p>
              <div class="form-embed-card">
                <div class="beacon-form" data-account="dovecottagedayhospice" data-form="5cada45e"></div>
              </div>
            </div>
          </div>

          <aside class="svc-side" aria-label={asideTitle}>
            <div class="side-card">
              <h2 class="side-card-title">{asideTitle}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{phoneLabel}</span>
                    <a class="side-value side-link" href={telHref}>{c.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{formLabel}</span>
                    <a
                      class="side-form-scroll-btn"
                      href="#facility-hire-enquiry-form"
                      aria-label="Scroll to the facility hire enquiry form on this page"
                    >
                      <span>{pageData.sideFormLinkText}</span>
                      <svg class="side-form-scroll-btn__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12 5v14" />
                        <path d="m19 12-7 7-7-7" />
                      </svg>
                    </a>
                    <p class="svc-side-hint">{pageData.sideFormHint}</p>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(c.sideCharityFooter)}</p>
            </div>
            <ArchiveSidebarPeek
              staticCards={sidebarPeekCards}
              staticTitle={pageData.sidebarPeekTitle}
              staticViewAllHref={pageData.sidebarPeekViewAllHref}
              staticViewAllLabel={pageData.sidebarPeekViewAllLabel}
            />
          </aside>
        </div>
      </section>
    </div>
  </div>
  <script is:inline>
    !function(e,t){if(!e.getElementById(t)){var c=e.createElement("script");c.id=t,c.src="https://static.beaconproducts.co.uk/js-sdk/production/beaconcrm.min.js",e.getElementsByTagName("head")[0].appendChild(c)}}(document,"beacon-js-sdk");
  </script>
  <script>
    import { initMotionScrollReveal } from "../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

<style>
  #facility-hire-enquiry-form {
    scroll-margin-top: 5.5rem;
  }

  .svc-body--strong {
    font-weight: 700;
    color: #203857;
  }

  .side-form-scroll-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 4px;
    padding: 10px 14px;
    border-radius: 999px;
    border: 1px solid #204a81;
    background: #fff;
    color: #204a81;
    font-size: var(--type-body-small);
    font-weight: 700;
    text-decoration: none;
    line-height: 1.2;
    transition:
      background 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .side-form-scroll-btn:hover,
  .side-form-scroll-btn:focus-visible {
    background: #f2f6fc;
    border-color: var(--color-steel-blue-1);
    color: var(--color-steel-blue-1);
    box-shadow: 0 2px 8px rgba(29, 101, 178, 0.12);
  }

  .side-form-scroll-btn:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
  }

  .side-form-scroll-btn__arrow {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .form-embed-card {
    background: #fff;
    border: 1px solid #d9e3f0;
    border-radius: 16px;
    padding: 10px;
    box-shadow: 0 8px 22px rgba(18, 44, 83, 0.07);
  }

  :global(.beacon-form) {
    width: 100%;
    min-height: 560px;
  }

  .facility-gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 0.75rem;
  }

  .facility-gallery-item {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #d9e3f0;
    background: #fff;
    box-shadow: 0 4px 12px rgba(18, 44, 83, 0.08);
  }

  .facility-gallery-item img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .facility-gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

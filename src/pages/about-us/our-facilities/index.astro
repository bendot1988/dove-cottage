---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import facilities from "../../../data/hire-our-facilities.json";

const pageTitle = "Our Facilities | Dove Cottage";
const heroH1 = "Our Facilities";
const heroDescription =
  "Explore the welcoming spaces at Dove Cottage, from our salon and therapy rooms to meeting spaces, gardens, and accessible facilities.";
const introBlocks = [facilities.mainIntro1, facilities.mainIntro2].filter((text) => text?.trim().length);
---

<BaseLayout title={pageTitle} description={heroDescription}>
  <div class="svc-page">
    <section class="hospice-svc-hero" aria-label={heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={facilities.heroImage}
        alt={facilities.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href="/explore/">
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          About Us
        </a>
        <h1>{heroH1}</h1>
        <p class="hospice-svc-hero-dek">{heroDescription}</p>
      </div>
    </section>

    <section class="svc-main facilities-main" aria-label="Facilities gallery">
      <img
        src="/images/sunflower-brand-small.png"
        alt=""
        class="svc-sunflower"
        loading="lazy"
        aria-hidden="true"
      />
      <div class="container">
        {introBlocks.map((text) => <p class="svc-lede">{text}</p>)}

        <div class="facility-sections">
          {facilities.gallerySections.map((section) => (
            <article class="svc-card facility-section" aria-label={section.heading}>
              <h2 class="svc-card__title">{section.heading}</h2>
              <div class="facility-gallery-grid">
                {section.images.map((image) => (
                  <figure class="facility-gallery-item">
                    <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
                  </figure>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .facilities-main {
    padding-top: clamp(2rem, 5vw, 3rem);
  }

  .facility-sections {
    display: grid;
    gap: 1rem;
  }

  .facility-section {
    margin-bottom: 0;
  }

  .facility-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 0.75rem;
  }

  .facility-gallery-item {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #d9e3f0;
    background: #fff;
    box-shadow: 0 4px 12px rgba(18, 44, 83, 0.08);
  }

  .facility-gallery-item img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (max-width: 980px) {
    .facility-gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .facility-gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

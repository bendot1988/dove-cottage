---
import BaseLayout from "../../layouts/BaseLayout.astro";
import data from "../../data/support-us-overview.json";
---

<BaseLayout title={data.pageTitle} description={data.heroShortDescription}>
  <section class="hospice-svc-hero" aria-label={data.heroH1}>
    <img
      class="hospice-svc-hero-bg"
      src={data.heroImage}
      alt={data.heroImageAlt}
      width="1920"
      height="720"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
    <div class="container hospice-svc-hero-inner">
      <a class="interior-hero-eyebrow" href={data.parentNavHref}>
        <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
        {data.parentNavLabel}
      </a>
      <h1>{data.heroH1}</h1>
      <p class="hospice-svc-hero-dek">{data.heroShortDescription}</p>
    </div>
  </section>

  <section class="support-overview" aria-labelledby="support-overview-title">
    <div class="container">
      <header class="support-overview__intro">
        <p class="support-overview__eyebrow">{data.introEyebrow}</p>
        <h2 id="support-overview-title">{data.introHeading}</h2>
      </header>

      <div class="support-overview__grid">
        {
          data.cards.map((item) => {
            const live = Boolean(item.href && item.href !== "#" && item.href.trim().length);

            return live ? (
              <a class="support-card support-card--link" href={item.href} aria-label={`${item.ctaLabel}: ${item.title}`}>
                <div class="support-card__media">
                  <img src={item.image} alt={item.imageAlt} width="1200" height="675" loading="lazy" decoding="async" />
                  <span class="support-card__badge">{item.badge}</span>
                </div>
                <div class="support-card__body">
                  <p class="support-card__stat">{item.stat}</p>
                  <h3>{item.title}</h3>
                  <p class="support-card__excerpt">{item.excerpt}</p>
                  <span class="support-card__cta">
                    {item.ctaLabel} <span aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            ) : (
              <article class="support-card">
                <div class="support-card__media">
                  <img src={item.image} alt={item.imageAlt} width="1200" height="675" loading="lazy" decoding="async" />
                  <span class="support-card__badge">{item.badge}</span>
                </div>
                <div class="support-card__body">
                  <p class="support-card__stat">{item.stat}</p>
                  <h3>{item.title}</h3>
                  <p class="support-card__excerpt">{item.excerpt}</p>
                  <span class="support-card__coming-soon">Coming Soon</span>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .support-overview {
    background: #f5f8fd;
    padding: clamp(2rem, 5vw, 3rem) 0 clamp(3rem, 7vw, 4.5rem);
  }

  .support-overview__intro {
    text-align: center;
    margin-bottom: 1.3rem;
  }

  .support-overview__eyebrow {
    margin: 0 0 0.35rem;
    font-size: var(--type-micro);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2f5c92;
  }

  .support-overview__intro h2 {
    margin: 0;
    font-size: var(--type-section-title);
    color: #132949;
  }

  .support-overview__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .support-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #dce5f2;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 6px 16px rgba(19, 47, 82, 0.08);
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.2s var(--motion-ease-out),
      box-shadow 0.2s var(--motion-ease-out);
  }

  .support-card--link:hover,
  .support-card--link:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(16, 38, 72, 0.13);
  }

  .support-card--link:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
  }

  .support-card__media {
    position: relative;
    aspect-ratio: 16 / 7;
    overflow: hidden;
  }

  .support-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .support-card__badge {
    position: absolute;
    left: 12px;
    bottom: 10px;
    display: inline-block;
    border-radius: 999px;
    padding: 3px 9px;
    font-size: 0.62rem;
    line-height: 1.25;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(10, 32, 62, 0.86);
    border: 1px solid rgba(255, 255, 255, 0.22);
  }

  .support-card__body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    min-height: 178px;
  }

  .support-card__stat {
    margin: 0 0 8px;
    padding: 4px 8px;
    border-radius: 8px;
    font-size: var(--type-micro);
    line-height: 1.3;
    font-weight: 700;
    color: #365a89;
    background: #eef3fa;
  }

  .support-card h3 {
    margin: 0 0 8px;
    font-size: var(--type-card-title);
    line-height: 1.28;
    color: #10233f;
  }

  .support-card__excerpt {
    margin: 0;
    font-size: var(--type-body-small);
    line-height: 1.55;
    color: #42556f;
  }

  .support-card__cta,
  .support-card__coming-soon {
    margin-top: auto;
    padding-top: 12px;
    font-size: var(--type-body-small);
    font-weight: 800;
    color: var(--color-steel-blue-1);
  }

  .support-card__coming-soon {
    color: #6b7c95;
  }

  @media (max-width: 900px) {
    .support-overview__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .support-overview__intro {
      margin-bottom: 1.1rem;
    }
  }
</style>

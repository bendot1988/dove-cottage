---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import p from "../../../data/volunteer-your-time.json";
import contact from "../../../data/contact.json";
import { toTitleCase } from "../../../lib/titleCase";

const c = contact;
const telHref = `tel:${c.trustPhone.replace(/\s+/g, "")}`;
const asideTitle = toTitleCase("Get in touch");
const phoneLabel = toTitleCase("Phone");
const formLabel = toTitleCase("Enquiry");

const beaconAccount = (p.beaconAccount ?? "dovecottagedayhospice").trim();
const beaconVolunteerFormId = (p.beaconVolunteerFormId ?? "").trim();
const showVolunteerBeacon = Boolean(beaconVolunteerFormId);
const volunteerFormHeading = toTitleCase(p.volunteerFormHeading ?? "Volunteer enquiry form");
const volunteerFormHref = showVolunteerBeacon ? "#volunteer-enquiry-form" : "/contact/";
const resolveRolePdfHref = (role: {
  pdfFile?: string;
  pdfHref?: string;
  ctaHref?: string;
}) => {
  const pdfFile = role.pdfFile?.trim();
  if (pdfFile) return pdfFile;
  const pdfHref = role.pdfHref?.trim();
  if (pdfHref) return pdfHref;
  const legacyHref = role.ctaHref?.trim();
  if (legacyHref) return legacyHref;
  return "";
};
---

<BaseLayout title={p.pageTitle}>
  <div class="svc-page volunteer-page">
    <section class="hospice-svc-hero" aria-label={p.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={p.heroImage}
        alt={p.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={p.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {toTitleCase(p.parentNavLabel)}
        </a>
        <h1>{p.heroH1}</h1>
        <p class="hospice-svc-hero-dek">{p.heroShortDescription}</p>
      </div>
    </section>

    <div class="motion-scope">
      <section class="svc-main" aria-label={p.heroH1}>
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            <h2 class="svc-section-h2">{p.introHeading}</h2>
            <p class="svc-lede">{p.introParagraph1}</p>
            <p class="svc-lede">{p.introParagraph2}</p>
            {
              p.sectionImage?.src && (
                <figure class="svc-figure">
                  <img
                    class="svc-figure__img"
                    src={p.sectionImage.src}
                    alt={p.sectionImage.alt}
                    width="1200"
                    height="675"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              )
            }

            <h2 class="svc-section-h2">{p.waysHeading}</h2>
            <p class="svc-lede svc-lede--after-h2">{p.waysIntro}</p>

            <div class="volunteer-role-grid">
              {p.roles.map((role) => (
                <article class="svc-card">
                  <h3 class="svc-card__subtitle">{role.title}</h3>
                  <p class="svc-body">{role.description}</p>
                  {
                    resolveRolePdfHref(role) && (
                      <p class="svc-body">
                        <a class="svc-inline-link" href={resolveRolePdfHref(role)} target="_blank" rel="noopener noreferrer">
                          {role.pdfLabel ?? role.ctaLabel ?? "Download PDF"}
                        </a>
                      </p>
                    )
                  }
                </article>
              ))}
            </div>

            <h2 class="svc-section-h2">{p.expectHeading}</h2>
            <p class="svc-lede">{p.expectParagraph1}</p>
            <p class="svc-lede">{p.expectParagraph2}</p>
            <p class="svc-lede">{p.expectParagraph3}</p>

            {
              showVolunteerBeacon && (
                <div class="volunteer-beacon-wrap" id="volunteer-enquiry-form">
                  <h2 class="svc-section-h2 volunteer-beacon-heading">{volunteerFormHeading}</h2>
                  {p.volunteerFormIntro && <p class="svc-lede volunteer-beacon-intro">{p.volunteerFormIntro}</p>}
                  <div class="volunteer-form-embed form-embed-card">
                    <div class="beacon-form" data-account={beaconAccount} data-form={beaconVolunteerFormId} />
                  </div>
                </div>
              )
            }
          </div>

          <aside class="svc-side" aria-label={asideTitle}>
            <div class="side-card">
              <h2 class="side-card-title">{asideTitle}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{phoneLabel}</span>
                    <a class="side-value side-link" href={telHref}>{c.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{formLabel}</span>
                    <a
                      class="side-form-scroll-btn"
                      href={volunteerFormHref}
                      aria-label={showVolunteerBeacon ? "Scroll to the volunteer enquiry form on this page" : undefined}
                    >
                      <span>{p.sideFormLinkText}</span>
                      {
                        showVolunteerBeacon && (
                          <svg class="side-form-scroll-btn__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 5v14" />
                            <path d="m19 12-7 7-7-7" />
                          </svg>
                        )
                      }
                    </a>
                    <p class="svc-side-hint">{p.sideFormHint}</p>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(c.sideCharityFooter)}</p>
            </div>

            <ArchiveSidebarPeek filterId="support-us" excludePath="/support-us/volunteer-your-time" />
          </aside>
        </div>
      </section>
    </div>
  </div>
  {showVolunteerBeacon && (
    <script is:inline>
      !function(e,t){if(!e.getElementById(t)){var c=e.createElement("script");c.id=t,c.src="https://static.beaconproducts.co.uk/js-sdk/production/beaconcrm.min.js",e.getElementsByTagName("head")[0].appendChild(c)}}(document,"beacon-js-sdk");
    </script>
  )}
</BaseLayout>

<script>
  import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
  initMotionScrollReveal();
</script>

<style>
  .volunteer-page .svc-primary .svc-section-h2:first-of-type {
    margin-top: 0;
  }

  .volunteer-role-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px 20px;
    margin-bottom: 1.1rem;
  }

  @media (max-width: 760px) {
    .volunteer-role-grid {
      grid-template-columns: 1fr;
    }
  }

  #volunteer-enquiry-form {
    scroll-margin-top: 5.5rem;
  }

  .volunteer-beacon-wrap {
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(29, 80, 141, 0.14);
  }

  .volunteer-beacon-heading {
    margin-top: 0;
  }

  .volunteer-beacon-intro {
    margin-top: 0.35rem;
  }

  .side-form-scroll-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 4px;
    padding: 10px 14px;
    border-radius: 999px;
    border: 1px solid #204a81;
    background: #fff;
    color: #204a81;
    font-size: var(--type-body-small);
    font-weight: 700;
    text-decoration: none;
    line-height: 1.2;
    transition:
      background 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .side-form-scroll-btn:hover,
  .side-form-scroll-btn:focus-visible {
    background: #f2f6fc;
    border-color: var(--color-steel-blue-1);
    color: var(--color-steel-blue-1);
    box-shadow: 0 2px 8px rgba(29, 101, 178, 0.12);
  }

  .side-form-scroll-btn:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
  }

  .side-form-scroll-btn__arrow {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .form-embed-card {
    background: #fff;
    border: 1px solid #d9e3f0;
    border-radius: 16px;
    padding: 10px;
    box-shadow: 0 8px 22px rgba(18, 44, 83, 0.07);
    margin-top: 0.5rem;
  }

  :global(.volunteer-form-embed .beacon-form) {
    width: 100%;
    min-height: 560px;
  }
</style>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import fallbackData from "../../../data/leave-a-gift-in-your-will.json";
import fallbackContact from "../../../data/contact.json";
import { sanityClient } from "../../../lib/sanity";
import { fetchSingletonPageJson } from "../../../lib/sanitySingleton";
import { toTitleCase } from "../../../lib/titleCase";

const structuredData = await sanityClient.fetch(`
  *[_type == "leaveGiftInWillPage" && _id == "leaveGiftInWillPage.main"][0]{
    pageTitle,
    metaDescription,
    heroImage,
    heroImageAlt,
    parentNavLabel,
    parentNavHref,
    heroH1,
    heroShortDescription,
    lastingGiftHeading,
    lastingGiftParagraphs,
    legacyHeading,
    legacyParagraphs,
    typesHeading,
    typesParagraphs,
    typesList,
    whyHeading,
    whyParagraphs,
    makingHeading,
    makingParagraphs,
    freeWillTitle,
    freeWillParagraphs,
    freeWillCtaLabel,
    freeWillCtaHref,
    codicilsHeading,
    codicilsParagraphs
  }
`);
const normalizeParagraphs = (items) =>
  Array.isArray(items)
    ? items.map((item) => (typeof item === "string" ? item : item?.text || "")).filter(Boolean)
    : [];
const data = structuredData
  ? {
      ...fallbackData,
      ...structuredData,
      lastingGiftParagraphs: normalizeParagraphs(structuredData.lastingGiftParagraphs),
      legacyParagraphs: normalizeParagraphs(structuredData.legacyParagraphs),
      typesParagraphs: normalizeParagraphs(structuredData.typesParagraphs),
      typesList: normalizeParagraphs(structuredData.typesList),
      whyParagraphs: normalizeParagraphs(structuredData.whyParagraphs),
      makingParagraphs: normalizeParagraphs(structuredData.makingParagraphs),
      freeWillParagraphs: normalizeParagraphs(structuredData.freeWillParagraphs),
      codicilsParagraphs: normalizeParagraphs(structuredData.codicilsParagraphs),
    }
  : fallbackData;
const contact = (await fetchSingletonPageJson<typeof fallbackContact>("contact")) ?? fallbackContact;
const telHref = `tel:${contact.trustPhone.replace(/\s+/g, "")}`;
---

<BaseLayout
  title={data.pageTitle}
  description={data.metaDescription}
>
  <div class="svc-page legacy-page">
    <section class="hospice-svc-hero" aria-label={data.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={data.heroImage}
        alt={data.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={data.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {toTitleCase(data.parentNavLabel)}
        </a>
        <h1>{data.heroH1}</h1>
        <p class="hospice-svc-hero-dek">
          {data.heroShortDescription}
        </p>
      </div>
    </section>

    <div class="motion-scope">
      <section class="svc-main" aria-label="Legacy giving information">
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            <h2 class="svc-section-h2">{data.lastingGiftHeading}</h2>
            {data.lastingGiftParagraphs.map((paragraph) => <p class="svc-lede">{paragraph}</p>)}

            <h2 class="svc-section-h2">{data.legacyHeading}</h2>
            {data.legacyParagraphs.map((paragraph) => <p class="svc-lede">{paragraph}</p>)}

            <h2 class="svc-section-h2">{data.typesHeading}</h2>
            {data.typesParagraphs.map((paragraph) => <p class="svc-lede">{paragraph}</p>)}
            <ul class="legacy-list">
              {data.typesList.map((item) => <li>{item}</li>)}
            </ul>

            <h2 class="svc-section-h2">{data.whyHeading}</h2>
            {data.whyParagraphs.map((paragraph) => <p class="svc-lede">{paragraph}</p>)}

            <h2 class="svc-section-h2">{data.makingHeading}</h2>
            {data.makingParagraphs.map((paragraph) => <p class="svc-lede">{paragraph}</p>)}

            <div class="svc-card legacy-highlight">
              <h3 class="svc-card__subtitle">{data.freeWillTitle}</h3>
              {data.freeWillParagraphs.map((paragraph) => <p class="svc-body">{paragraph}</p>)}
              <p class="svc-body">
                <a
                  class="svc-inline-link"
                  href={data.freeWillCtaHref}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {data.freeWillCtaLabel}
                </a>
              </p>
            </div>

            <h2 class="svc-section-h2">{data.codicilsHeading}</h2>
            {data.codicilsParagraphs.map((paragraph) => <p class="svc-lede">{paragraph}</p>)}
          </div>

          <aside class="svc-side" aria-label={toTitleCase("Get in touch")}>
            <div class="side-card">
              <h2 class="side-card-title">{toTitleCase("Get in touch")}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{toTitleCase("Phone")}</span>
                    <a class="side-value side-link" href={telHref}>{contact.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{toTitleCase("Email")}</span>
                    <a class="side-value side-link" href={`mailto:${contact.email}`}>{contact.email}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{toTitleCase("Contact form")}</span>
                    <a class="side-value side-link" href="/contact/">Use Our Contact Form</a>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(contact.sideCharityFooter)}</p>
            </div>

            <ArchiveSidebarPeek filterId="support-us" excludePath="/support-us/leave-a-gift-in-your-will" />
          </aside>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
  initMotionScrollReveal();
</script>

<style>
  .legacy-list {
    margin: 0.25rem 0 1.2rem 1.2rem;
    padding: 0;
    color: #354a67;
    line-height: 1.6;
  }

  .legacy-list li {
    margin-bottom: 0.55rem;
  }

  .legacy-highlight {
    margin-top: 0.9rem;
    margin-bottom: 1.1rem;
  }
</style>

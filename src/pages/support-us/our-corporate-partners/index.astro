---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import fallbackData from "../../../data/our-corporate-partners.json";
import fallbackContact from "../../../data/contact.json";
import { resolveSanityImageUrl, sanityClient } from "../../../lib/sanity";
import { fetchSingletonPageJson } from "../../../lib/sanitySingleton";
import { toTitleCase } from "../../../lib/titleCase";

const structuredData = await sanityClient.fetch(`
  *[_type == "ourCorporatePartnersPage"][0]{
    pageTitle,
    metaDescription,
    heroImage,
    heroImageAlt,
    parentNavLabel,
    parentNavHref,
    heroH1,
    heroShortDescription,
    introParagraph1,
    introParagraph2,
    partners,
    closingParagraph,
    closingCtaLabel,
    closingCtaHref
  }
`);
const singletonData =
  (await fetchSingletonPageJson<typeof fallbackData>("our_corporate_partners")) ?? null;
const data = structuredData ?? singletonData ?? fallbackData;
const contact = (await fetchSingletonPageJson<typeof fallbackContact>("contact")) ?? fallbackContact;
const telHref = `tel:${contact.trustPhone.replace(/\s+/g, "")}`;
const partners = data.partners.map((partner) => {
  const legacyLogo = typeof partner.logo === "object" && partner.logo !== null ? partner.logo.legacyUrl || "" : "";
  return {
    ...partner,
    logo: resolveSanityImageUrl(
      typeof partner.logo === "object" && partner.logo !== null ? partner.logo.image ?? partner.logo : partner.logo,
      legacyLogo || (typeof partner.logo === "string" ? partner.logo : "")
    ),
  };
});
---

<BaseLayout title={data.pageTitle} description={data.metaDescription}>
  <div class="svc-page corporate-partners-page">
    <section class="hospice-svc-hero" aria-label={data.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={data.heroImage}
        alt={data.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={data.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {toTitleCase(data.parentNavLabel)}
        </a>
        <h1>{data.heroH1}</h1>
        <p class="hospice-svc-hero-dek">{data.heroShortDescription}</p>
      </div>
    </section>

    <div class="motion-scope">
      <section class="svc-main" aria-label={data.heroH1}>
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            <p class="svc-lede">{data.introParagraph1}</p>
            <p class="svc-lede">{data.introParagraph2}</p>

            <div class="partner-grid">
              {partners.map((partner) => (
                <article class="partner-card">
                  <a href={partner.website} target="_blank" rel="noopener noreferrer" aria-label={`Visit ${partner.name} website`}>
                    <img src={partner.logo} alt={partner.logoAlt || `${partner.name} logo`} loading="lazy" decoding="async" />
                    <h3>{partner.name}</h3>
                  </a>
                </article>
              ))}
            </div>

            <p class="svc-lede">{data.closingParagraph}</p>
            <p class="svc-lede">
              <a class="svc-inline-link" href={data.closingCtaHref}>{data.closingCtaLabel}</a>
            </p>
          </div>

          <aside class="svc-side" aria-label={toTitleCase("Get in touch")}>
            <div class="side-card">
              <h2 class="side-card-title">{toTitleCase("Get in touch")}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{toTitleCase("Phone")}</span>
                    <a class="side-value side-link" href={telHref}>{contact.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{toTitleCase("Email")}</span>
                    <a class="side-value side-link" href={`mailto:${contact.email}`}>{contact.email}</a>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(contact.sideCharityFooter)}</p>
            </div>

            <ArchiveSidebarPeek filterId="support-us" excludePath="/support-us/our-corporate-partners" />
          </aside>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
  initMotionScrollReveal();
</script>

<style>
  .partner-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin: 1rem 0 1.35rem;
  }

  .partner-card {
    background: #fff;
    border: 1px solid #dce5f2;
    border-radius: 12px;
    padding: 12px;
  }

  .partner-card a {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .partner-card img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    background: #f9fbff;
    border-radius: 8px;
    border: 1px solid #e7edf8;
    padding: 10px;
    box-sizing: border-box;
  }

  .partner-card h3 {
    margin: 0.65rem 0 0;
    font-size: var(--type-body);
    color: #153a6d;
    text-align: center;
  }

  @media (max-width: 980px) {
    .partner-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .partner-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveSidebarPeek from "../../../components/ArchiveSidebarPeek.astro";
import fallbackData from "../../../data/corporate-partnerships.json";
import fallbackContact from "../../../data/contact.json";
import { sanityClient } from "../../../lib/sanity";
import { fetchSingletonPageJson } from "../../../lib/sanitySingleton";
import { toEachWordCapitalized, toTitleCase } from "../../../lib/titleCase";

const structuredData = await sanityClient.fetch(`
  *[_type == "corporatePartnershipsPage"][0]{
    pageTitle,
    metaDescription,
    heroImage,
    heroImageAlt,
    parentNavLabel,
    parentNavHref,
    heroH1,
    heroShortDescription,
    intro,
    visionTitle,
    visionBody,
    whatWeDoBody,
    missionParagraphs,
    ways,
    donations,
    sponsorshipBody,
    expectIntro,
    ctaBody
  }
`);
const singletonData =
  (await fetchSingletonPageJson<typeof fallbackData>("corporate_partnerships")) ?? null;
const data = structuredData ?? singletonData ?? fallbackData;
const contact = (await fetchSingletonPageJson<typeof fallbackContact>("contact")) ?? fallbackContact;
const telHref = `tel:${contact.trustPhone.replace(/\s+/g, "")}`;
const cap = toEachWordCapitalized;
const pageHeading = data.heroH1;
const layoutTitle = data.pageTitle;
const corporateIntroPackHref = "/resources/dove-corporate-intro-pack.pdf";

---

<BaseLayout title={layoutTitle} description={data.metaDescription}>
  <div class="svc-page corporate-page">
    <section class="hospice-svc-hero" aria-label={pageHeading}>
      <img
        class="hospice-svc-hero-bg"
        src={data.heroImage}
        alt={data.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={data.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {cap(data.parentNavLabel)}
        </a>
        <h1>{pageHeading}</h1>
        <p class="hospice-svc-hero-dek">{data.heroShortDescription}</p>
      </div>
    </section>

    <div class="motion-scope">
      <section class="svc-main" aria-label={pageHeading}>
        <img
          src="/images/sunflower-brand-small.png"
          alt=""
          class="svc-sunflower"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="container svc-layout">
          <div class="svc-primary">
            <p class="svc-lede corporate-intro">{data.intro}</p>
            <h2 class="svc-section-h2">{cap(data.visionTitle)}</h2>
            <p class="svc-lede">{data.visionBody}</p>
            <p class="svc-lede">{data.whatWeDoBody}</p>
            {data.missionParagraphs.map((p) => <p class="svc-lede">{p}</p>)}

            <ul class="corporate-main-list">
              {data.ways.map((item) => (
                <li class="svc-body">
                  <strong>{item.title}:</strong> {item.body}
                </li>
              ))}
              {data.donations.map((item) => (
                <li class="svc-body">
                  <strong>{item.title}:</strong> {item.body}
                </li>
              ))}
            </ul>

            <p class="svc-lede">{data.sponsorshipBody}</p>
            <p class="svc-lede">{data.expectIntro}</p>
            <a
              class="corporate-download"
              href={corporateIntroPackHref}
              download
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Download the Dove Cottage corporate intro pack PDF"
            >
              <span class="corporate-download__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <path d="M14 2v6h6" />
                  <path d="M12 12v6" />
                  <path d="m9.5 15 2.5 3 2.5-3" />
                </svg>
              </span>
              <span>
                <strong>Download Corporate Intro Pack</strong>
                <small>PDF · opens in a new tab</small>
              </span>
            </a>
            <p class="svc-lede">{data.ctaBody}</p>
            <p class="svc-lede">
              <a class="svc-inline-link" href={telHref}>{contact.trustPhoneDisplay}</a>
              {" · "}
              <a class="svc-inline-link" href={`mailto:${contact.email}`}>{contact.email}</a>
              {" · "}
              <a class="svc-inline-link" href="/contact/">{cap("Contact form")}</a>
            </p>
          </div>

          <aside class="svc-side" aria-label={toTitleCase("Get in touch")}>
            <div class="side-card">
              <h2 class="side-card-title">{toTitleCase("Get in touch")}</h2>
              <ul class="side-list">
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{toTitleCase("Phone")}</span>
                    <a class="side-value side-link" href={telHref}>{contact.trustPhoneDisplay}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{toTitleCase("Email")}</span>
                    <a class="side-value side-link" href={`mailto:${contact.email}`}>{contact.email}</a>
                  </div>
                </li>
                <li>
                  <span class="side-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
                    </svg>
                  </span>
                  <div>
                    <span class="side-label">{toTitleCase("Contact form")}</span>
                    <a class="side-value side-link" href="/contact/">Use our contact form</a>
                  </div>
                </li>
              </ul>
              <p class="side-charity">{toTitleCase(contact.sideCharityFooter)}</p>
            </div>

            <ArchiveSidebarPeek filterId="support-us" excludePath="/support-us/corporate-partnerships" />
          </aside>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  import { initMotionScrollReveal } from "../../../scripts/motion-scroll-reveal.ts";
  initMotionScrollReveal();
</script>

<style>
  .corporate-intro {
    font-size: var(--type-body-large);
    font-weight: 600;
    color: #2a3f5c;
  }

  .corporate-main-list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .corporate-main-list > li {
    margin: 0;
    padding: 14px 16px;
    border: 1px solid #dce5f2;
    border-radius: 10px;
    background: #fbfcfe;
  }

  .corporate-download {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 0.25rem 0 1.1rem;
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid #cddbef;
    background: #f6f9ff;
    color: #173b6d;
    text-decoration: none;
    box-shadow: 0 4px 12px rgba(16, 38, 72, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .corporate-download:hover,
  .corporate-download:focus-visible {
    transform: translateY(-1px);
    border-color: #b8cae6;
    box-shadow: 0 10px 22px rgba(16, 38, 72, 0.14);
    outline: none;
  }

  .corporate-download__icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(29, 80, 141, 0.1);
    color: #1d4f92;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .corporate-download__icon svg {
    width: 21px;
    height: 21px;
  }

  .corporate-download strong {
    display: block;
    font-size: var(--type-body);
    line-height: 1.25;
  }

  .corporate-download small {
    display: block;
    margin-top: 2px;
    color: #4a6387;
    font-size: var(--type-body-small);
    line-height: 1.3;
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fallbackData from "../../data/make-a-referral.json";
import { fetchSingletonPageJson } from "../../lib/sanitySingleton";
import { marked } from "marked";

const data = (await fetchSingletonPageJson<typeof fallbackData>("make_a_referral")) ?? fallbackData;
const introHtml = marked.parse(data.introMarkdown.trim(), { async: false }) as string;
const bodyHtml = marked.parse(data.bodyMarkdown.trim(), { async: false }) as string;
---

<BaseLayout title={data.pageTitle} description={data.heroShortDescription}>
  <div class="svc-page">
    <section class="hospice-svc-hero" aria-label={data.heroH1}>
      <img
        class="hospice-svc-hero-bg"
        src={data.heroImage}
        alt={data.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hospice-svc-hero-overlay" aria-hidden="true"></div>
      <div class="container hospice-svc-hero-inner">
        <a class="interior-hero-eyebrow" href={data.parentNavHref}>
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {data.parentNavLabel}
        </a>
        <h1>{data.heroH1}</h1>
        <p class="hospice-svc-hero-dek">{data.heroShortDescription}</p>
      </div>
    </section>

    <section class="svc-main referral-main" aria-label={data.heroH1}>
      <div class="container referral-container">
        <div class="referral-content">
          <div class="referral-intro" set:html={introHtml} />
        <figure class="svc-figure">
          <img
            class="svc-figure__img"
            src={data.heroImage}
            alt={data.heroImageAlt}
            width="1200"
            height="675"
            loading="lazy"
            decoding="async"
          />
        </figure>
          <div class="referral-body" set:html={bodyHtml} />
        </div>
        <div class="referral-form-wrap">
          <div class="beacon-form" data-account={data.beaconAccount} data-form={data.beaconFormId}></div>
        </div>
      </div>
    </section>
  </div>
  <script is:inline>
    !function(e,t){if(!e.getElementById(t)){var c=e.createElement("script");c.id=t,c.src="https://static.beaconproducts.co.uk/js-sdk/production/beaconcrm.min.js",e.getElementsByTagName("head")[0].appendChild(c)}}(document,"beacon-js-sdk");
  </script>
</BaseLayout>

<style>
  .hospice-svc-hero-overlay {
    background: linear-gradient(105deg, rgba(8, 22, 48, 0.88) 0%, rgba(8, 22, 48, 0.62) 45%, rgba(8, 22, 48, 0.38) 100%);
  }

  .hospice-svc-hero h1,
  .hospice-svc-hero-dek {
    color: #fff;
  }

  .referral-main {
    padding-top: clamp(2rem, 5vw, 3rem);
  }

  .referral-container {
    max-width: 820px;
  }

  .referral-content {
    background: #fff;
    border: 1px solid #d9e3f0;
    border-radius: 16px;
    padding: clamp(1rem, 3vw, 1.5rem);
    box-shadow: 0 8px 22px rgba(18, 44, 83, 0.07);
  }

  .referral-content :global(h2) {
    margin: 1.8rem 0 0.65rem;
    color: #0f2240;
    font-size: clamp(1.15rem, 2vw, 1.35rem);
  }

  .referral-content :global(h2:first-child) {
    margin-top: 0.25rem;
  }

  .referral-content :global(p),
  .referral-content :global(li) {
    color: #2c3f5d;
    line-height: 1.65;
  }

  .referral-content :global(p) {
    margin: 0 0 0.9rem;
  }

  .referral-content :global(ul) {
    margin: 0 0 1rem 1.2rem;
    padding: 0;
  }

  .referral-content :global(a) {
    color: var(--color-steel-blue);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .referral-form-wrap {
    margin-top: 1.5rem;
    background: #fff;
    border: 1px solid #d9e3f0;
    border-radius: 16px;
    padding: 10px;
    box-shadow: 0 8px 22px rgba(18, 44, 83, 0.07);
  }

  :global(.beacon-form) {
    width: 100%;
    min-height: 560px;
  }
</style>

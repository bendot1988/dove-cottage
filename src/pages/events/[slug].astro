---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EventKeyInfo from "../../components/EventKeyInfo.astro";
import { resolveSanityImageUrl, sanityClient } from "../../lib/sanity";
import { portableTextToHtml } from "../../lib/portableText";
import { estimateReadingTimeLabel } from "../../lib/readTime";

export async function getStaticPaths() {
  const events = await sanityClient.fetch(`
    *[_type == "eventPost" && !coalesce(draft, false) && defined(slug.current)]{
      "slug": slug.current
    }
  `);
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event }
  }));
}

const { event } = Astro.props as { event: { slug: string } };
const entry = await sanityClient.fetch(
  `
    *[_type == "eventPost" && slug.current == $slug][0]{
      title,
      excerpt,
      category,
      eventDate,
      eventEndDate,
      location,
      featuredImage,
      bookingUrl,
      body
    }
  `,
  { slug: event.slug }
);

if (!entry) {
  throw new Error(`Event not found for slug: ${event.slug}`);
}

const eventStart = entry.eventDate ? new Date(entry.eventDate) : new Date();
const eventEnd = entry.eventEndDate ? new Date(entry.eventEndDate) : undefined;
const comparisonDate = eventEnd ?? eventStart;
const now = new Date();
const isPastEvent = comparisonDate.getTime() < now.getTime();
const contentHtml = portableTextToHtml(entry.body);
const featuredImageUrl = resolveSanityImageUrl(entry.featuredImage, "");
const heroImageUrl = featuredImageUrl || "/images/uploads/news/latest-news-featured.png";
const readingTimeLabel = estimateReadingTimeLabel(contentHtml);
---

<BaseLayout title={`${entry.title} | Dove Cottage`} description={entry.excerpt}>
  <section class="story-hero" aria-label="Event">
    <img
      class="story-hero-bg"
      src={heroImageUrl}
      alt=""
      width="1920"
      height="720"
      loading="eager"
      fetchpriority="high"
    />
    <div class="story-hero-overlay" aria-hidden="true"></div>
    <div class="container story-hero-inner">
      <a href="/news/" class="interior-hero-eyebrow">
        <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
        Back to News &amp; Events
      </a>
      <p class="story-hero-meta">
        <span class="story-hero-category">{entry.category}</span>
        <span>·</span>
        <span>{readingTimeLabel}</span>
      </p>
      {isPastEvent && <p class="past-flag">Past event</p>}
      <h1 class:list={{ "is-past": isPastEvent }}>{entry.title}</h1>
    </div>
  </section>

  <article class="event-post">
    <div class="motion-scope">
      <section class="event-article-inner" aria-label="Event">
        <div class="container container--narrow">
          <EventKeyInfo
            eventStart={eventStart}
            eventEnd={eventEnd}
            location={entry.location}
          />

          <div class="content">
            <div set:html={contentHtml} />
            {entry.bookingUrl && !isPastEvent && (
              <p class="event-booking">
                <a href={entry.bookingUrl} target="_blank" rel="noopener noreferrer">
                  Book event tickets
                </a>
              </p>
            )}
          </div>
          <p class="back-link back-link--bottom">
            <a href="/news/">← Back to News &amp; Events</a>
          </p>
        </div>
      </section>
    </div>
  </article>
  <script>
    import { initMotionScrollReveal } from "../../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

<style>
  .story-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: min(52vh, 460px);
    padding: clamp(2.75rem, 6vw, 3.8rem) 0 clamp(2rem, 5vw, 3rem);
    color: #fff;
    overflow: hidden;
  }

  .story-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .story-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(110deg, rgba(8, 22, 48, 0.9) 0%, rgba(8, 22, 48, 0.62) 46%, rgba(8, 22, 48, 0.42) 100%);
  }

  .story-hero-inner {
    position: relative;
    z-index: 2;
  }

  .story-hero-meta {
    margin: 0 0 0.8rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: var(--type-body-small);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .story-hero-category {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-golden-yellow);
    font-weight: 800;
  }

  .event-post {
    background: var(--color-lavender);
    padding: 40px 0 72px;
  }

  .past-flag {
    margin: 0 0 8px;
    font-size: var(--type-micro);
    font-weight: 800;
    color: #8e5b3e;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0;
    max-width: 18ch;
    font-size: var(--type-hero-title);
    color: #fff;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  h1.is-past {
    text-decoration: line-through;
    text-decoration-thickness: 2px;
    text-decoration-color: rgba(142, 91, 62, 0.42);
  }

  .content {
    background: #fff;
    border-radius: 14px;
    border: 1px solid #dce5f2;
    padding: 22px;
    color: #304662;
    line-height: 1.7;
  }

  .event-booking a {
    color: var(--color-steel-blue);
    font-weight: 700;
  }

  .back-link {
    margin: 0;
    font-size: var(--type-body-small);
  }

  .back-link--bottom {
    margin-top: 14px;
  }

  .back-link a {
    color: var(--color-steel-blue);
    font-weight: 700;
    text-decoration: none;
  }

  .back-link a:hover {
    text-decoration: underline;
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import archive from "../../data/site-archive.json";
import contact from "../../data/contact.json";
import { toTitleCase } from "../../lib/titleCase";
import hospiceServicesOverviewData from "../../data/hospice-services-overview.json";
import carerPatientWellbeingData from "../../data/carer-patient-wellbeing.json";
import dementiaHomeSittingData from "../../data/dementia-home-sitting.json";
import counsellingSupportOverviewData from "../../data/counselling-support-overview.json";
import bereavementSupportData from "../../data/bereavement-support.json";
import bereavementSupportGroupData from "../../data/bereavement-support-group.json";
import counsellingData from "../../data/counselling.json";
import nursingCareData from "../../data/nursing-care-medical-advice.json";
import wellbeingActivitiesData from "../../data/wellbeing-activities.json";
import complementaryTherapiesData from "../../data/complementary-therapies.json";
import therapyBathingData from "../../data/therapy-bathing.json";
import spiritualChaplaincyData from "../../data/spiritual-chaplaincy-support.json";
import transportData from "../../data/transport.json";
import supportGroupsData from "../../data/support-groups.json";
import carerSupportData from "../../data/carer-support.json";
import mensShedData from "../../data/mens-shed.json";
import hireFacilitiesData from "../../data/hire-our-facilities.json";
import supportUsOverviewData from "../../data/support-us-overview.json";
import volunteerData from "../../data/volunteer-your-time.json";
import donateData from "../../data/donate.json";

const c = contact;
const telHref = `tel:${c.trustPhone.replace(/\s+/g, "")}`;

const layoutTitle = archive.pageTitle
  .split(/\s*\|\s*/)
  .map((part) => toTitleCase(part.trim()))
  .join(" | ");

const titleCaseCharity = toTitleCase(c.trustCharityLine);
const trustDonate = toTitleCase(c.trustDonateLabel);
const isLiveHref = (h: string) => Boolean(h && h !== "#" && h.trim().length);

function filterKeysList(raw: string): string[] {
  return raw
    .split(/[,]+/)
    .map((k) => k.trim())
    .filter(Boolean);
}

const filterLabelById = new Map(archive.filters.map((f) => [f.id, f.label]));
function categoryLabelsForKeys(keys: string[]): string[] {
  return keys.map((id) => filterLabelById.get(id) ?? id);
}

type HeroRef = { heroImage: string; heroImageAlt: string };

const featuredByHref = new Map<string, HeroRef>([
  ["/hospice-services/", { heroImage: hospiceServicesOverviewData.heroImage, heroImageAlt: hospiceServicesOverviewData.heroImageAlt }],
  ["/what-we-offer/carer-patient-wellbeing/", { heroImage: carerPatientWellbeingData.heroImage, heroImageAlt: carerPatientWellbeingData.heroImageAlt }],
  ["/what-we-offer/dementia-home-sitting/", { heroImage: dementiaHomeSittingData.heroImage, heroImageAlt: dementiaHomeSittingData.heroImageAlt }],
  ["/hospice-services/counselling-support/", { heroImage: counsellingSupportOverviewData.heroImage, heroImageAlt: counsellingSupportOverviewData.heroImageAlt }],
  ["/hospice-services/bereavement-support/", { heroImage: bereavementSupportData.heroImage, heroImageAlt: bereavementSupportData.heroImageAlt }],
  ["/hospice-services/bereavement-support-group/", { heroImage: bereavementSupportGroupData.heroImage, heroImageAlt: bereavementSupportGroupData.heroImageAlt }],
  ["/hospice-services/counselling/", { heroImage: counsellingData.heroImage, heroImageAlt: counsellingData.heroImageAlt }],
  ["/hospice-services/nursing-care-medical-advice/", { heroImage: nursingCareData.heroImage, heroImageAlt: nursingCareData.heroImageAlt }],
  ["/hospice-services/wellbeing-activities/", { heroImage: wellbeingActivitiesData.heroImage, heroImageAlt: wellbeingActivitiesData.heroImageAlt }],
  ["/hospice-services/complementary-therapies/", { heroImage: complementaryTherapiesData.heroImage, heroImageAlt: complementaryTherapiesData.heroImageAlt }],
  ["/hospice-services/therapy-bathing/", { heroImage: therapyBathingData.heroImage, heroImageAlt: therapyBathingData.heroImageAlt }],
  ["/hospice-services/spiritual-chaplaincy-support/", { heroImage: spiritualChaplaincyData.heroImage, heroImageAlt: spiritualChaplaincyData.heroImageAlt }],
  ["/hospice-services/transport/", { heroImage: transportData.heroImage, heroImageAlt: transportData.heroImageAlt }],
  ["/hospice-services/support-groups/", { heroImage: supportGroupsData.heroImage, heroImageAlt: supportGroupsData.heroImageAlt }],
  ["/hospice-services/carer-support/", { heroImage: carerSupportData.heroImage, heroImageAlt: carerSupportData.heroImageAlt }],
  ["/hospice-services/mens-shed/", { heroImage: mensShedData.heroImage, heroImageAlt: mensShedData.heroImageAlt }],
  ["/hire-our-facilities/", { heroImage: hireFacilitiesData.heroImage, heroImageAlt: hireFacilitiesData.heroImageAlt }],
  ["/support-us/", { heroImage: supportUsOverviewData.heroImage, heroImageAlt: supportUsOverviewData.heroImageAlt }],
  ["/support-us/volunteer-your-time/", { heroImage: volunteerData.heroImage, heroImageAlt: volunteerData.heroImageAlt }],
  ["/donate/", { heroImage: donateData.heroImage, heroImageAlt: donateData.heroImageAlt }]
]);

const syncedItems = archive.items.map((item) => {
  const featured = featuredByHref.get(item.href);
  return featured
    ? { ...item, image: featured.heroImage, imageAlt: featured.heroImageAlt }
    : item;
});
---

<BaseLayout title={layoutTitle}>
  <div class="archive-page" id="archive-explore">
    <section class="archive-hero" aria-label={archive.heroH1}>
      <img
        class="archive-hero-bg"
        src={archive.heroImage}
        alt={archive.heroImageAlt}
        width="1920"
        height="720"
        loading="eager"
        fetchpriority="high"
      />
      <div class="archive-hero-overlay" aria-hidden="true"></div>
      <div class="container archive-hero-inner">
        <a class="interior-hero-eyebrow" href="/">
          <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
          {toTitleCase("Home")}
        </a>
        <h1 class="archive-hero-h1">{archive.heroH1}</h1>
        <p class="archive-hero-dek">{archive.heroDescription}</p>
      </div>
    </section>

    <div class="contact-trust" aria-label="Key details">
      <div class="container contact-trust-inner">
        <span class="contact-trust-charity">{titleCaseCharity}</span>
        <div class="contact-trust-actions">
          <a class="contact-trust-phone" href={telHref}>☎ {c.trustPhoneDisplay}</a>
          <a href={c.trustDonateUrl} class="btn btn-primary btn-shine contact-trust-donate">{trustDonate}</a>
        </div>
      </div>
    </div>

    <div class="motion-scope">
      <section class="archive-section" aria-label="Service and support directory">
        <div class="container">
          <div
            class="archive-filter"
            role="group"
            aria-label="Filter by topic"
          >
            {
              archive.filters.map((f) => (
                <button
                  type="button"
                  class="archive-filter-btn"
                  data-archive-filter={f.id}
                  id={`archive-filter-${f.id}`}
                  aria-pressed={f.id === "all" ? "true" : "false"}
                >
                  {f.label}
                </button>
              ))
            }
          </div>

          <div class="archive-grid">
            {
              syncedItems.map((item) => {
                const keys = filterKeysList(item.filterKeys);
                const dataFilters = keys.join(" ");
                const tagLabels = categoryLabelsForKeys(keys);
                const live = isLiveHref(item.href);
                return live ? (
                  <a
                    class="archive-card archive-card--link"
                    href={item.href}
                    data-archive-item
                    data-filters={dataFilters}
                    aria-label={`Read more about ${item.title}`}
                  >
                    <div class="archive-card-visual">
                      <img
                        class="archive-card-img"
                        src={item.image}
                        alt={item.imageAlt}
                        width="1200"
                        height="675"
                        loading="lazy"
                        decoding="async"
                      />
                      <div class="archive-card-shade" aria-hidden="true"></div>
                      <div class="archive-card-herocopy">
                        {
                          tagLabels.length > 0 && (
                            <ul class="archive-card-tags" aria-label="Category">
                              {tagLabels.map((label) => (
                                <li>
                                  <span class="archive-card-tag">{label}</span>
                                </li>
                              ))}
                            </ul>
                          )
                        }
                        <h2 class="archive-card-title">{toTitleCase(item.title)}</h2>
                      </div>
                    </div>
                    <div class="archive-card-body">
                      <p class="archive-card-excerpt">{item.excerpt}</p>
                      <span class="archive-card-cta">
                        Read more <span aria-hidden="true">→</span>
                      </span>
                    </div>
                  </a>
                ) : (
                  <article
                    class="archive-card"
                    data-archive-item
                    data-filters={dataFilters}
                  >
                    <div class="archive-card-visual">
                      <img
                        class="archive-card-img"
                        src={item.image}
                        alt={item.imageAlt}
                        width="1200"
                        height="675"
                        loading="lazy"
                        decoding="async"
                      />
                      <div class="archive-card-shade" aria-hidden="true"></div>
                      <div class="archive-card-herocopy">
                        {
                          tagLabels.length > 0 && (
                            <ul class="archive-card-tags" aria-label="Category">
                              {tagLabels.map((label) => (
                                <li>
                                  <span class="archive-card-tag">{label}</span>
                                </li>
                              ))}
                            </ul>
                          )
                        }
                        <h2 class="archive-card-title">{toTitleCase(item.title)}</h2>
                      </div>
                    </div>
                    <div class="archive-card-body">
                      <p class="archive-card-excerpt">{item.excerpt}</p>
                      <span class="archive-card-soon">Coming soon</span>
                    </div>
                  </article>
                );
              })
            }
          </div>
        </div>
      </section>
    </div>
  </div>
  <script>
    import { initArchiveFilter } from "../../scripts/archive-filter.ts";
    import { initMotionScrollReveal } from "../../scripts/motion-scroll-reveal.ts";
    initArchiveFilter();
    initMotionScrollReveal();
  </script>
</BaseLayout>

<style>
  .archive-page {
    position: relative;
  }

  .archive-hero {
    position: relative;
    isolation: isolate;
    min-height: min(40vh, 400px);
    display: flex;
    align-items: center;
    padding: clamp(2rem, 5vw, 2.75rem) 0;
    color: #fff;
    text-align: left;
    overflow: hidden;
  }

  .archive-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    z-index: 0;
  }

  .archive-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(100deg, rgba(8, 22, 48, 0.9) 0%, rgba(8, 22, 48, 0.55) 50%, rgba(8, 22, 48, 0.35) 100%);
  }

  .archive-hero-inner {
    position: relative;
    z-index: 2;
  }

  .archive-hero-h1 {
    margin: 0 0 0.5rem;
    max-width: 20ch;
    font-size: var(--type-hero-title);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .archive-hero-dek {
    margin: 0;
    max-width: 38rem;
    font-size: var(--type-body-large);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.95);
  }

  .archive-section {
    background: var(--color-lavender);
    padding: 40px 0 72px;
  }

  .archive-filter {
    display: grid;
    width: 100%;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 8px 10px;
    margin: 0 0 10px;
    padding-bottom: 10px;
    border-bottom: 1px solid #d0d8e8;
  }

  .archive-filter-btn {
    width: 100%;
    box-sizing: border-box;
    cursor: pointer;
    border: 1px solid #c1cde0;
    background: #fff;
    color: #1a3558;
    font-family: inherit;
    font-size: var(--type-body-small);
    font-weight: 700;
    line-height: 1.2;
    padding: 0.5rem 0.65rem;
    text-align: center;
    border-radius: 999px;
    transition:
      background 0.18s var(--motion-ease-out),
      color 0.18s var(--motion-ease-out),
      border-color 0.18s var(--motion-ease-out),
      box-shadow 0.18s var(--motion-ease-out);
  }

  .archive-filter-btn:hover,
  .archive-filter-btn:focus-visible {
    border-color: var(--color-steel-blue-1);
    color: var(--color-steel-blue-1);
  }

  .archive-filter-btn:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
  }

  .archive-filter-btn.is-active,
  .archive-filter-btn[aria-pressed="true"] {
    background: var(--color-steel-blue-1);
    color: #fff;
    border-color: var(--color-steel-blue-1);
    box-shadow: 0 3px 10px rgba(29, 101, 178, 0.28);
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px 18px;
  }

  .archive-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 14px;
    border: 1px solid #dde6f4;
    overflow: hidden;
    box-shadow: 0 6px 16px rgba(18, 44, 83, 0.07);
    transition: box-shadow 0.2s var(--motion-ease-out), transform 0.2s var(--motion-ease-out);
  }

  .archive-card--link {
    text-decoration: none;
    color: inherit;
  }

  @media (hover: hover) and (pointer: fine) {
    .archive-card:hover {
      box-shadow: 0 12px 28px rgba(16, 38, 72, 0.12);
      transform: translateY(-2px);
    }
  }

  .archive-card--link:focus-visible {
    outline: 2px solid var(--color-golden-yellow);
    outline-offset: 2px;
  }

  .archive-card[hidden] {
    display: none;
  }

  .archive-card-visual {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #e2e8f0;
  }

  .archive-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1);
    transform-origin: center;
    transition: transform 0.55s var(--motion-ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .archive-card:hover .archive-card-img {
      transform: scale(1.05);
    }
  }

  .archive-card-shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(5, 18, 40, 0.1) 0%, rgba(5, 18, 40, 0.58) 55%, rgba(5, 18, 40, 0.82) 100%);
  }

  .archive-card-herocopy {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 10px 14px 12px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .archive-card-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 8px;
  }

  .archive-card-tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    line-height: 1.35;
    color: #0f2240;
    background: var(--color-golden-yellow);
    border: 1px solid rgba(15, 34, 64, 0.12);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.12);
  }

  .archive-card-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 800;
    line-height: 1.25;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }

  .archive-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 14px 16px 16px;
    gap: 12px;
  }

  .archive-card-excerpt {
    margin: 0;
    font-size: var(--type-body);
    line-height: 1.5;
    color: #2f3f5a;
  }

  .archive-card-cta {
    margin-top: auto;
    font-size: var(--type-body-small);
    font-weight: 800;
    color: var(--color-steel-blue-1);
  }

  .archive-card--link:focus-visible .archive-card-cta {
    text-decoration: underline;
  }

  .archive-card-soon {
    margin-top: auto;
    font-size: var(--type-body-small);
    font-weight: 700;
    color: #6a7a92;
  }

  @media (max-width: 1020px) {
    .archive-filter {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .archive-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .archive-hero {
      min-height: min(32vh, 300px);
    }

    .archive-grid {
      grid-template-columns: 1fr;
    }

    .archive-filter {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .archive-card,
    .archive-filter-btn {
      transition: none;
    }

    .archive-card:hover {
      transform: none;
    }

    .archive-card-img {
      transition: none;
    }

    .archive-card:hover .archive-card-img {
      transform: none;
    }
  }
</style>

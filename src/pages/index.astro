---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import CareServicesSection from "../components/CareServicesSection.astro";
import FeaturedNewsSection from "../components/FeaturedNewsSection.astro";
import VideoFeatureSection from "../components/VideoFeatureSection.astro";
import HomeShopsSection from "../components/HomeShopsSection.astro";
import ReachSection from "../components/ReachSection.astro";
import SupportCardsSection from "../components/SupportCardsSection.astro";
import fallbackHomepage from "../data/homepage.json";
import fallbackHospiceServicesOverview from "../data/hospice-services-overview.json";
import fallbackCarerPatientWellbeing from "../data/carer-patient-wellbeing.json";
import fallbackDementiaHomeSitting from "../data/dementia-home-sitting.json";
import fallbackCounsellingSupportOverview from "../data/counselling-support-overview.json";
import { resolveSanityImageUrl, sanityClient } from "../lib/sanity";
import { fetchSingletonPageJson } from "../lib/sanitySingleton";

const structuredHomepage = await sanityClient.fetch(`
  *[_type == "homepagePage"][0]{
    hero,
    careServices,
    videoFeature,
    shopsSection,
    reachSection,
    supportSection
  }
`);
const singletonHomepage =
  (await fetchSingletonPageJson<typeof fallbackHomepage>("homepage-content")) ?? null;

const DEFAULT_VINTED_URL =
  "https://www.vinted.co.uk/member/252874220?fbclid=IwY2xjawQ4pd9leHRuA2FlbQIxMABicmlkETFJdGhyNEREbkhVVFdOemJuc3J0YwZhcHBfaWQQMjIyMDM5MTc4ODIwMDg5MgABHi00iNDgOAYkIWBCIO2gz7E0lGbWoqMMkaJKvTCL6QZLgYkElq5qttzhr_5Z_aem_EU0jUNIxlOzWEsOvaSEbsA";
const DEFAULT_EBAY_URL = "https://www.charity.ebay.co.uk/charity/i/Dove-Cottage-Day-Hospice/99401";

function mergeHomepageForSite(
  structured: typeof structuredHomepage,
  singleton: typeof singletonHomepage,
  fb: typeof fallbackHomepage
) {
  const src = structured ?? singleton;
  if (!src) return fb;

  const fbCards = fb.supportSection.cards;
  const srcCards = src.supportSection?.cards ?? fbCards;
  const cards = srcCards.map((card, i) => ({
    ...(fbCards[i] ?? fbCards[0]),
    ...card,
    icon: resolveSanityImageUrl(card.icon, fbCards[i]?.icon ?? "")
  }));

  return {
    ...fb,
    ...src,
    hero: {
      ...fb.hero,
      ...src.hero,
      backgroundImage: resolveSanityImageUrl(src.hero?.backgroundImage, fb.hero.backgroundImage),
      ctas: src.hero?.ctas ?? fb.hero.ctas
    },
    careServices: { ...fb.careServices, ...src.careServices },
    videoFeature: { ...fb.videoFeature, ...src.videoFeature },
    shopsSection: {
      ...fb.shopsSection,
      ...src.shopsSection,
      vintedUrl:
        src.shopsSection?.vintedUrl && src.shopsSection.vintedUrl !== "#"
          ? src.shopsSection.vintedUrl
          : fb.shopsSection.vintedUrl && fb.shopsSection.vintedUrl !== "#"
            ? fb.shopsSection.vintedUrl
            : DEFAULT_VINTED_URL,
      ebayUrl:
        src.shopsSection?.ebayUrl && src.shopsSection.ebayUrl !== "#"
          ? src.shopsSection.ebayUrl
          : fb.shopsSection.ebayUrl && fb.shopsSection.ebayUrl !== "#"
            ? fb.shopsSection.ebayUrl
            : DEFAULT_EBAY_URL,
      sunflowerImage: resolveSanityImageUrl(src.shopsSection?.sunflowerImage, fb.shopsSection.sunflowerImage)
    },
    reachSection: {
      ...fb.reachSection,
      ...src.reachSection,
      backgroundImage: resolveSanityImageUrl(src.reachSection?.backgroundImage, fb.reachSection.backgroundImage)
    },
    supportSection: {
      ...fb.supportSection,
      ...src.supportSection,
      backgroundFlowerLeft: resolveSanityImageUrl(
        src.supportSection?.backgroundFlowerLeft,
        fb.supportSection.backgroundFlowerLeft
      ),
      backgroundFlowerRight: resolveSanityImageUrl(
        src.supportSection?.backgroundFlowerRight,
        fb.supportSection.backgroundFlowerRight
      ),
      cards
    }
  };
}

const homepage = mergeHomepageForSite(structuredHomepage, singletonHomepage, fallbackHomepage);
const hospiceServicesOverview =
  (await fetchSingletonPageJson<typeof fallbackHospiceServicesOverview>("hospice_services_overview")) ??
  fallbackHospiceServicesOverview;
const carerPatientWellbeing =
  (await fetchSingletonPageJson<typeof fallbackCarerPatientWellbeing>("carer_patient_wellbeing")) ??
  fallbackCarerPatientWellbeing;
const dementiaHomeSitting =
  (await fetchSingletonPageJson<typeof fallbackDementiaHomeSitting>("dementia_home_sitting")) ??
  fallbackDementiaHomeSitting;
const counsellingSupportOverview =
  (await fetchSingletonPageJson<typeof fallbackCounsellingSupportOverview>("counselling_support_overview")) ??
  fallbackCounsellingSupportOverview;

const careServiceCards = [
  {
    tag: "Tue-Thu | 10am-3pm",
    title: hospiceServicesOverview.heroH1,
    description: hospiceServicesOverview.homepageCareCardExcerpt,
    image: hospiceServicesOverview.heroImage,
    imagePosition: "center 42%",
    href: "/hospice-services/"
  },
  {
    tag: "Mondays | 10am-1pm",
    title: "Carer & Patient Wellbeing",
    description: carerPatientWellbeing.homepageCareCardExcerpt,
    image: carerPatientWellbeing.heroImage,
    imagePosition: "center 45%",
    href: "/what-we-offer/carer-patient-wellbeing/"
  },
  {
    tag: "Dementia Support",
    title: dementiaHomeSitting.heroH1,
    description: dementiaHomeSitting.homepageCareCardExcerpt,
    image: dementiaHomeSitting.heroImage,
    imagePosition: "center 48%",
    href: "/what-we-offer/dementia-home-sitting/"
  },
  {
    tag: "Counselling & Support",
    title: counsellingSupportOverview.heroH1,
    description: counsellingSupportOverview.homepageCareCardExcerpt,
    image: counsellingSupportOverview.heroImage,
    imagePosition: "center 40%",
    href: "/hospice-services/counselling-support/"
  }
];

const featuredNews = (await getCollection("blog", ({ data }) => !data.draft))
  .sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
  )
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    category: post.data.category,
    excerpt: post.data.excerpt,
    image: post.data.featuredImage ?? post.data.featured_image,
    slug: post.slug
  }));

const homeShops = (await getCollection("shops", ({ data }) => !data.draft))
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .map((s) => ({
    slug: s.slug,
    image: s.data.shop_main_image,
    label: (s.data.hero_location ?? s.data.title).toUpperCase()
  }));
---

<BaseLayout
  title="Dove Cottage"
  description="Dove Cottage Day Hospice provides free palliative care, counselling and family support across Leicestershire, Nottinghamshire and Lincolnshire."
>
  <div class="page-home motion-scope">
    <HeroSection {...homepage.hero} />
    <CareServicesSection
      title={homepage.careServices.title}
      intro={homepage.careServices.intro}
      cards={careServiceCards}
    />
    <VideoFeatureSection {...homepage.videoFeature} />
    <HomeShopsSection {...homepage.shopsSection} shops={homeShops} />
    <ReachSection {...homepage.reachSection} />
    <SupportCardsSection {...homepage.supportSection} />
    {featuredNews.length > 0 && <FeaturedNewsSection posts={featuredNews} />}
  </div>
  <script>
    import { initMotionScrollReveal } from "../scripts/motion-scroll-reveal.ts";
    initMotionScrollReveal();
  </script>
</BaseLayout>

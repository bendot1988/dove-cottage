---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Donation Thank You | Dove Cottage" noindex={true}>
  <section class="thanks-hero" aria-label="Donation thank you">
    <img
      class="thanks-hero-bg"
      src="/images/hero-supporting-journey.png"
      alt="People supported by Dove Cottage Day Hospice"
      width="1920"
      height="720"
      loading="eager"
      fetchpriority="high"
    />
    <div class="thanks-hero-overlay" aria-hidden="true"></div>
    <div class="container thanks-hero-inner">
      <a class="interior-hero-eyebrow" href="/">
        <span class="interior-hero-eyebrow__arrow" aria-hidden="true">←</span>
        Home
      </a>
      <h1>Thank You</h1>
      <p class="thanks-hero-dek">Your support makes a real difference to local families.</p>
    </div>
  </section>

  <section class="thanks-main">
    <div class="container thanks-card">
      <h2>We really appreciate your donation.</h2>
      <p>
        Thank you for your donation to Dove Cottage Day Hospice. We've emailed you a receipt for your records.
      </p>
      <p>
        Your generosity helps us continue providing compassionate care and support to people across our local community.
      </p>
      <div class="thanks-actions">
        <a class="btn btn-primary btn-shine" href="/">Return to Home</a>
        <a class="btn btn-secondary" href="/support-us/">More Ways to Support Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks-hero {
    position: relative;
    min-height: min(44vh, 360px);
    display: flex;
    align-items: center;
    color: #fff;
    overflow: hidden;
  }

  .thanks-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .thanks-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(100deg, rgba(8, 22, 48, 0.88) 0%, rgba(8, 22, 48, 0.52) 100%);
  }

  .thanks-hero-inner {
    position: relative;
    z-index: 2;
  }

  .thanks-hero h1 {
    margin: 0 0 0.6rem;
    font-size: var(--type-hero-title);
    line-height: 1.12;
    color: #fff;
  }

  .thanks-hero-dek {
    margin: 0;
    font-size: var(--type-body-large);
    color: rgba(255, 255, 255, 0.94);
  }

  .thanks-main {
    background: var(--color-lavender);
    padding: clamp(2.4rem, 6vw, 4rem) 0;
  }

  .thanks-card {
    background: #fff;
    border: 1px solid #d9e3f0;
    border-radius: 16px;
    box-shadow: 0 10px 26px rgba(18, 44, 83, 0.08);
    padding: clamp(1.2rem, 3vw, 2rem);
    max-width: 760px;
  }

  .thanks-card h2 {
    margin: 0 0 0.7rem;
    color: #102a4e;
  }

  .thanks-card p {
    margin: 0 0 0.8rem;
    color: #3b4d66;
    line-height: 1.6;
  }

  .thanks-card p:last-of-type {
    margin-bottom: 0;
  }

  .thanks-actions {
    margin-top: 1.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
</style>
